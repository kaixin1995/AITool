@page
@model AITool.Web.Pages.IndexModel
@{
    ViewData["Title"] = "仪表盘";
}

<!-- 欢迎横幅 -->
<div class="welcome-banner">
    <h1>欢迎使用 AI Tool 管理平台</h1>
    <p>统一管理站点、模型、代理路由与密钥</p>
</div>

<!-- 统计卡片 -->
<div class="row g-4 mb-4">
    <div class="col-xl-2 col-lg-4 col-md-4 col-sm-6">
        <a href="/Admin/Sites" class="stat-card">
            <div class="stat-card-icon primary">🌐</div>
            <div class="stat-card-value">@Model.EnabledSiteCount</div>
            <div class="stat-card-label">启用站点</div>
        </a>
    </div>
    <div class="col-xl-2 col-lg-4 col-md-4 col-sm-6">
        <a href="/Admin/Models" class="stat-card">
            <div class="stat-card-icon success">🧠</div>
            <div class="stat-card-value">@Model.ModelCount</div>
            <div class="stat-card-label">模型总数</div>
        </a>
    </div>
    <div class="col-xl-2 col-lg-4 col-md-4 col-sm-6">
        <a href="/Admin/Routes" class="stat-card">
            <div class="stat-card-icon warning">🔀</div>
            <div class="stat-card-value">@Model.RouteRuleCount</div>
            <div class="stat-card-label">路由规则</div>
        </a>
    </div>
    <div class="col-xl-2 col-lg-4 col-md-4 col-sm-6">
        <a href="/Admin/AccessKeys" class="stat-card">
            <div class="stat-card-icon danger">🔑</div>
            <div class="stat-card-value">@Model.EnabledKeyCount</div>
            <div class="stat-card-label">启用密钥</div>
        </a>
    </div>
    <div class="col-xl-2 col-lg-4 col-md-4 col-sm-6">
        <a href="/Admin/DetectionTasks" class="stat-card">
            <div class="stat-card-icon purple">⏰</div>
            <div class="stat-card-value">@Model.EnabledTaskCount</div>
            <div class="stat-card-label">启用检测任务</div>
        </a>
    </div>
</div>

<!-- 快捷操作 -->
<div class="quick-actions">
    <h6 style="font-weight:600; margin-bottom:16px; font-size:14px;">快捷操作</h6>
    <div class="row g-2">
        <div class="col-lg-3 col-md-4 col-sm-6">
            <a href="/Admin/Sites/Create" class="quick-action-link">
                <span class="quick-action-icon" style="background:var(--primary-light);color:var(--primary);">＋</span>
                <span>新增站点</span>
            </a>
        </div>
        <div class="col-lg-3 col-md-4 col-sm-6">
            <a href="/Admin/Models/Create" class="quick-action-link">
                <span class="quick-action-icon" style="background:var(--success-light);color:var(--success);">＋</span>
                <span>新增模型</span>
            </a>
        </div>
        <div class="col-lg-3 col-md-4 col-sm-6">
            <a href="/Admin/Routes" class="quick-action-link">
                <span class="quick-action-icon" style="background:var(--warning-light);color:var(--warning);">🔀</span>
                <span>配置路由</span>
            </a>
        </div>
        <div class="col-lg-3 col-md-4 col-sm-6">
            <a href="/Admin/UsageLogs" class="quick-action-link">
                <span class="quick-action-icon" style="background:var(--info-light);color:var(--info);">📋</span>
                <span>查看日志</span>
            </a>
        </div>
    </div>
</div>
