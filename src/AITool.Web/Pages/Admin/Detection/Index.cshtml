@page
@model AITool.Web.Pages.Admin.Detection.IndexModel
@{
    ViewData["Title"] = "模型检测";
}

<!-- 页面标题 -->
<div class="page-header">
    <div>
        <h2 class="page-title">模型检测</h2>
        <p class="page-subtitle">按模型分组查看各站点的可用性和响应状态</p>
    </div>
    <form method="post" asp-page-handler="ProbeAll" class="d-inline">
        <button type="submit" class="btn btn-primary">全部检测</button>
    </form>
</div>

<!-- 检测结果提示 -->
@if (Model.ProbeMessage is not null)
{
    <div class="alert alert-@(Model.ProbeSuccess ? "success" : "danger")">
        @Model.ProbeMessage
    </div>
}

<!-- 按模型分组展示 -->
@if (!Model.ModelGroups.Any())
{
    <div class="table-wrapper">
        <div class="table-empty">
            <div class="table-empty-icon">🔍</div>
            <div class="table-empty-text">暂无映射数据，请先配置站点和模型</div>
        </div>
    </div>
}

@foreach (var group in Model.ModelGroups)
{
    <div class="detection-group">
        <div class="detection-group-header">
            <div>
                <h3 class="detection-group-title">@group.DisplayName</h3>
                <span class="badge bg-light text-dark"><code>@group.ModelName</code></span>
            </div>
            <form method="post" asp-page-handler="ProbeModel" asp-route-modelId="@group.ModelLibraryItemId" class="d-inline">
                <button type="submit" class="btn btn-sm btn-outline-primary">检测该模型</button>
            </form>
        </div>
        <div class="table-wrapper">
            <table class="table">
                <thead>
                    <tr>
                        <th>站点名称</th>
                        <th>远程模型名</th>
                        <th>最近状态</th>
                        <th>最近检测时间</th>
                        <th>耗时</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var site in group.Sites)
                    {
                        <tr>
                            <td><strong>@site.SiteName</strong></td>
                            <td><code>@site.RemoteModelName</code></td>
                            <td>
                                <span class="badge bg-@(site.LastStatus == "success" ? "success" : site.LastStatus == "fail" ? "danger" : "secondary")">
                                    @site.LastStatus
                                </span>
                            </td>
                            <td>@(site.LastCheckedAt?.ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</td>
                            <td>@(site.LastDurationMs.HasValue ? $"{site.LastDurationMs} ms" : "-")</td>
                            <td>
                                <form method="post" asp-page-handler="Probe" asp-route-mappingId="@site.MappingId" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-primary">检测</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
