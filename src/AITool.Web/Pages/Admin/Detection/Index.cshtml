@page
@model AITool.Web.Pages.Admin.Detection.IndexModel
@{
    ViewData["Title"] = "模型检测";
}

<!-- 页面标题 -->
<div class="page-header">
    <div>
        <h2 class="page-title">模型检测</h2>
        <p class="page-subtitle">按模型分组查看各站点的可用性和响应状态</p>
    </div>
    <div class="d-flex gap-2">
        <button type="button" id="btnProbeAll" class="btn btn-primary">全部检测</button>
    </div>
</div>

<!-- 检测进度提示 -->
<div id="probeAlert" style="display:none;" class="alert alert-info">
    <span id="probeAlertText"></span>
</div>

<!-- 模型搜索过滤 -->
<div class="form-card" style="margin-bottom:20px;">
    <div class="row g-2 align-items-end">
        <div class="col-md-4">
            <label class="form-label">搜索模型</label>
            <input type="text" id="modelSearch" class="form-control" placeholder="输入模型名称过滤..." oninput="filterModels()" />
        </div>
    </div>
</div>

<!-- 按模型分组展示 -->
@if (!Model.ModelGroups.Any())
{
    <div class="table-wrapper">
        <div class="table-empty">
            <div class="table-empty-icon">🔍</div>
            <div class="table-empty-text">暂无映射数据，请先配置站点和模型</div>
        </div>
    </div>
}

@foreach (var group in Model.ModelGroups)
{
    <div class="detection-group" data-model-id="@group.ModelLibraryItemId" data-display-name="@group.DisplayName">
        <div class="detection-group-header">
            <div>
                <h3 class="detection-group-title">@group.DisplayName</h3>
                <span class="badge bg-light text-dark"><code>@group.ModelName</code></span>
            </div>
            <div class="d-flex gap-2">
                <button type="button" class="btn btn-sm btn-outline-primary btn-probe-model"
                        data-model-id="@group.ModelLibraryItemId">
                    检测该模型
                </button>
            </div>
        </div>
        <div class="table-wrapper">
            <table class="table">
                <thead>
                    <tr>
                        <th>站点名称</th>
                        <th>远程模型名</th>
                        <th>最近状态</th>
                        <th>最近检测时间</th>
                        <th>耗时</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var site in group.Sites)
                    {
                        <tr data-mapping-id="@site.MappingId">
                            <td style="max-width:15%;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="@site.SiteName"><strong>@site.SiteName</strong></td>
                            <td style="max-width:20%;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="@site.RemoteModelName"><code>@site.RemoteModelName</code></td>
                            <td class="status-cell">
                                <span class="badge bg-@(site.LastStatus == "success" ? "success" : site.LastStatus == "fail" ? "danger" : "secondary")">
                                    @site.LastStatus
                                </span>
                            </td>
                            <td class="time-cell">@(site.LastCheckedAt?.ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</td>
                            <td class="duration-cell">@(site.LastDurationMs.HasValue ? $"{site.LastDurationMs} ms" : "-")</td>
                            <td>
                                <button type="button" class="btn btn-sm btn-primary btn-probe-single"
                                        data-mapping-id="@site.MappingId">
                                    检测
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<script>
    document.addEventListener('DOMContentLoaded', function() {
        /* 单条检测 */
        document.querySelectorAll('.btn-probe-single').forEach(function(btn) {
            btn.addEventListener('click', function() {
                var mappingId = this.getAttribute('data-mapping-id');
                var btn = this;
                btn.disabled = true;
                btn.textContent = '检测中...';

                fetch('/api/admin/detection/probe/' + mappingId, { method: 'POST' })
                    .then(function(r) { return r.json(); })
                    .then(function(data) {
                        updateRow(btn.closest('tr'), data);
                        btn.disabled = false;
                        btn.textContent = '检测';
                    })
                    .catch(function(err) {
                        alert('检测失败：' + err.message);
                        btn.disabled = false;
                        btn.textContent = '检测';
                    });
            });
        });

        /* 检测该模型 */
        document.querySelectorAll('.btn-probe-model').forEach(function(btn) {
            btn.addEventListener('click', function() {
                var modelId = this.getAttribute('data-model-id');
                var btn = this;
                btn.disabled = true;
                btn.textContent = '检测中...';

                fetch('/api/admin/detection/probe-model/' + modelId, { method: 'POST' })
                    .then(function(r) { return r.json(); })
                    .then(function(data) {
                        pollProbeProgress(data.taskId, btn, '检测该模型');
                    })
                    .catch(function(err) {
                        alert('启动检测失败：' + err.message);
                        btn.disabled = false;
                        btn.textContent = '检测该模型';
                    });
            });
        });

        /* 全部检测 */
        document.getElementById('btnProbeAll').addEventListener('click', function() {
            var btn = this;
            btn.disabled = true;
            btn.textContent = '检测中...';

            fetch('/api/admin/detection/probe-all', { method: 'POST' })
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    pollProbeProgress(data.taskId, btn, '全部检测');
                })
                .catch(function(err) {
                    alert('启动检测失败：' + err.message);
                    btn.disabled = false;
                    btn.textContent = '全部检测';
                });
        });
    });

    /* 轮询检测进度 */
    function pollProbeProgress(taskId, triggerBtn, btnText) {
        var alert = document.getElementById('probeAlert');
        var alertText = document.getElementById('probeAlertText');
        alert.style.display = '';
        alert.className = 'alert alert-info';

        function poll() {
            fetch('/api/admin/detection/progress/' + taskId)
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    alertText.textContent = '正在检测... (' + data.completed + '/' + data.total + ')';
                    /* 实时更新已完成的行 */
                    data.results.forEach(function(r) {
                        var row = document.querySelector('tr[data-mapping-id="' + r.mappingId + '"]');
                        if (row) updateRow(row, r);
                    });

                    if (data.isCompleted) {
                        var sc = data.results.filter(function(r) { return r.status === 'success'; }).length;
                        var fc = data.results.filter(function(r) { return r.status === 'fail'; }).length;
                        alert.className = 'alert alert-success';
                        alertText.textContent = '检测完成：' + sc + ' 成功，' + fc + ' 失败';
                        if (triggerBtn) {
                            triggerBtn.disabled = false;
                            triggerBtn.textContent = btnText || '全部检测';
                        }
                    } else {
                        setTimeout(poll, 1000);
                    }
                })
                .catch(function() {
                    setTimeout(poll, 2000);
                });
        }
        poll();
    }

    /* 更新单行检测结果 */
    function updateRow(row, data) {
        var statusCell = row.querySelector('.status-cell');
        var timeCell = row.querySelector('.time-cell');
        var durationCell = row.querySelector('.duration-cell');

        if (statusCell) {
            var badge = statusCell.querySelector('.badge');
            if (badge) {
                badge.className = 'badge bg-' + (data.status === 'success' ? 'success' : data.status === 'fail' ? 'danger' : 'secondary');
                badge.textContent = data.status;
            }
        }
        if (timeCell) {
            var now = new Date();
            var y = now.getFullYear();
            var mo = String(now.getMonth() + 1).padStart(2, '0');
            var d = String(now.getDate()).padStart(2, '0');
            var h = String(now.getHours()).padStart(2, '0');
            var mi = String(now.getMinutes()).padStart(2, '0');
            var s = String(now.getSeconds()).padStart(2, '0');
            timeCell.textContent = y + '-' + mo + '-' + d + ' ' + h + ':' + mi + ':' + s;
        }
        if (durationCell && data.durationMs) {
            durationCell.textContent = data.durationMs + ' ms';
        }
    }

    /* 搜索过滤 */
    function filterModels() {
        var keyword = document.getElementById('modelSearch').value.toLowerCase();
        document.querySelectorAll('.detection-group').forEach(function(g) {
            var name = g.getAttribute('data-display-name').toLowerCase();
            g.style.display = name.indexOf(keyword) >= 0 ? '' : 'none';
        });
    }
</script>
