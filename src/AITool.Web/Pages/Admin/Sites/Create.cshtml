@page
@model AITool.Web.Pages.Admin.Sites.CreateModel
@{
    ViewData["Title"] = "新增站点";
}

<h1>新增站点</h1>

<form method="post" class="mb-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Command.Name" class="form-label">站点名称</label>
        <input asp-for="Command.Name" class="form-control" required />
        <span asp-validation-for="Command.Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Command.BaseUrl" class="form-label">根地址</label>
        <input asp-for="Command.BaseUrl" class="form-control" placeholder="https://api.example.com" required />
        <span asp-validation-for="Command.BaseUrl" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Command.ApiKey" class="form-label">访问密钥</label>
        <input asp-for="Command.ApiKey" class="form-control" type="password" required />
        <span asp-validation-for="Command.ApiKey" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Command.ProtocolType" class="form-label">协议类型</label>
        <select asp-for="Command.ProtocolType" class="form-select">
            <option value="OpenAI">OpenAI</option>
            <option value="Anthropic">Anthropic</option>
        </select>
    </div>

    <div class="mb-3 form-check">
        <input asp-for="Command.IsEnabled" class="form-check-input" type="checkbox" checked />
        <label asp-for="Command.IsEnabled" class="form-check-label">启用</label>
    </div>

    <button type="submit" class="btn btn-primary">保存</button>
    <a asp-page="./Index" class="btn btn-secondary">取消</a>
</form>
