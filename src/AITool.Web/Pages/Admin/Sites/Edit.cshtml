@page "{id:guid}"
@model AITool.Web.Pages.Admin.Sites.EditModel
@{
    ViewData["Title"] = "编辑站点";
}

<!-- 页面标题 -->
<div class="page-header">
    <div>
        <h2 class="page-title">编辑站点</h2>
        <p class="page-subtitle">修改站点配置信息</p>
    </div>
</div>

<!-- 状态提示 -->
@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert @(Model.StatusSuccess ? "alert-success" : "alert-danger")">
        @Model.StatusMessage
    </div>
}

<!-- 编辑表单 -->
<div class="form-card">
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="Name" class="form-label">站点名称</label>
            <input asp-for="Name" class="form-control" required />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="BaseUrl" class="form-label">根地址</label>
            <input asp-for="BaseUrl" class="form-control" placeholder="https://api.example.com" required />
            <span asp-validation-for="BaseUrl" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="EndpointPathMode" class="form-label form-label-tip">站点类型<span class="tip-icon" data-bs-toggle="tooltip" data-bs-placement="top" title="原生：请求地址会自动补 /v1，例如 /v1/chat/completions、/v1/messages。非原生：适用于地址本身已包含接口前缀的站点，例如 https://api.z.ai/api/coding/paas/v4，最终会直接拼接 /chat/completions、/messages。">?</span></label>
            <select asp-for="EndpointPathMode" class="form-select">
                <option value="standard-root">原生</option>
                <option value="versioned-base">非原生</option>
            </select>
        </div>

        <div class="mb-3">
            <label asp-for="ApiKey" class="form-label">访问密钥</label>
            <input asp-for="ApiKey" class="form-control" type="password" placeholder="留空则保持原有密钥" />
            <span asp-validation-for="ApiKey" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">支持协议</label>
            <div class="d-flex flex-column gap-2">
                <div class="form-check">
                    <input asp-for="SupportsOpenAi" class="form-check-input" type="checkbox" />
                    <label asp-for="SupportsOpenAi" class="form-check-label">支持 OpenAI</label>
                </div>
                <div class="form-check">
                    <input asp-for="SupportsAnthropic" class="form-check-input" type="checkbox" />
                    <label asp-for="SupportsAnthropic" class="form-check-label">支持 Anthropic</label>
                </div>
            </div>
            <span asp-validation-for="SupportsOpenAi" class="text-danger"></span>
        </div>

        <div class="mb-3 form-check">
            <input asp-for="IsEnabled" class="form-check-input" type="checkbox" />
            <label asp-for="IsEnabled" class="form-check-label">启用</label>
        </div>

        <div class="divider"></div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">保存</button>
            <a asp-page="./Index" class="btn btn-secondary">取消</a>
        </div>
    </form>
</div>

<script>
    document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (element) {
        new bootstrap.Tooltip(element);
    });
</script>
