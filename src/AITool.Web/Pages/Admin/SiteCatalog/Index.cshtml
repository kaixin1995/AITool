@page
@model AITool.Web.Pages.Admin.SiteCatalog.IndexModel
@{
    ViewData["Title"] = "站点模型拉取";
}

<!-- 页面标题 -->
<div class="page-header">
    <div>
        <h2 class="page-title">站点模型拉取</h2>
        <p class="page-subtitle">从各站点自动拉取可用模型并导入模型库</p>
    </div>
    <div class="d-flex gap-2">
        <button type="button" id="btnPullAll" class="btn btn-success">一键拉取全部站点</button>
    </div>
</div>

<!-- 状态提示 -->
@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert @(Model.StatusSuccess ? "alert-success" : "alert-danger")">
        @Model.StatusMessage
    </div>
}

<!-- 拉取结果提示 -->
@if (Model.PullResult is not null)
{
    <div class="alert alert-success">
        成功导入 @Model.PullResult.ImportedCount 个模型。
    </div>
}

<!-- 异步拉取进度面板 -->
<div id="progressPanel" class="form-card" style="display:none; margin-bottom:20px;">
    <div class="form-section-title">
        拉取进度 <span id="progressCount" class="badge bg-primary" style="font-size:12px;">0/0</span>
    </div>
    <!-- 总进度条 -->
    <div class="progress" style="height:8px; margin-bottom:12px;">
        <div id="progressBar" class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" style="width:0%"></div>
    </div>
    <!-- 各站点状态列表 -->
    <div id="siteStatusList"></div>
</div>

<!-- 站点列表表格 -->
<div class="table-wrapper">
    <table class="table">
        <thead>
            <tr>
                <th>站点名称</th>
                <th>协议类型</th>
                <th>已映射模型数</th>
                <th>状态</th>
                <th>操作</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Sites.Any())
            {
                <tr>
                    <td colspan="5">
                        <div class="table-empty">
                            <div class="table-empty-icon">📥</div>
                            <div class="table-empty-text">暂无站点数据，请先配置站点</div>
                        </div>
                    </td>
                </tr>
            }
            @foreach (var item in Model.Sites)
            {
                <tr>
                    <td><strong>@item.Name</strong></td>
                    <td><span class="badge bg-info">@item.ProtocolType</span></td>
                    <td><span class="badge bg-primary">@item.MappingCount</span></td>
                    <td>
                        <span class="badge bg-@(item.IsEnabled ? "success" : "secondary")">
                            @(item.IsEnabled ? "启用" : "禁用")
                        </span>
                    </td>
                    <td>
                        <form method="post" asp-page-handler="Pull" asp-route-siteId="@item.SiteId" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-primary" @(item.IsEnabled ? "" : "disabled")>拉取模型</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<script>
// 拉取全部站点的异步并发逻辑
(function () {
    var btn = document.getElementById('btnPullAll');
    var panel = document.getElementById('progressPanel');
    var bar = document.getElementById('progressBar');
    var count = document.getElementById('progressCount');
    var siteList = document.getElementById('siteStatusList');

    // 状态显示映射
    var statusMap = {
        pending: { text: '等待中', cls: 'bg-secondary' },
        running: { text: '拉取中...', cls: 'bg-info' },
        success: { text: '成功', cls: 'bg-success' },
        fail: { text: '失败', cls: 'bg-danger' }
    };

    btn.addEventListener('click', function () {
        btn.disabled = true;
        panel.style.display = 'block';
        bar.style.width = '0%';
        bar.className = 'progress-bar progress-bar-striped progress-bar-animated';
        siteList.innerHTML = '';

        // 发起异步拉取请求
        fetch('/api/admin/site-catalog/pull-all', { method: 'POST' })
            .then(function (r) { return r.json(); })
            .then(function (data) {
                if (!data.taskId) {
                    alert(data.message || '没有可拉取的站点');
                    btn.disabled = false;
                    panel.style.display = 'none';
                    return;
                }
                pollProgress(data.taskId);
            })
            .catch(function (err) {
                alert('请求失败：' + err.message);
                btn.disabled = false;
            });
    });

    // 轮询拉取进度
    function pollProgress(taskId) {
        fetch('/api/admin/site-catalog/pull-progress/' + taskId)
            .then(function (r) { return r.json(); })
            .then(function (data) {
                // 更新进度条和计数
                var pct = data.totalSites > 0 ? (data.completedSites / data.totalSites * 100) : 0;
                bar.style.width = pct.toFixed(0) + '%';
                count.textContent = data.completedSites + '/' + data.totalSites;

                // 渲染各站点状态
                var html = '';
                for (var i = 0; i < data.sites.length; i++) {
                    var s = data.sites[i];
                    var info = statusMap[s.status] || { text: s.status, cls: 'bg-secondary' };
                    var extra = s.importedCount > 0 ? ' (导入 ' + s.importedCount + ' 个)' : '';
                    var err = s.error ? ' <span class="text-danger" style="font-size:12px;">' + s.error + '</span>' : '';
                    html += '<div style="display:flex;align-items:center;gap:8px;padding:4px 0;font-size:13px;">';
                    html += '<span class="badge ' + info.cls + '">' + info.text + '</span>';
                    html += '<span>' + s.siteName + extra + err + '</span>';
                    html += '</div>';
                }
                siteList.innerHTML = html;

                // 完成后停止轮询
                if (data.isCompleted) {
                    bar.className = 'progress-bar';
                    bar.style.width = '100%';
                    btn.disabled = false;
                    // 完成后自动刷新页面更新映射计数
                    setTimeout(function () {
                        var msg = '拉取完成：共导入 ' + data.totalImported + ' 个模型';
                        if (data.failCount > 0) msg += '，' + data.failCount + ' 个站点失败';
                        alert(msg);
                        window.location.reload();
                    }, 800);
                    return;
                }

                // 继续轮询
                setTimeout(function () { pollProgress(taskId); }, 1000);
            })
            .catch(function () {
                setTimeout(function () { pollProgress(taskId); }, 2000);
            });
    }
})();
</script>
