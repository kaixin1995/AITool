@page
@model AITool.Web.Pages.Admin.UsageLogs.IndexModel
@{
    ViewData["Title"] = "调用日志";
}

<!-- 页面标题 -->
<div class="page-header">
    <div>
        <h2 class="page-title">调用日志</h2>
        <p class="page-subtitle">查看代理服务和对话测试的调用记录</p>
    </div>
</div>

<!-- 日志列表表格 -->
<div class="table-wrapper">
    <table class="table">
        <thead>
            <tr>
                <th>时间</th>
                <th>来源</th>
                <th>协议</th>
                <th>模型</th>
                <th>目标站点</th>
                <th>状态</th>
                <th>重试次数</th>
                <th>输入 Tokens</th>
                <th>输出 Tokens</th>
                <th>总 Tokens</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Logs.Any())
            {
                <tr>
                    <td colspan="10">
                        <div class="table-empty">
                            <div class="table-empty-icon">📋</div>
                            <div class="table-empty-text">暂无调用日志</div>
                        </div>
                    </td>
                </tr>
            }
            @foreach (var item in Model.Logs)
            {
                <tr>
                    <td>@item.RequestedAt.LocalDateTime.ToString("yyyy-MM-dd HH:mm:ss")</td>
                    <td>
                        <span class="badge bg-@(item.Source == "chat" ? "primary" : "secondary")">
                            @(item.Source == "chat" ? "对话测试" : "代理")
                        </span>
                    </td>
                    <td><span class="badge bg-info">@item.ProtocolType</span></td>
                    <td><code>@item.RequestModel</code></td>
                    <td>@item.SiteName</td>
                    <td>
                        <span class="badge bg-@(item.Status == "success" ? "success" : "danger")">
                            @(item.Status == "success" ? "成功" : "失败")
                        </span>
                    </td>
                    <td>
                        @if (item.RetryCount > 0)
                        {
                            <span class="badge bg-warning text-dark">@item.RetryCount</span>
                        }
                        else
                        {
                            <span class="text-secondary">0</span>
                        }
                    </td>
                    <td>@item.InputTokens</td>
                    <td>@item.OutputTokens</td>
                    <td><strong>@item.TotalTokens</strong></td>
                </tr>
            }
        </tbody>
    </table>
</div>
