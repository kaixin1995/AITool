@page
@model AITool.Web.Pages.Admin.UsageLogs.IndexModel
@{
    ViewData["Title"] = "调用日志";
}

<div class="page-header">
    <div>
        <h2 class="page-title">调用日志</h2>
        <p class="page-subtitle">查看代理服务和对话测试的调用记录</p>
    </div>
</div>

<div id="usageLogsStatus" class="alert" style="display:none;"></div>

<div class="card mb-3 usage-logs-filter-card">
    <div class="card-header usage-logs-filter-header">
        <button type="button" class="usage-logs-filter-toggle" id="usageLogsFilterToggle" aria-expanded="false" aria-controls="usageLogsFilterBody" onclick="toggleUsageLogsFilters()">
            <span>筛选与汇总</span>
            <span id="usageLogsFilterToggleText">展开</span>
        </button>
    </div>
    <div class="card-body d-none" id="usageLogsFilterBody">
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label" for="rangeTypeSelect">时间范围</label>
                <select id="rangeTypeSelect" class="form-select">
                    <option value="day" selected>按天</option>
                    <option value="week">按周</option>
                    <option value="month">按月</option>
                    <option value="all">全部</option>
                    <option value="custom">指定时间范围</option>
                </select>
            </div>
            <div class="col-md-3 custom-range-field" style="display:none;">
                <label class="form-label" for="startTimeInput">开始时间</label>
                <input id="startTimeInput" type="datetime-local" class="form-control">
            </div>
            <div class="col-md-3 custom-range-field" style="display:none;">
                <label class="form-label" for="endTimeInput">结束时间</label>
                <input id="endTimeInput" type="datetime-local" class="form-control">
            </div>
            <div class="col-md-3">
                <label class="form-label" for="siteFilterSelect">站点筛选</label>
                <select id="siteFilterSelect" class="form-select">
                    <option value="">全部站点</option>
                    @foreach (var site in Model.SiteFilters)
                    {
                        <option value="@site.Id">@site.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <div class="form-check form-switch mb-2">
                    <input class="form-check-input" type="checkbox" id="autoRefreshToggle" checked>
                    <label class="form-check-label" for="autoRefreshToggle">自动刷新（固定 5 秒）</label>
                </div>
                <button type="button" class="btn btn-primary w-100" onclick="loadUsageLogsPage(1)">刷新</button>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-3 usage-logs-summary-row">
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-secondary small">总请求</div>
                <div id="summaryTotalRequests" class="fs-4 fw-semibold">-</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-secondary small">成功率</div>
                <div id="summarySuccessRate" class="fs-4 fw-semibold">-</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-secondary small">总 Tokens</div>
                <div id="summaryTotalTokens" class="fs-4 fw-semibold">-</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-secondary small">失败请求</div>
                <div id="summaryFailedRequests" class="fs-4 fw-semibold">-</div>
            </div>
        </div>
    </div>
</div>

<div class="table-wrapper">
    <table class="table">
        <thead>
            <tr>
                <th>时间</th>
                <th>来源</th>
                <th>模型</th>
                <th>目标站点</th>
                <th>状态</th>
                <th>用时/首字</th>
                <th>输入</th>
                <th>缓存</th>
                <th>输出</th>
                <th>总Token数</th>
                <th>操作</th>
            </tr>
        </thead>
        <tbody id="usageLogsTableBody">
            <tr>
                <td colspan="11">
                    <div class="table-empty">
                        <div class="table-empty-text">加载中...</div>
                    </div>
                </td>
            </tr>
        </tbody>
    </table>
</div>

<div class="d-flex justify-content-between align-items-center mt-3 gap-3 flex-wrap">
    <div id="usageLogsPaginationSummary" class="text-secondary small">-</div>
    <div class="d-flex align-items-center gap-2">
        <button type="button" class="btn btn-outline-secondary btn-sm" id="prevPageButton">上一页</button>
        <span id="usageLogsPaginationInfo" class="small text-secondary">-</span>
        <button type="button" class="btn btn-outline-secondary btn-sm" id="nextPageButton">下一页</button>
    </div>
</div>

<div class="offcanvas offcanvas-end" tabindex="-1" id="requestDetailDrawer" aria-labelledby="requestDetailDrawerLabel">
    <div class="offcanvas-header">
        <h5 id="requestDetailDrawerLabel" class="offcanvas-title">请求链路详情</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="关闭"></button>
    </div>
    <div class="offcanvas-body">
        <div id="requestDetailMeta" class="small text-secondary mb-3">请选择一条记录查看链路</div>
        <div id="requestDetailContent" class="d-flex flex-column gap-3">
            <div class="text-secondary">暂无详情</div>
        </div>
    </div>
</div>

<style>
    .usage-logs-filter-card {
        overflow: hidden;
    }

    .usage-logs-filter-header {
        background: #fff;
        padding: 0;
        border-bottom: 0;
    }

    .usage-logs-filter-toggle {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        border: 0;
        background: transparent;
        padding: 14px 18px;
        font-size: 14px;
        font-weight: 600;
        color: #0f172a;
        text-align: left;
    }

    .usage-logs-filter-toggle:hover {
        background: #f8fafc;
    }

    .usage-logs-summary-row {
        transition: opacity 0.2s ease;
    }

    .usage-logs-summary-row.is-collapsed {
        display: none;
    }

    .usage-log-chip {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 24px;
        padding: 4px 10px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 600;
        line-height: 1;
        white-space: nowrap;
    }

    .usage-log-chip-total {
        background: #e8f7ea;
        color: #2e7d32;
    }

    .usage-log-chip-first {
        background: #fff1e0;
        color: #c77800;
    }

    .usage-log-chip-stream {
        position: relative;
        background: #e8f0ff;
        color: #3366cc;
    }

    .usage-log-chip-stream-interrupted::after {
        content: '';
        position: absolute;
        top: 3px;
        right: 3px;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #dc3545;
        box-shadow: 0 0 0 2px #fff;
    }
</style>

<script>
    var usageLogsRefreshTimer = null;
    var usageLogsDetailDrawer = null;
    var usageLogsCurrentPage = 1;
    var usageLogsPageSize = 20;
    var usageLogsTotalPages = 0;
    var usageLogsTotalCount = 0;
    var usageLogsFiltersCollapsed = true;

    document.addEventListener('DOMContentLoaded', function() {
        usageLogsDetailDrawer = new bootstrap.Offcanvas(document.getElementById('requestDetailDrawer'));
        document.getElementById('autoRefreshToggle').addEventListener('change', syncAutoRefresh);
        document.getElementById('rangeTypeSelect').addEventListener('change', function() {
            syncCustomRangeVisibility();
            loadUsageLogsPage(1);
        });
        document.getElementById('startTimeInput').addEventListener('change', function() {
            if (document.getElementById('rangeTypeSelect').value === 'custom') {
                loadUsageLogsPage(1);
            }
        });
        document.getElementById('siteFilterSelect').addEventListener('change', function() {
            loadUsageLogsPage(1);
        });
        document.getElementById('prevPageButton').addEventListener('click', function() {
            if (usageLogsCurrentPage > 1) {
                loadUsageLogsPage(usageLogsCurrentPage - 1);
            }
        });
        document.getElementById('nextPageButton').addEventListener('click', function() {
            if (usageLogsCurrentPage < usageLogsTotalPages) {
                loadUsageLogsPage(usageLogsCurrentPage + 1);
            }
        });
        initializeCustomRange();
        syncCustomRangeVisibility();
        syncUsageLogsFilterVisibility();
        syncAutoRefresh();
        loadUsageLogsPage(1);
    });

    function initializeCustomRange() {
        var now = new Date();
        var start = new Date(now.getFullYear(), now.getMonth(), now.getDate(), 0, 0, 0);
        document.getElementById('startTimeInput').value = formatDateTimeInputValue(start);
        document.getElementById('endTimeInput').value = formatDateTimeInputValue(now);
    }

    function syncCustomRangeVisibility() {
        var isCustom = document.getElementById('rangeTypeSelect').value === 'custom';
        document.querySelectorAll('.custom-range-field').forEach(function(element) {
            element.style.display = isCustom ? '' : 'none';
        });
    }

    function toggleUsageLogsFilters() {
        usageLogsFiltersCollapsed = !usageLogsFiltersCollapsed;
        syncUsageLogsFilterVisibility();
    }

    function syncUsageLogsFilterVisibility() {
        var body = document.getElementById('usageLogsFilterBody');
        var toggle = document.getElementById('usageLogsFilterToggle');
        var toggleText = document.getElementById('usageLogsFilterToggleText');
        var summaryRow = document.querySelector('.usage-logs-summary-row');
        if (!body || !toggle || !toggleText || !summaryRow) {
            return;
        }

        body.classList.toggle('d-none', usageLogsFiltersCollapsed);
        summaryRow.classList.toggle('is-collapsed', usageLogsFiltersCollapsed);
        toggle.setAttribute('aria-expanded', usageLogsFiltersCollapsed ? 'false' : 'true');
        toggleText.textContent = usageLogsFiltersCollapsed ? '展开' : '收起';
    }

    function loadUsageLogsPage(page) {
        usageLogsCurrentPage = page || 1;
        syncAutoRefresh();
        Promise.all([
            loadUsageLogSummary(),
            loadUsageLogList()
        ]).catch(function(error) {
            showUsageLogsStatus('加载失败：' + error.message, false);
        });
    }

    function syncAutoRefresh() {
        if (usageLogsRefreshTimer) {
            clearInterval(usageLogsRefreshTimer);
            usageLogsRefreshTimer = null;
        }

        if (!document.getElementById('autoRefreshToggle').checked) {
            return;
        }

        usageLogsRefreshTimer = window.setInterval(function() {
            loadUsageLogSummary();
            loadUsageLogList();
        }, 5000);
    }

    function getUsageLogQuery() {
        var query = new URLSearchParams();
        query.set('page', usageLogsCurrentPage);
        query.set('pageSize', usageLogsPageSize);
        var rangeType = document.getElementById('rangeTypeSelect').value || 'day';
        query.set('rangeType', rangeType);

        if (rangeType === 'custom') {
            var startTime = document.getElementById('startTimeInput').value;
            var endTime = document.getElementById('endTimeInput').value;
            if (startTime) {
                query.set('startTime', new Date(startTime).toISOString());
            }
            if (endTime) {
                query.set('endTime', new Date(endTime).toISOString());
            }
        }

        var siteId = document.getElementById('siteFilterSelect').value;
        if (siteId) {
            query.set('siteId', siteId);
        }

        return query.toString();
    }

    async function loadUsageLogSummary() {
        var url = '/api/admin/usage-logs/summary?' + getUsageLogQuery();
        var response = await fetch(url);
        if (!response.ok) {
            throw new Error('无法加载汇总数据');
        }

        var data = await response.json();
        document.getElementById('summaryTotalRequests').textContent = formatNumber(readValue(data, ['totalRequests', 'requestCount', 'totalCount']) || 0);
        document.getElementById('summarySuccessRate').textContent = formatPercent(readValue(data, ['successRate']) || 0);
        document.getElementById('summaryTotalTokens').textContent = formatNumber(readValue(data, ['totalTokens']) || 0);
        document.getElementById('summaryFailedRequests').textContent = formatNumber(readValue(data, ['failedRequests', 'failureCount']) || 0);
    }

    async function loadUsageLogList() {
        var url = '/api/admin/usage-logs/list?' + getUsageLogQuery();
        var response = await fetch(url);
        if (!response.ok) {
            throw new Error('无法加载日志列表');
        }

        var data = await response.json();
        var items = Array.isArray(data) ? data : (data.items || data.logs || []);
        usageLogsCurrentPage = Number(readValue(data, ['page']) || usageLogsCurrentPage);
        usageLogsPageSize = Number(readValue(data, ['pageSize']) || usageLogsPageSize);
        usageLogsTotalPages = Number(readValue(data, ['totalPages']) || 0);
        usageLogsTotalCount = Number(readValue(data, ['totalCount']) || items.length);
        renderUsageLogRows(items);
        renderPagination();
    }

    function renderUsageLogRows(items) {
        var tbody = document.getElementById('usageLogsTableBody');
        if (!items.length) {
            tbody.innerHTML = '<tr><td colspan="11"><div class="table-empty"><div class="table-empty-icon">📋</div><div class="table-empty-text">暂无调用日志</div></div></td></tr>';
            return;
        }

        tbody.innerHTML = '';
        items.forEach(function(item) {
            var status = readValue(item, ['status']) || '-';
            var source = readValue(item, ['source']) || '-';
            var requestId = readValue(item, ['requestId']) || readValue(item, ['id']) || '';
            var row = document.createElement('tr');
            row.innerHTML =
                '<td>' + escHtml(formatDateTime(readValue(item, ['requestedAt', 'createdAt']))) + '</td>' +
                '<td>' + renderSourceBadge(source) + '</td>' +
                '<td><code>' + escHtml(readValue(item, ['attemptedModel', 'requestModel']) || '-') + '</code></td>' +
                '<td>' + escHtml(readValue(item, ['siteName', 'targetSiteName']) || '-') + '</td>' +
                '<td>' + renderStatusBadge(status, item) + '</td>' +
                '<td>' + renderLatencyBadges(item) + '</td>' +
                '<td>' + escHtml(formatNumber(readValue(item, ['inputTokens']) || 0)) + '</td>' +
                '<td>' + escHtml(formatNumber(readValue(item, ['cachedTokens']) || 0)) + '</td>' +
                '<td>' + escHtml(formatNumber(readValue(item, ['outputTokens']) || 0)) + '</td>' +
                '<td><strong>' + escHtml(formatNumber(readValue(item, ['totalTokens']) || 0)) + '</strong></td>' +
                '<td><button type="button" class="btn btn-sm btn-outline-primary" onclick="openRequestDetail(\'' + escJs(requestId) + '\')">查看链路</button></td>';
            tbody.appendChild(row);
        });
    }

    function renderPagination() {
        var summary = document.getElementById('usageLogsPaginationSummary');
        var info = document.getElementById('usageLogsPaginationInfo');
        var prevButton = document.getElementById('prevPageButton');
        var nextButton = document.getElementById('nextPageButton');

        if (usageLogsTotalCount <= 0) {
            summary.textContent = '共 0 条';
            info.textContent = '第 0 / 0 页';
            prevButton.disabled = true;
            nextButton.disabled = true;
            return;
        }

        var start = (usageLogsCurrentPage - 1) * usageLogsPageSize + 1;
        var end = Math.min(usageLogsCurrentPage * usageLogsPageSize, usageLogsTotalCount);
        summary.textContent = '显示第 ' + formatNumber(start) + ' - ' + formatNumber(end) + ' 条，共 ' + formatNumber(usageLogsTotalCount) + ' 条';
        info.textContent = '第 ' + usageLogsCurrentPage + ' / ' + usageLogsTotalPages + ' 页';
        prevButton.disabled = usageLogsCurrentPage <= 1;
        nextButton.disabled = usageLogsCurrentPage >= usageLogsTotalPages;
    }

    async function openRequestDetail(requestId) {
        if (!requestId) {
            showUsageLogsStatus('当前记录缺少 requestId，无法查看链路', false);
            return;
        }

        document.getElementById('requestDetailMeta').textContent = '正在加载请求 ' + requestId + ' 的链路详情';
        document.getElementById('requestDetailContent').innerHTML = '<div class="text-secondary">加载中...</div>';
        usageLogsDetailDrawer.show();

        try {
            var response = await fetch('/api/admin/usage-logs/request-detail/' + encodeURIComponent(requestId));
            if (!response.ok) {
                throw new Error('无法加载链路详情');
            }

            var data = await response.json();
            renderRequestDetail(requestId, data);
        } catch (error) {
            document.getElementById('requestDetailMeta').textContent = '请求链路详情加载失败';
            document.getElementById('requestDetailContent').innerHTML = '<div class="alert alert-danger mb-0">' + escHtml(error.message) + '</div>';
        }
    }

    function renderRequestDetail(requestId, data) {
        var attempts = readValue(data, ['attempts', 'logs', 'items']) || [];
        document.getElementById('requestDetailMeta').textContent = 'RequestId: ' + requestId;

        if (!Array.isArray(attempts) || !attempts.length) {
            document.getElementById('requestDetailContent').innerHTML = '<div class="text-secondary">暂无链路数据</div>';
            return;
        }

        var html = attempts.map(function(item, index) {
            var status = readValue(item, ['status']) || '-';
            var attemptedModel = readValue(item, ['attemptedModel', 'requestModel']) || '-';
            var reasoningEffort = readValue(item, ['reasoningEffort']) || '';
            var errorMessage = readValue(item, ['errorMessage']) || '';
            return '' +
                '<div class="card">' +
                    '<div class="card-body">' +
                        '<div class="d-flex justify-content-between align-items-start gap-3 mb-2">' +
                            '<div>' +
                                '<div class="fw-semibold">第 ' + (index + 1) + ' 次尝试</div>' +
                                '<div class="small text-secondary">模型：' + escHtml(attemptedModel) + '</div>' +
                            '</div>' +
                            renderStatusBadge(status, item) +
                        '</div>' +
                        '<div class="small text-secondary mb-1">站点：' + escHtml(readValue(item, ['siteName', 'targetSiteName']) || '-') + '</div>' +
                        '<div class="small text-secondary mb-1">时间：' + escHtml(formatDateTime(readValue(item, ['requestedAt', 'createdAt']))) + '</div>' +
                        '<div class="small text-secondary mb-1">Tokens：' + escHtml(formatNumber(readValue(item, ['totalTokens']) || 0)) + '</div>' +
                        '<div class="small text-secondary mb-1">思考等级：' + escHtml(reasoningEffort || '-') + '</div>' +
                        '<div class="small text-secondary">错误：' + escHtml(errorMessage || '-') + '</div>' +
                    '</div>' +
                '</div>';
        }).join('');

        document.getElementById('requestDetailContent').innerHTML = html;
    }

    function renderStatusBadge(status, item) {
        var normalized = String(status || '').toLowerCase();
        var success = normalized === 'success' || normalized === 'ok';
        return '<span class="badge bg-' + (success ? 'success' : 'danger') + '">' + escHtml(success ? '成功' : (status || '失败')) + '</span>';
    }

    function renderSourceBadge(source) {
        var isChat = String(source || '').toLowerCase() === 'chat';
        return '<span class="badge bg-' + (isChat ? 'primary' : 'secondary') + '">' + escHtml(isChat ? '对话测试' : (source || '代理')) + '</span>';
    }

    function showUsageLogsStatus(message, success) {
        var el = document.getElementById('usageLogsStatus');
        el.textContent = message;
        el.className = 'alert alert-' + (success ? 'success' : 'danger');
        el.style.display = 'block';
    }

    function readValue(source, keys) {
        for (var i = 0; i < keys.length; i++) {
            var value = source ? source[keys[i]] : null;
            if (value !== undefined && value !== null) {
                return value;
            }
        }
        return null;
    }

    function formatDateTime(value) {
        if (!value) {
            return '-';
        }

        var date = new Date(value);
        if (isNaN(date.getTime())) {
            return String(value);
        }

        return date.getFullYear() + '-' +
            String(date.getMonth() + 1).padStart(2, '0') + '-' +
            String(date.getDate()).padStart(2, '0') + ' ' +
            String(date.getHours()).padStart(2, '0') + ':' +
            String(date.getMinutes()).padStart(2, '0') + ':' +
            String(date.getSeconds()).padStart(2, '0');
    }

    function formatDateTimeInputValue(date) {
        return date.getFullYear() + '-' +
            String(date.getMonth() + 1).padStart(2, '0') + '-' +
            String(date.getDate()).padStart(2, '0') + 'T' +
            String(date.getHours()).padStart(2, '0') + ':' +
            String(date.getMinutes()).padStart(2, '0');
    }

    function formatPercent(value) {
        var number = Number(value || 0);
        if (!isFinite(number)) {
            return '-';
        }

        if (number <= 1) {
            number = number * 100;
        }

        return number.toFixed(1) + '%';
    }

    function renderLatencyBadges(item) {
        var totalMs = Number(readValue(item, ['totalDurationMs']) || 0);
        var firstMs = Number(readValue(item, ['firstTokenLatencyMs']) || 0);
        var isStreaming = !!readValue(item, ['isStreaming']);
        var isInterrupted = !!readValue(item, ['isStreamInterrupted']);
        var firstLabel = isStreaming ? formatDuration(firstMs) : '-';
        var streamClass = 'usage-log-chip usage-log-chip-stream' + (isInterrupted ? ' usage-log-chip-stream-interrupted' : '');
        return '' +
            '<div style="display:flex;flex-wrap:wrap;gap:4px;align-items:center;">' +
                '<span class="usage-log-chip usage-log-chip-total">' + escHtml(formatDuration(totalMs)) + '</span>' +
                '<span class="usage-log-chip usage-log-chip-first">' + escHtml(firstLabel) + '</span>' +
                '<span class="' + streamClass + '">' + escHtml(isStreaming ? '流' : '非流') + '</span>' +
            '</div>';
    }

    function formatDuration(value) {
        var number = Number(value || 0);
        if (!isFinite(number) || number <= 0) {
            return '-';
        }

        if (number >= 1000) {
            var seconds = number / 1000;
            return (Math.abs(seconds - Math.round(seconds)) < 0.05 ? Math.round(seconds).toString() : seconds.toFixed(1)) + 's';
        }

        return number + 'ms';
    }

    function formatNumber(value) {
        var number = Number(value || 0);
        if (!isFinite(number)) {
            return '-';
        }
        return number.toLocaleString('zh-CN');
    }

    function escHtml(str) {
        var d = document.createElement('div');
        d.textContent = str == null ? '' : String(str);
        return d.innerHTML;
    }

    function escJs(str) {
        return String(str == null ? '' : str)
            .replace(/\\/g, '\\\\')
            .replace(/'/g, "\\'");
    }
</script>
