</style>

@section Scripts {
    <script>
        // 直接复用服务端路由能力快照，前端切换协议时就能马上识别当前模型是否可用。
        var modelProtocolCapabilities = @Html.Raw(modelProtocolJson);
        var defaultOpenAiModel = @Html.Raw(JsonSerializer.Serialize(Model.DefaultOpenAiModel));
        var defaultAnthropicModel = @Html.Raw(JsonSerializer.Serialize(Model.DefaultAnthropicModel));

        function getBaseUrl() {
            return (document.getElementById('baseUrlInput')?.value || '').trim().replace(/\/$/, '');
        }

        function getAccessKey() {
            return (document.getElementById('accessKeyInput')?.value || '').trim();
        }

        function getModelName() {
            return (document.getElementById('modelInput')?.value || '').trim();
        }

        function getMessage() {
            return (document.getElementById('messageInput')?.value || '').trim();
        }

        function findModelCapability(modelName) {
            return modelProtocolCapabilities.find(function (item) {
                return item.ModelName === modelName;
            }) || null;
        }

        function updateModelSupportHint() {
            var hint = document.getElementById('modelSupportHint');
            if (!hint) {
                return;
            }

            var modelName = getModelName();
            var capability = findModelCapability(modelName);

            if (!modelName) {
                hint.textContent = '请选择或输入模型名。';
                hint.className = 'form-text';
                return;
            }

            if (!capability) {
                hint.textContent = '当前模型不在已发现的路由列表中。';
                hint.className = 'form-text text-danger';
                return;
            }

            var supported = [];
            if (capability.SupportsOpenAi) supported.push('OpenAI 原生');
            else if (capability.CanUseOpenAi) supported.push('OpenAI 兼容');
            if (capability.SupportsAnthropic) supported.push('Anthropic 原生');
            else if (capability.CanUseAnthropic) supported.push('Anthropic 兼容');
            hint.textContent = '当前模型支持协议：' + supported.join(' / ');
            hint.className = 'form-text text-muted';
        }

        function ensureProtocolModel(protocolName, silent) {
            var capability = findModelCapability(getModelName());
            var isSupported = capability
                ? (protocolName === 'Anthropic' ? capability.CanUseAnthropic : capability.CanUseOpenAi)
                : false;

            if (isSupported) {
                updateModelSupportHint();
                return true;
            }

            var fallbackModel = protocolName === 'Anthropic' ? defaultAnthropicModel : defaultOpenAiModel;
            if (fallbackModel) {
                document.getElementById('modelInput').value = fallbackModel;
                updateModelSupportHint();
                renderAllExamples();
                if (!silent) {
                    showStatus('当前模型不支持 ' + protocolName + '，已自动切换为可用模型：' + fallbackModel, true);
                }
                return true;
            }

            updateModelSupportHint();
            if (!silent) {
                showStatus('当前没有支持 ' + protocolName + ' 的可用模型，请先配置对应协议的路由。', false);
            }

            return false;
        }

        function updateEndpointTexts() {
            var baseUrl = getBaseUrl();
            var openAiModelsUrl = document.getElementById('openAiModelsUrl');
            var openAiChatUrl = document.getElementById('openAiChatUrl');
            var anthropicChatUrl = document.getElementById('anthropicChatUrl');
            if (openAiModelsUrl) {
                openAiModelsUrl.textContent = baseUrl ? baseUrl + '/v1/models' : '/v1/models';
            }
            if (openAiChatUrl) {
                openAiChatUrl.textContent = baseUrl ? baseUrl + '/v1/chat/completions' : '/v1/chat/completions';
            }
            if (anthropicChatUrl) {
                anthropicChatUrl.textContent = baseUrl ? baseUrl + '/v1/messages' : '/v1/messages';
            }
            var responsesUrl = document.getElementById('responsesUrl');
            if (responsesUrl) {
                responsesUrl.textContent = baseUrl ? baseUrl + '/v1/responses' : '/v1/responses';
            }
        }

        function renderRequestExamples() {
            var openAiModelsRequest = document.getElementById('openAiModelsRequest');
            var openAiChatRequest = document.getElementById('openAiChatRequest');
            var anthropicChatRequest = document.getElementById('anthropicChatRequest');
            var responsesChatRequest = document.getElementById('responsesChatRequest');
            if (!openAiModelsRequest || !openAiChatRequest || !anthropicChatRequest) {
                return;
            }

            var modelName = getModelName();
            var message = getMessage();
            var accessKey = getAccessKey();
            var openAiStream = !!document.getElementById('openAiStreamToggle')?.checked;
            var anthropicStream = !!document.getElementById('anthropicStreamToggle')?.checked;
            var responsesStream = !!document.getElementById('responsesStreamToggle')?.checked;

            var openAiModelsExample = {
                method: 'GET',
                url: document.getElementById('openAiModelsUrl').textContent,
                headers: {
                    Authorization: 'Bearer ' + accessKey
                }
            };

            var openAiChatExample = {
                method: 'POST',
                url: document.getElementById('openAiChatUrl').textContent,
                headers: {
                    'Content-Type': 'application/json',
                    Authorization: 'Bearer ' + accessKey
                },
                body: {
                    model: modelName,
                    messages: [
                        { role: 'user', content: message }
                    ],
                    stream: openAiStream
                }
            };

            var anthropicChatExample = {
                method: 'POST',
                url: document.getElementById('anthropicChatUrl').textContent,
                headers: {
                    'Content-Type': 'application/json',
                    'x-api-key': accessKey,
                    'anthropic-version': '2023-06-01'
                },
                body: {
                    model: modelName,
                    max_tokens: 1024,
                    messages: [
                        { role: 'user', content: message }
                    ],
                    stream: anthropicStream
                }
            };

            // Responses 端点请求示例
            var responsesChatExample = {
                method: 'POST',
                url: document.getElementById('responsesUrl').textContent,
                headers: {
                    'Content-Type': 'application/json',
                    Authorization: 'Bearer ' + accessKey
                },
                body: {
                    model: modelName,
                    input: message,
                    stream: responsesStream
                }
            };

            openAiModelsRequest.textContent = prettyJson(openAiModelsExample);
            openAiChatRequest.textContent = prettyJson(openAiChatExample);
            anthropicChatRequest.textContent = prettyJson(anthropicChatExample);
            if (responsesChatRequest) {
                responsesChatRequest.textContent = prettyJson(responsesChatExample);
            }
        }

        function prettyJson(value) {
            return JSON.stringify(value, null, 2);
        }

        function showStatus(message, success) {
            var alert = document.getElementById('simulatorStatus');
            if (!alert) {
                return;
            }

            alert.style.display = '';
            alert.className = 'alert ' + (success ? 'alert-success' : 'alert-danger');
            alert.textContent = message;
        }

        function clearStatus() {
            var alert = document.getElementById('simulatorStatus');
            if (!alert) {
                return;
            }

            alert.style.display = 'none';
            alert.textContent = '';
        }

        function validateInputs(requireMessage, requireModel) {
            if (requireModel === undefined) {
                requireModel = true;
            }
            if (!getBaseUrl()) {
                showStatus('请先填写代理根地址', false);
                return false;
            }

            if (!getAccessKey()) {
                showStatus('请先填写访问密钥', false);
                return false;
            }

            if (requireModel && !getModelName()) {
                showStatus('请先填写模型名', false);
                return false;
            }

            if (requireMessage && !getMessage()) {
                showStatus('请输入测试消息', false);
                return false;
            }

            clearStatus();
            return true;
        }

        async function loadOpenAiModels() {
            if (!validateInputs(false, false)) return;

            var btn = document.getElementById('btnLoadModels');
            var output = document.getElementById('openAiModelsResponse');
            btn.disabled = true;
            output.textContent = '请求中...';

            try {
                var response = await fetch('/v1/models', {
                    method: 'GET',
                    headers: {
                        Authorization: 'Bearer ' + getAccessKey()
                    }
                });

                var text = await response.text();
                output.textContent = formatResponseText(text);
                showStatus(response.ok ? '模型列表拉取完成' : '模型列表拉取失败', response.ok);
            } catch (error) {
                output.textContent = error.message;
                showStatus('模型列表拉取失败：' + error.message, false);
            } finally {
                btn.disabled = false;
            }
        }

        async function sendOpenAiChat() {
            if (!validateInputs(true)) return;
            if (!ensureProtocolModel('OpenAI', false)) return;
            await sendJsonRequest({
                buttonId: 'btnOpenAiChat',
                outputId: 'openAiChatResponse',
                path: '/v1/chat/completions',
                headers: {
                    'Content-Type': 'application/json',
                    Authorization: 'Bearer ' + getAccessKey()
                },
                body: {
                    model: getModelName(),
                    messages: [
                        { role: 'user', content: getMessage() }
                    ],
                    stream: document.getElementById('openAiStreamToggle').checked
                },
                protocolName: 'OpenAI',
                isStreaming: document.getElementById('openAiStreamToggle').checked
            });
        }

        async function sendAnthropicChat() {
            if (!validateInputs(true)) return;
            if (!ensureProtocolModel('Anthropic', false)) return;
            await sendJsonRequest({
                buttonId: 'btnAnthropicChat',
                outputId: 'anthropicChatResponse',
                path: '/v1/messages',
                headers: {
                    'Content-Type': 'application/json',
                    'x-api-key': getAccessKey(),
                    'anthropic-version': '2023-06-01'
                },
                body: {
                    model: getModelName(),
                    max_tokens: 1024,
                    messages: [
                        { role: 'user', content: getMessage() }
                    ],
                    stream: document.getElementById('anthropicStreamToggle').checked
                },
                protocolName: 'Anthropic',
                isStreaming: document.getElementById('anthropicStreamToggle').checked
            });
        }

        // Responses 端点发送请求
        async function sendResponsesChat() {
            if (!validateInputs(true)) return;
            await sendJsonRequest({
                buttonId: 'btnResponsesChat',
                outputId: 'responsesChatResponse',
                path: '/v1/responses',
                headers: {
                    'Content-Type': 'application/json',
                    Authorization: 'Bearer ' + getAccessKey()
                },
                body: {
                    model: getModelName(),
                    input: getMessage(),
                    stream: document.getElementById('responsesStreamToggle').checked
                },
                protocolName: 'Responses',
                isStreaming: document.getElementById('responsesStreamToggle').checked
            });
        }

        async function sendJsonRequest(options) {
            var btn = document.getElementById(options.buttonId);
            var output = document.getElementById(options.outputId);
            btn.disabled = true;
            output.textContent = '请求中...';

            try {
                var response = await fetch(options.path, {
                    method: 'POST',
                    headers: options.headers,
                    body: JSON.stringify(options.body)
                });

                if (options.isStreaming && response.ok && response.body) {
                    output.textContent = '正在接收流式响应...\n';
                    showStatus(options.protocolName + ' 流式响应接收中', true);
                    await readStreamingResponse(response, output);
                    showStatus(options.protocolName + ' 流式调用完成', true);
                    return;
                }

                var text = await response.text();
                output.textContent = formatResponseText(text);
                showStatus(response.ok ? options.protocolName + ' 调用完成' : options.protocolName + ' 调用失败', response.ok);
            } catch (error) {
                output.textContent = error.message;
                showStatus(options.protocolName + ' 调用失败：' + error.message, false);
            } finally {
                btn.disabled = false;
            }
        }

        async function readStreamingResponse(response, output) {
            var reader = response.body.getReader();
            var decoder = new TextDecoder();
            var received = '';

            try {
                while (true) {
                    var result = await reader.read();
                    if (result.done) {
                        break;
                    }

                    received += decoder.decode(result.value, { stream: true });
                    output.textContent = received;
                    output.scrollTop = output.scrollHeight;
                }

                received += decoder.decode();
                output.textContent = received || '流式响应为空';
                output.scrollTop = output.scrollHeight;
            } finally {
                reader.releaseLock();
            }
        }

        function formatResponseText(text) {
            if (!text) return '';
            try {
                return JSON.stringify(JSON.parse(text), null, 2);
            } catch {
                return text;
            }
        }

        function copyFieldValue(id) {
            var target = document.getElementById(id);
            copyText(target ? (target.value || '') : '');
        }

        function copyText(text) {
            if (navigator.clipboard && window.isSecureContext) {
                navigator.clipboard.writeText(text).then(function () {
                    showStatus('已复制到剪贴板', true);
                }).catch(function () {
                    fallbackCopy(text);
                });
            } else {
                fallbackCopy(text);
            }
        }

        function fallbackCopy(text) {
            var textarea = document.createElement('textarea');
            textarea.value = text;
            textarea.style.position = 'fixed';
            textarea.style.opacity = '0';
            document.body.appendChild(textarea);
            textarea.select();
            try {
                document.execCommand('copy');
                showStatus('已复制到剪贴板', true);
            } catch (e) {
                showStatus('复制失败，请手动复制', false);
            }
            document.body.removeChild(textarea);
        }

        function renderAllExamples() {
            updateEndpointTexts();
            updateModelSupportHint();
            renderRequestExamples();
        }

        (function () {
            var autoRefreshToggle = document.getElementById('autoRefreshToggle');
            var refreshNowButton = document.getElementById('refreshNowButton');
            var traceAccordion = document.getElementById('invocationTraceAccordion');
            var traceLoadingCard = document.getElementById('traceLoadingCard');
            var tracePaginationBar = document.getElementById('tracePaginationBar');
            var tracePaginationSummary = document.getElementById('tracePaginationSummary');
            var tracePrevPageButton = document.getElementById('tracePrevPageButton');
            var traceNextPageButton = document.getElementById('traceNextPageButton');
            var refreshIntervalMs = 5000;
            var refreshTimerId = null;
            var listEndpoint = '@Url.Page("./Index", "List")';
            var detailEndpoint = '@Url.Page("./Index", "Detail")';
            var concurrencyEndpoint = '@Url.Page("./Index", "Concurrency")';
            var hasLoadedListOnce = false;
            var isRefreshing = false;
            var isRefreshingConcurrency = false;
            var concurrencyRenderSignature = '';
            var currentPage = 1;
            var currentTotalPages = 1;

            function escapeHtml(value) {
                return (value || '').replace(/[&<>"']/g, function (char) {
                    switch (char) {
                        case '&': return '&amp;';
                        case '<': return '&lt;';
                        case '>': return '&gt;';
                        case '"': return '&quot;';
                        case '\'': return '&#39;';
                        default: return char;
                    }
                });
            }

            function getOpenTraceIds() {
                if (!traceAccordion) {
                    return [];
                }

                return Array.from(traceAccordion.querySelectorAll('.collapse.show'))
                    .map(function (element) { return element.id; })
                    .filter(Boolean);
            }

            function updateSummary(payload) {
                var totalEl = document.getElementById('traceTotalCount');
                var failedEl = document.getElementById('traceFailedCount');
                var pendingEl = document.getElementById('tracePendingCount');
                if (totalEl) {
                    totalEl.textContent = payload.totalCount;
                }
                if (failedEl) {
                    failedEl.textContent = payload.failedCount;
                }
                if (pendingEl) {
                    pendingEl.textContent = payload.pendingCount;
                }
            }

            function formatDuration(durationMs) {
                var value = Number(durationMs || 0);
                if (!value || value <= 0) {
                    return '-';
                }

                // 按量级自动切换毫秒、秒、分钟，避免长耗时记录难以扫读。
                if (value < 1000) {
                    return value + ' ms';
                }
                if (value < 60000) {
                    return formatDurationNumber(value / 1000) + ' 秒';
                }
                return formatDurationNumber(value / 60000) + ' 分';
            }

            function formatDurationNumber(value) {
                return Number(value.toFixed(value >= 10 ? 1 : 2)).toString();
            }

            // 分页信息需要在自动刷新后继续保持当前页，并在不足一页时直接隐藏翻页栏。
            function updatePagination(payload) {
                currentPage = payload.pageNumber || 1;
                currentTotalPages = payload.totalPages || 1;
                var totalCount = payload.totalCount || 0;
                var pageSize = payload.pageSize || 20;
                var shouldShowPagination = currentTotalPages > 1 && totalCount > pageSize;
                if (tracePaginationBar) {
                    tracePaginationBar.style.display = shouldShowPagination ? 'flex' : 'none';
                }
                if (tracePaginationSummary) {
                    tracePaginationSummary.textContent = '第 ' + currentPage + ' / ' + currentTotalPages + ' 页 · 每页 ' + pageSize + ' 条 · 共 ' + totalCount + ' 条';
                }
                if (tracePrevPageButton) {
                    tracePrevPageButton.disabled = !shouldShowPagination || currentPage <= 1 || isRefreshing;
                }
                if (traceNextPageButton) {
                    traceNextPageButton.disabled = !shouldShowPagination || currentPage >= currentTotalPages || isRefreshing;
                }
            }

            function buildListUrl(page) {
                var url = new URL(listEndpoint, window.location.origin);
                url.searchParams.set('pageNumber', String(page || 1));
                return url.toString();
            }

            function buildDetailUrl(traceId) {
                var url = new URL(detailEndpoint, window.location.origin);
                url.searchParams.set('traceId', String(traceId || ''));
                return url.toString();
            }

            function buildConcurrencyUrl() {
                return new URL(concurrencyEndpoint, window.location.origin).toString();
            }

            function isInvocationsTabActive() {
                return document.getElementById('developerInvocationsPane')?.classList.contains('show')
                    && document.getElementById('developerInvocationsPane')?.classList.contains('active');
            }

            function isConcurrencyTabActive() {
                return document.getElementById('developerConcurrencyPane')?.classList.contains('show')
                    && document.getElementById('developerConcurrencyPane')?.classList.contains('active');
            }

            function renderRequestHeaders(headers) {
                try {
                    return JSON.stringify(headers || {}, null, 2);
                } catch {
                    return '{}';
                }
            }

            function getForwardingModeText(forwardingMode) {
                switch ((forwardingMode || '').toLowerCase()) {
                    case 'direct':
                        return '直接透传';
                    case 'bridge':
                        return '兼容中转';
                    default:
                        return '未标记';
                }
            }

            function renderAttempts(entry) {
                if (!entry.attempts || entry.attempts.length === 0) {
                    return '';
                }

                return '' +
                    '<div class="trace-attempt-list">' +
                    entry.attempts.map(function (attempt, attemptIndex) {
                        var attemptStatusCodeText = attempt.statusCode > 0 ? String(attempt.statusCode) : '-';
                        var attemptDurationText = formatDuration(attempt.totalDurationMs);
                        var attemptResponseBodyText = attempt.responseBody && attempt.responseBody.trim() ? attempt.responseBody : '-';
                        var attemptErrorBlock = attempt.errorMessage && attempt.errorMessage.trim()
                            ? '<div class="trace-error-stack"><div class="trace-section-title trace-section-title-danger">尝试错误</div><pre class="trace-pre trace-code-panel trace-code-panel-danger">' + escapeHtml(attempt.errorMessage) + '</pre></div>'
                            : '';

                        return '' +
                            '<article class="trace-attempt-card trace-attempt-card-' + escapeHtml(attempt.statusClass) + '">' +
                                '<div class="trace-attempt-head">' +
                                    '<div class="trace-title-group">' +
                                        '<span class="trace-status-pill trace-status-pill-' + escapeHtml(attempt.statusClass) + '">' + escapeHtml(attempt.statusText) + '</span>' +
                                        '<span class="trace-attempt-order">尝试 ' + (attemptIndex + 1) + '</span>' +
                                        '<span class="trace-protocol-pill">' + escapeHtml(attempt.upstreamProtocolType || '-') + '</span>' +
                                        '<span class="trace-source-pill">' + escapeHtml(getForwardingModeText(attempt.forwardingMode)) + '</span>' +
                                    '</div>' +
                                    '<div class="trace-summary-time">' + escapeHtml(attempt.createdAtText) + '</div>' +
                                '</div>' +
                                '<div class="trace-attempt-route">' +
                                    '<div class="trace-attempted-model">' + escapeHtml(attempt.summaryAttemptedModel) + '</div>' +
                                    '<div class="trace-attempt-site">' + escapeHtml(attempt.summarySite) + '</div>' +
                                '</div>' +
                                '<div class="trace-meta-grid trace-meta-grid-attempt">' +
                                    '<div class="trace-meta-chip"><span class="trace-meta-label">转发方式</span><strong>' + escapeHtml(getForwardingModeText(attempt.forwardingMode)) + '</strong></div>' +
                                    '<div class="trace-meta-chip"><span class="trace-meta-label">状态码</span><strong>' + escapeHtml(attemptStatusCodeText) + '</strong></div>' +
                                    '<div class="trace-meta-chip"><span class="trace-meta-label">总耗时</span><strong>' + escapeHtml(attemptDurationText) + '</strong></div>' +
                                    '<div class="trace-meta-chip"><span class="trace-meta-label">Token</span><strong>' + escapeHtml(attempt.inputTokens + ' / ' + attempt.cachedTokens + ' / ' + attempt.outputTokens) + '</strong></div>' +
                                '</div>' +
                                attemptErrorBlock +
                                '<div class="row g-3">' +
                                    '<div class="col-xl-6">' +
                                        '<div class="trace-panel-header">' +
                                            '<div class="trace-section-title mb-0">尝试返回体</div>' +
                                            '<button type="button" class="btn btn-sm btn-outline-secondary trace-copy-btn" onclick="copyTraceContent(this)" data-copy-target="attempt-response-body-' + entry.traceId + '-' + attempt.attemptId + '">复制返回体</button>' +
                                        '</div>' +
                                        '<pre id="attempt-response-body-' + entry.traceId + '-' + attempt.attemptId + '" class="trace-pre trace-code-panel">' + escapeHtml(attemptResponseBodyText) + '</pre>' +
                                    '</div>' +
                                '</div>' +
                            '</article>';
                    }).join('') +
                    '</div>';
            }

            function renderDetail(entry) {
                var responseBodyText = entry.responseBody && entry.responseBody.trim() ? entry.responseBody : '-';
                var errorBlock = entry.errorMessage && entry.errorMessage.trim()
                    ? '<div class="trace-error-stack"><div class="trace-section-title trace-section-title-danger">错误信息</div><pre class="trace-pre trace-code-panel trace-code-panel-danger">' + escapeHtml(entry.errorMessage) + '</pre></div>'
                    : '';
                var attemptsSummary = '成功 ' + (entry.successAttemptCount || 0) + ' / 失败 ' + (entry.failedAttemptCount || 0) + ' / 等待 ' + (entry.pendingAttemptCount || 0);

                return '' +
                    '<div class="card-body d-flex flex-column gap-3">' +
                        '<div class="row g-3">' +
                            '<div class="col-xl-4">' +
                                '<div class="trace-section-title">基础信息</div>' +
                                '<div class="trace-info-panel">' +
                                    '<div><strong>客户端来源：</strong>' + escapeHtml(entry.source) + '</div>' +
                                    '<div><strong>User-Agent：</strong>' + escapeHtml(entry.userAgent || '-') + '</div>' +
                                    '<div><strong>客户端 IP：</strong>' + escapeHtml(entry.clientIp || '-') + '</div>' +
                                    '<div><strong>请求协议：</strong>' + escapeHtml(entry.protocolType) + '</div>' +
                                    '<div><strong>请求模型：</strong>' + escapeHtml(entry.requestModel) + '</div>' +
                                    '<div><strong>最终状态：</strong>' + escapeHtml(entry.statusText) + '</div>' +
                                    '<div><strong>尝试次数：</strong>' + escapeHtml(String((entry.attempts || []).length)) + '</div>' +
                                    '<div><strong>尝试统计：</strong>' + escapeHtml(attemptsSummary) + '</div>' +
                                '</div>' +
                            '</div>' +
                            '<div class="col-xl-8">' +
                                '<div class="trace-section-title">请求头</div>' +
                                '<pre class="trace-pre trace-code-panel">' + escapeHtml(renderRequestHeaders(entry.requestHeaders)) + '</pre>' +
                            '</div>' +
                        '</div>' +
                        '<div>' +
                            '<div class="trace-section-title">真实路由尝试链路</div>' +
                            '<div class="trace-chain-tip">会按真实尝试顺序展示每一次命中的路由模型，包括前面失败、后面成功的完整链路。</div>' +
                            (renderAttempts(entry) || '<div class="trace-info-panel">当前还没有命中任何路由尝试。</div>') +
                        '</div>' +
                        errorBlock +
                        '<div class="row g-3">' +
                            '<div class="col-xl-6">' +
                                '<div class="trace-panel-header">' +
                                    '<div class="trace-section-title mb-0">请求体</div>' +
                                    '<button type="button" class="btn btn-sm btn-outline-secondary trace-copy-btn" onclick="copyTraceContent(this)" data-copy-target="request-body-' + entry.traceId + '">复制请求体</button>' +
                                '</div>' +
                                '<pre id="request-body-' + entry.traceId + '" class="trace-pre trace-code-panel">' + escapeHtml(entry.requestBody) + '</pre>' +
                            '</div>' +
                            '<div class="col-xl-6">' +
                                '<div class="trace-panel-header">' +
                                    '<div class="trace-section-title mb-0">返回体</div>' +
                                    '<button type="button" class="btn btn-sm btn-outline-secondary trace-copy-btn" onclick="copyTraceContent(this)" data-copy-target="response-body-' + entry.traceId + '">复制返回体</button>' +
                                '</div>' +
                                '<pre id="response-body-' + entry.traceId + '" class="trace-pre trace-code-panel">' + escapeHtml(responseBodyText) + '</pre>' +
                            '</div>' +
                        '</div>' +
                    '</div>';
            }

            function renderEntry(entry) {
                var traceCollapseId = 'invocation-trace-' + entry.traceId;
                var statusCodeText = entry.statusCode > 0 ? String(entry.statusCode) : '-';
                var durationText = formatDuration(entry.totalDurationMs);
                var attemptsSummary = '成功 ' + (entry.successAttemptCount || 0) + ' / 失败 ' + (entry.failedAttemptCount || 0) + ' / 等待 ' + (entry.pendingAttemptCount || 0);

                return '' +
                    '<div class="card trace-card trace-card-' + escapeHtml(entry.statusClass) + '" data-trace-status="' + escapeHtml(entry.status) + '">' +
                        '<div class="card-header trace-card-header bg-white">' +
                            '<button class="trace-card-toggle" type="button" data-bs-toggle="collapse" data-bs-target="#' + traceCollapseId + '" aria-expanded="false" aria-controls="' + traceCollapseId + '">' +
                                '<div class="trace-card-main">' +
                                    '<div class="trace-card-topline">' +
                                        '<div class="trace-title-group">' +
                                            '<span class="trace-status-pill trace-status-pill-' + escapeHtml(entry.statusClass) + '">' + escapeHtml(entry.statusText) + '</span>' +
                                            '<span class="trace-protocol-pill">' + escapeHtml(entry.protocolType) + '</span>' +
                                            '<span class="trace-source-pill">' + escapeHtml(entry.source) + '</span>' +
                                        '</div>' +
                                        '<div class="trace-summary-time">' + escapeHtml(entry.createdAtText) + '</div>' +
                                    '</div>' +
                                    '<div class="trace-card-title-row">' +
                                        '<div class="trace-model-pair">' +
                                            '<div class="trace-request-model">' + escapeHtml(entry.requestModel) + '</div>' +
                                            '<div class="trace-model-arrow">→</div>' +
                                            '<div class="trace-attempted-model">' + escapeHtml(entry.summaryAttemptedModel) + '</div>' +
                                        '</div>' +
                                    '</div>' +
                                    '<div class="trace-meta-grid">' +
                                        '<div class="trace-meta-chip"><span class="trace-meta-label">目标站点</span><strong>' + escapeHtml(entry.summarySite) + '</strong></div>' +
                                        '<div class="trace-meta-chip"><span class="trace-meta-label">请求路径</span><strong>' + escapeHtml(entry.requestPath) + '</strong></div>' +
                                        '<div class="trace-meta-chip"><span class="trace-meta-label">尝试统计</span><strong>' + escapeHtml(attemptsSummary) + '</strong></div>' +
                                        '<div class="trace-meta-chip"><span class="trace-meta-label">状态码</span><strong>' + escapeHtml(statusCodeText) + '</strong></div>' +
                                        '<div class="trace-meta-chip"><span class="trace-meta-label">总耗时</span><strong>' + escapeHtml(durationText) + '</strong></div>' +
                                    '</div>' +
                                '</div>' +
                            '</button>' +
                        '</div>' +
                        '<div id="' + traceCollapseId + '" class="collapse" data-bs-parent="#invocationTraceAccordion" data-trace-id="' + escapeHtml(entry.traceId) + '">' +
                            '<div class="card-body d-flex flex-column gap-3 trace-detail-loading">' +
                                '<div class="trace-loading-title">详情将在展开后加载</div>' +
                                '<div class="trace-loading-text">为减少列表刷新开销，请求头、请求体、返回体和完整尝试链路会在展开当前卡片后单独获取。</div>' +
                            '</div>' +
                        '</div>' +
                    '</div>';
            }

            function renderEmptyState() {
                return '<div class="card trace-empty-card"><div class="card-body text-secondary">暂无调用记录</div></div>';
            }

            function renderConcurrencyTable(items) {
                var tableBody = document.getElementById('concurrencyTableBody');
                if (!tableBody) {
                    return;
                }

                if (!Array.isArray(items) || items.length === 0) {
                    tableBody.innerHTML = '<tr><td colspan="5" class="text-center text-secondary py-4">最近 6 小时内没有模型并发记录</td></tr>';
                    return;
                }

                tableBody.innerHTML = items.map(function (item) {
                    var maxStr = item.maxConcurrency != null ? String(item.maxConcurrency) : '-';
                    var queueCount = item.queueCount || 0;
                    var rowClass = queueCount > 0 ? ' class="concurrency-queued-row"' : '';
                    var queueStr = queueCount > 0 ? '<span class="concurrency-queue-badge">' + escapeHtml(String(queueCount)) + '</span>' : '0';
                    return '' +
                        '<tr' + rowClass + '>' +
                            '<td>' + escapeHtml(item.modelName || '-') + '</td>' +
                            '<td>' + escapeHtml(item.siteName || '-') + '</td>' +
                            '<td class="text-end"><span class="concurrency-count-badge">' + escapeHtml(String(item.activeCount || 0)) + '</span></td>' +
                            '<td class="text-end">' + escapeHtml(maxStr) + '</td>' +
                            '<td class="text-end">' + queueStr + '</td>' +
                        '</tr>';
                }).join('');
            }

            // 并发页只在当前页签激活时请求，避免额外刷新干扰正常调试操作。
            async function refreshConcurrencyTable() {
                if (isRefreshingConcurrency || !isConcurrencyTabActive()) {
                    return;
                }

                var tableBody = document.getElementById('concurrencyTableBody');
                isRefreshingConcurrency = true;

                try {
                    var response = await fetch(buildConcurrencyUrl(), {
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        cache: 'no-store'
                    });

                    if (!response.ok) {
                        if (tableBody) {
                            tableBody.innerHTML = '<tr><td colspan="3" class="text-center text-danger py-4">加载失败，请稍后重试</td></tr>';
                        }
                        return;
                    }

                    var payload = await response.json();
                    var items = Array.isArray(payload.items) ? payload.items : [];
                    var nextSignature = JSON.stringify(items.map(function (item) {
                        return [item.siteName || '', item.modelName || '', Number(item.activeCount || 0), item.maxConcurrency, Number(item.queueCount || 0)];
                    }));

                    if (nextSignature !== concurrencyRenderSignature) {
                        renderConcurrencyTable(items);
                        concurrencyRenderSignature = nextSignature;
                    }
                } catch {
                    if (tableBody) {
                        tableBody.innerHTML = '<tr><td colspan="3" class="text-center text-danger py-4">加载失败，请稍后重试</td></tr>';
                    }
                } finally {
                    isRefreshingConcurrency = false;
                }
            }

            // 展开时单独加载明细，避免分页列表和自动刷新反复搬运大字段。
            async function loadTraceDetail(collapseElement) {
                if (!collapseElement) {
                    return;
                }

                var traceId = collapseElement.getAttribute('data-trace-id');
                if (!traceId || collapseElement.getAttribute('data-detail-loading') === 'true') {
                    return;
                }

                collapseElement.setAttribute('data-detail-loading', 'true');
                collapseElement.innerHTML = '<div class="card-body d-flex flex-column gap-3 trace-detail-loading"><div class="trace-loading-title">详情加载中</div><div class="trace-loading-text">正在单独获取当前调用记录的请求头、请求体、返回体和尝试链路。</div></div>';

                try {
                    var response = await fetch(buildDetailUrl(traceId), {
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        cache: 'no-store'
                    });

                    if (!response.ok) {
                        collapseElement.innerHTML = '<div class="card-body"><div class="trace-error-stack"><div class="trace-section-title trace-section-title-danger">详情加载失败</div><pre class="trace-pre trace-code-panel trace-code-panel-danger">无法读取当前调用记录详情，请稍后重试。</pre></div></div>';
                        return;
                    }

                    var payload = await response.json();
                    collapseElement.innerHTML = renderDetail(payload);
                } catch {
                    collapseElement.innerHTML = '<div class="card-body"><div class="trace-error-stack"><div class="trace-section-title trace-section-title-danger">详情加载失败</div><pre class="trace-pre trace-code-panel trace-code-panel-danger">请求详情接口时发生异常，请稍后重试。</pre></div></div>';
                } finally {
                    collapseElement.removeAttribute('data-detail-loading');
                }
            }

            function restoreOpenTraceIds(openIds) {
                if (!Array.isArray(openIds)) {
                    return;
                }

                openIds.forEach(function (id) {
                    var element = document.getElementById(id);
                    if (!element) {
                        return;
                    }

                    var collapse = bootstrap.Collapse.getOrCreateInstance(element, { toggle: false });
                    collapse.show();
                });
            }

            async function refreshTraceList(page) {
                if (isRefreshing) {
                    return;
                }

                isRefreshing = true;
                var requestedPage = Math.max(1, page || currentPage || 1);
                var openIds = hasLoadedListOnce ? getOpenTraceIds() : [];
                updatePagination({ pageNumber: requestedPage, pageSize: 20, totalPages: Math.max(currentTotalPages, requestedPage, 1), totalCount: currentTotalPages > 1 ? currentTotalPages * 20 : 0 });

                try {
                    var response = await fetch(buildListUrl(requestedPage), {
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        cache: 'no-store'
                    });

                    if (!response.ok) {
                        return;
                    }

                    var payload = await response.json();
                    updateSummary(payload);
                    updatePagination(payload);

                    if (!traceAccordion) {
                        return;
                    }

                    if (!payload.entries || payload.entries.length === 0) {
                        traceAccordion.innerHTML = renderEmptyState();
                        hasLoadedListOnce = true;
                        if (traceLoadingCard) {
                            traceLoadingCard.classList.add('d-none');
                        }
                        return;
                    }

                    traceAccordion.innerHTML = payload.entries.map(renderEntry).join('');
                    hasLoadedListOnce = true;
                    if (traceLoadingCard) {
                        traceLoadingCard.classList.add('d-none');
                    }
                    restoreOpenTraceIds(openIds);
                } finally {
                    isRefreshing = false;
                    if (tracePrevPageButton) {
                        tracePrevPageButton.disabled = currentPage <= 1;
                    }
                    if (traceNextPageButton) {
                        traceNextPageButton.disabled = currentPage >= currentTotalPages;
                    }
                }
            }

            if (traceAccordion) {
                traceAccordion.addEventListener('shown.bs.collapse', function (event) {
                    loadTraceDetail(event.target);
                });
            }

            if (refreshNowButton) {
                refreshNowButton.addEventListener('click', function () {
                    refreshTraceList(currentPage);
                });
            }

            if (tracePrevPageButton) {
                tracePrevPageButton.addEventListener('click', function () {
                    if (currentPage > 1) {
                        refreshTraceList(currentPage - 1);
                    }
                });
            }

            if (traceNextPageButton) {
                traceNextPageButton.addEventListener('click', function () {
                    if (currentPage < currentTotalPages) {
                        refreshTraceList(currentPage + 1);
                    }
                });
            }

            if (autoRefreshToggle) {
                autoRefreshToggle.addEventListener('change', function () {
                    if (autoRefreshToggle.checked && !hasLoadedListOnce && isInvocationsTabActive()) {
                        refreshTraceList(currentPage);
                    }
                });
            }

            var developerSimulatorTab = document.getElementById('developerSimulatorTab');
            var developerInvocationsTab = document.getElementById('developerInvocationsTab');
            var developerConcurrencyTab = document.getElementById('developerConcurrencyTab');

            function syncDeveloperTabHash(hash) {
                var url = new URL(window.location.href);
                url.hash = hash;
                window.history.replaceState({}, '', url.toString());
            }

            function activateDeveloperTabFromLocation() {
                var hash = (window.location.hash || '').toLowerCase();
                var targetTab = null;

                if (hash === '#developersimulatorpane') {
                    targetTab = developerSimulatorTab;
                } else if (hash === '#developerinvocationspane') {
                    targetTab = developerInvocationsTab;
                } else if (hash === '#developerconcurrencypane') {
                    targetTab = developerConcurrencyTab;
                }

                if (targetTab && window.bootstrap) {
                    bootstrap.Tab.getOrCreateInstance(targetTab).show();
                }
            }

            if (developerSimulatorTab) {
                developerSimulatorTab.addEventListener('shown.bs.tab', function () {
                    syncDeveloperTabHash('#developerSimulatorPane');
                });
            }
            if (developerInvocationsTab) {
                developerInvocationsTab.addEventListener('shown.bs.tab', function () {
                    syncDeveloperTabHash('#developerInvocationsPane');
                    if (!hasLoadedListOnce) {
                        refreshTraceList(currentPage);
                    }
                });
            }
            if (developerConcurrencyTab) {
                developerConcurrencyTab.addEventListener('shown.bs.tab', function () {
                    syncDeveloperTabHash('#developerConcurrencyPane');
                    refreshConcurrencyTable();
                });
            }

            document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (element) {
                if (window.bootstrap && window.bootstrap.Tooltip) {
                    new window.bootstrap.Tooltip(element);
                }
            });

            activateDeveloperTabFromLocation();

            document.getElementById('baseUrlInput')?.addEventListener('input', renderAllExamples);
            document.getElementById('accessKeyInput')?.addEventListener('input', renderAllExamples);
            document.getElementById('modelInput')?.addEventListener('input', renderAllExamples);
            document.getElementById('messageInput')?.addEventListener('input', renderAllExamples);
            document.getElementById('openAiStreamToggle')?.addEventListener('change', renderAllExamples);
            document.getElementById('anthropicStreamToggle')?.addEventListener('change', renderAllExamples);
            document.getElementById('responsesStreamToggle')?.addEventListener('change', renderAllExamples);
            document.querySelector('button[data-bs-target="#tabOpenAi"]')?.addEventListener('shown.bs.tab', function () {
                ensureProtocolModel('OpenAI', true);
            });
            document.querySelector('button[data-bs-target="#tabAnthropic"]')?.addEventListener('shown.bs.tab', function () {
                ensureProtocolModel('Anthropic', true);
            });
            document.querySelector('button[data-bs-target="#tabResponses"]')?.addEventListener('shown.bs.tab', function () {
                renderAllExamples();
            });

            ensureProtocolModel('OpenAI', true);
            renderAllExamples();

            window.copyTraceContent = async function (button) {
                if (!button) {
                    return;
                }

                var targetId = button.getAttribute('data-copy-target');
                var target = targetId ? document.getElementById(targetId) : null;
                var text = target ? (target.textContent || '') : '';
                if (!text) {
                    return;
                }

                try {
                    if (navigator.clipboard && window.isSecureContext) {
                        await navigator.clipboard.writeText(text);
                    } else {
                        var textarea = document.createElement('textarea');
                        textarea.value = text;
                        textarea.setAttribute('readonly', 'readonly');
                        textarea.style.position = 'fixed';
                        textarea.style.opacity = '0';
                        textarea.style.left = '-9999px';
                        document.body.appendChild(textarea);
                        textarea.focus();
                        textarea.select();
                        document.execCommand('copy');
                        document.body.removeChild(textarea);
                    }

                    var originalText = button.textContent;
                    button.textContent = '复制成功';
                    button.disabled = true;
                    window.setTimeout(function () {
                        button.textContent = originalText;
                        button.disabled = false;
                    }, 1200);
                } catch {
                    var fallbackText = button.textContent;
                    button.textContent = '复制失败';
                    button.disabled = true;
                    window.setTimeout(function () {
                        button.textContent = fallbackText;
                        button.disabled = false;
                    }, 1200);
                }
            };

            function ensureRefreshTimer() {
                if (refreshTimerId) {
                    window.clearInterval(refreshTimerId);
                }

                refreshTimerId = window.setInterval(function () {
                    if (isInvocationsTabActive() && autoRefreshToggle && autoRefreshToggle.checked) {
                        refreshTraceList(currentPage);
                    }

                    if (isConcurrencyTabActive()) {
                        refreshConcurrencyTable();
                    }
                }, refreshIntervalMs);
            }

            ensureRefreshTimer();
            window.setTimeout(function () {
                if (isConcurrencyTabActive()) {
                    refreshConcurrencyTable();
                    return;
                }

                if (isInvocationsTabActive()) {
                    refreshTraceList(currentPage);
                }
            }, 0);
        })();
    </script>
}
