@page
@model AITool.Web.Pages.Admin.Developer.Invocations.IndexModel
@using global::System.Text.Json
@{
    ViewData["Title"] = "调试工具";
    var simulatorTabActive = string.Equals(Model.ActiveTab, "simulator", StringComparison.OrdinalIgnoreCase);
    var concurrencyTabActive = string.Equals(Model.ActiveTab, "concurrency", StringComparison.OrdinalIgnoreCase);
    var invocationsTabActive = !simulatorTabActive && !concurrencyTabActive;
    var defaultModel = !string.IsNullOrWhiteSpace(Model.DefaultOpenAiModel)
        ? Model.DefaultOpenAiModel
        : (Model.Models.FirstOrDefault()?.ModelName ?? string.Empty);
    var modelProtocolJson = JsonSerializer.Serialize(Model.Models.Select(item => new
    {
        item.ModelName,
        item.SupportsOpenAi,
        item.SupportsAnthropic,
        item.CanUseOpenAi,
        item.CanUseAnthropic
    }));
}

<div class="card developer-tools-card">
    <div class="card-header p-0">
        <ul class="nav nav-tabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link @(invocationsTabActive ? "active" : null)" id="developerInvocationsTab" data-bs-toggle="tab" data-bs-target="#developerInvocationsPane" type="button" role="tab">调用调试</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(simulatorTabActive ? "active" : null)" id="developerSimulatorTab" data-bs-toggle="tab" data-bs-target="#developerSimulatorPane" type="button" role="tab">客户端模拟</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(concurrencyTabActive ? "active" : null)" id="developerConcurrencyTab" data-bs-toggle="tab" data-bs-target="#developerConcurrencyPane" type="button" role="tab">当前模型并发数检测</button>
            </li>
        </ul>
    </div>
    <div class="card-body">
        <div class="tab-content">
            <div class="tab-pane fade @(simulatorTabActive ? "show active" : null)" id="developerSimulatorPane" role="tabpanel">
                <div class="page-header mb-3">
                    <div>
                        <h3 class="page-title h4 mb-1">客户端模拟</h3>
                        <p class="page-subtitle mb-0">按真实代理 URL 链路模拟 OpenAI 与 Anthropic 客户端调用，自动带入本机地址与访问密钥</p>
                    </div>
                </div>

                <div class="client-simulator-page">
                    <div class="card simulator-config-card">
                        <div class="card-body">
                            <div id="simulatorStatus" class="alert" style="display:none;"></div>
                            <div class="row g-3">
                                <div class="col-xl-6">
                                    <label class="form-label" for="baseUrlInput">代理根地址</label>
                                    <input type="text" id="baseUrlInput" class="form-control" value="@Model.DefaultBaseUrl" />
                                </div>
                                <div class="col-xl-6">
                                    <label class="form-label" for="accessKeyInput">访问密钥</label>
                                    <div class="input-group">
                                        <input type="text" id="accessKeyInput" class="form-control" value="@Model.DefaultAccessKey" />
                                        <button type="button" class="btn btn-outline-primary" onclick="copyFieldValue('accessKeyInput')">复制</button>
                                    </div>
                                </div>
                                <div class="col-xl-6">
                                    <label class="form-label" for="modelInput">模型名</label>
                                    <input type="text" id="modelInput" class="form-control" list="modelOptions" value="@defaultModel" placeholder="输入对外模型名" />
                                    <datalist id="modelOptions">
                                        @foreach (var item in Model.Models)
                                        {
                                            var supportedProtocols = string.Join(" / ", new[]
                                            {
                                                item.SupportsOpenAi ? "OpenAI 原生" : null,
                                                item.SupportsAnthropic ? "Anthropic 原生" : null,
                                                !item.SupportsOpenAi && item.CanUseOpenAi ? "OpenAI 兼容" : null,
                                                !item.SupportsAnthropic && item.CanUseAnthropic ? "Anthropic 兼容" : null
                                            }.Where(x => x is not null));
                                            <option value="@item.ModelName">@item.ModelName (@item.RouteCount 条路由, @supportedProtocols)</option>
                                        }
                                    </datalist>
                                    <div id="modelSupportHint" class="form-text">请选择支持当前协议的模型。</div>
                                </div>
                                <div class="col-xl-6">
                                    <label class="form-label" for="messageInput">测试消息</label>
                                    <textarea id="messageInput" class="form-control" rows="3" placeholder="输入测试消息...">你好，请简单介绍一下你自己。</textarea>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card">
                        <div class="card-header p-0">
                            <ul class="nav nav-tabs" role="tablist">
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tabModels" type="button" role="tab">模型列表</button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabOpenAi" type="button" role="tab">OpenAI 聊天</button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabAnthropic" type="button" role="tab">Anthropic 聊天</button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabResponses" type="button" role="tab">Responses</button>
                                </li>
                            </ul>
                        </div>
                        <div class="card-body">
                            <div class="tab-content">
                                <div class="tab-pane fade show active" id="tabModels" role="tabpanel">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <code id="openAiModelsUrl" class="simulator-endpoint-code"></code>
                                        <div class="d-flex gap-2">
                                            <button type="button" class="btn btn-sm btn-outline-primary" onclick="copyText(document.getElementById('openAiModelsUrl').textContent)">复制 URL</button>
                                            <button type="button" class="btn btn-sm btn-primary" id="btnLoadModels" onclick="loadOpenAiModels()">拉取模型</button>
                                        </div>
                                    </div>
                                    <div class="simulator-panel-grid">
                                        <div>
                                            <div class="simulator-section-title">请求示例</div>
                                            <pre id="openAiModelsRequest" class="simulator-pre"></pre>
                                        </div>
                                        <div>
                                            <div class="simulator-section-title">响应结果</div>
                                            <pre id="openAiModelsResponse" class="simulator-pre simulator-result-pre">尚未请求</pre>
                                        </div>
                                    </div>
                                </div>

                                <div class="tab-pane fade" id="tabOpenAi" role="tabpanel">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <code id="openAiChatUrl" class="simulator-endpoint-code"></code>
                                        <div class="d-flex gap-2 align-items-center">
                                            <div class="form-check form-switch mb-0">
                                                <input class="form-check-input" type="checkbox" id="openAiStreamToggle">
                                                <label class="form-check-label" for="openAiStreamToggle">流式</label>
                                            </div>
                                            <button type="button" class="btn btn-sm btn-outline-primary" onclick="copyText(document.getElementById('openAiChatUrl').textContent)">复制 URL</button>
                                            <button type="button" class="btn btn-sm btn-primary" id="btnOpenAiChat" onclick="sendOpenAiChat()">发送请求</button>
                                        </div>
                                    </div>
                                    <div class="simulator-panel-grid">
                                        <div>
                                            <div class="simulator-section-title">请求示例</div>
                                            <pre id="openAiChatRequest" class="simulator-pre"></pre>
                                        </div>
                                        <div>
                                            <div class="simulator-section-title">响应结果</div>
                                            <pre id="openAiChatResponse" class="simulator-pre simulator-result-pre">尚未请求</pre>
                                        </div>
                                    </div>
                                </div>

                                <div class="tab-pane fade" id="tabAnthropic" role="tabpanel">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <code id="anthropicChatUrl" class="simulator-endpoint-code"></code>
                                        <div class="d-flex gap-2 align-items-center">
                                            <div class="form-check form-switch mb-0">
                                                <input class="form-check-input" type="checkbox" id="anthropicStreamToggle">
                                                <label class="form-check-label" for="anthropicStreamToggle">流式</label>
                                            </div>
                                            <button type="button" class="btn btn-sm btn-outline-primary" onclick="copyText(document.getElementById('anthropicChatUrl').textContent)">复制 URL</button>
                                            <button type="button" class="btn btn-sm btn-primary" id="btnAnthropicChat" onclick="sendAnthropicChat()">发送请求</button>
                                        </div>
                                    </div>
                                    <div class="simulator-panel-grid">
                                        <div>
                                            <div class="simulator-section-title">请求示例</div>
                                            <pre id="anthropicChatRequest" class="simulator-pre"></pre>
                                        </div>
                                        <div>
                                            <div class="simulator-section-title">响应结果</div>
                                            <pre id="anthropicChatResponse" class="simulator-pre simulator-result-pre">尚未请求</pre>
                                        </div>
                                    </div>
                                </div>

                                <div class="tab-pane fade" id="tabResponses" role="tabpanel">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <code id="responsesUrl" class="simulator-endpoint-code"></code>
                                        <div class="d-flex gap-2 align-items-center">
                                            <div class="form-check form-switch mb-0">
                                                <input class="form-check-input" type="checkbox" id="responsesStreamToggle">
                                                <label class="form-check-label" for="responsesStreamToggle">流式</label>
                                            </div>
                                            <button type="button" class="btn btn-sm btn-outline-primary" onclick="copyText(document.getElementById('responsesUrl').textContent)">复制 URL</button>
                                            <button type="button" class="btn btn-sm btn-primary" id="btnResponsesChat" onclick="sendResponsesChat()">发送请求</button>
                                        </div>
                                    </div>
                                    <div class="simulator-panel-grid">
                                        <div>
                                            <div class="simulator-section-title">请求示例</div>
                                            <pre id="responsesChatRequest" class="simulator-pre"></pre>
                                        </div>
                                        <div>
                                            <div class="simulator-section-title">响应结果</div>
                                            <pre id="responsesChatResponse" class="simulator-pre simulator-result-pre">尚未请求</pre>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="tab-pane fade @(concurrencyTabActive ? "show active" : null)" id="developerConcurrencyPane" role="tabpanel">
                <div class="page-header mb-3">
                    <div>
                        <h3 class="page-title h4 mb-1 d-flex align-items-center gap-2">
                            <span>当前模型并发数检测</span>
                            <button type="button"
                                    class="concurrency-help-trigger"
                                    data-bs-toggle="tooltip"
                                    data-bs-placement="top"
                                    title="仅展示最近 6 小时内出现过的站点模型，并同步显示当前并发数、最大并发和排队数。"
                                    aria-label="并发说明">?</button>
                        </h3>
                    </div>
                    <div class="concurrency-refresh-tip">进入此页后自动刷新</div>
                </div>

                <div class="card">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0 concurrency-table">
                                <thead>
                                    <tr>
                                        <th>模型名</th>
                                        <th>站点</th>
                                        <th class="text-end">并发数</th>
                                        <th class="text-end">最大并发</th>
                                        <th class="text-end">排队数</th>
                                    </tr>
                                </thead>
                                <tbody id="concurrencyTableBody">
                                    <tr>
                                        <td colspan="5" class="text-center text-secondary py-4">加载中...</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="tab-pane fade @(invocationsTabActive ? "show active" : null)" id="developerInvocationsPane" role="tabpanel">
                <div class="trace-page-header mb-3">
                    <div>
                        <h3 class="page-title h4 mb-1">调用调试</h3>
                        <p class="page-subtitle mb-0">内存中最多保留最近 100 条记录，且仅保留 6 小时；列表按页加载，每页只展示 20 条</p>
                    </div>
                    <div class="trace-toolbar">
                        <label class="trace-refresh-switch" for="autoRefreshToggle">
                            <input type="checkbox" id="autoRefreshToggle">
                            <span>自动刷新（5 秒）</span>
                        </label>
                        <button type="button" class="btn btn-primary" id="refreshNowButton">立即刷新</button>
                    </div>
                </div>

                <div class="trace-overview-grid mb-4">
                    <article class="trace-overview-card trace-overview-card-primary">
                        <span class="trace-overview-label">当前记录数</span>
                        <strong class="trace-overview-value" id="traceTotalCount">@Model.InitialTotalCount</strong>
                        <span class="trace-overview-hint">最多 100 条，且仅保留 6 小时</span>
                    </article>
                    <article class="trace-overview-card trace-overview-card-danger">
                        <span class="trace-overview-label">失败 / 异常</span>
                        <strong class="trace-overview-value" id="traceFailedCount">@Model.InitialFailedCount</strong>
                        <span class="trace-overview-hint">优先检查红色告警记录</span>
                    </article>
                    <article class="trace-overview-card trace-overview-card-warning">
                        <span class="trace-overview-label">等待返回</span>
                        <strong class="trace-overview-value" id="tracePendingCount">@Model.InitialPendingCount</strong>
                        <span class="trace-overview-hint">请求已到达，但返回尚未补齐</span>
                    </article>
                </div>

                <div class="trace-loading-card" id="traceLoadingCard">
                    <div class="trace-loading-title">调用记录按需加载中</div>
                    <div class="trace-loading-text">首次进入页面时先展示统计信息，详细列表会在后台懒加载，并按页加载 20 条，避免一次性渲染过多记录导致页面抖动。</div>
                </div>

                <div class="accordion trace-accordion d-flex flex-column gap-3" id="invocationTraceAccordion"></div>

                <div class="trace-pagination-bar" id="tracePaginationBar">
                    <div class="trace-pagination-summary" id="tracePaginationSummary">每页 20 条</div>
                    <div class="trace-pagination-actions">
                        <button type="button" class="btn btn-outline-secondary btn-sm" id="tracePrevPageButton">上一页</button>
                        <button type="button" class="btn btn-outline-secondary btn-sm" id="traceNextPageButton">下一页</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .developer-tools-card .nav-tabs {
        padding: 0 12px;
    }

    .client-simulator-page {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .simulator-config-card {
        min-width: 0;
    }

    .simulator-endpoint-code {
        font-size: 13px;
        word-break: break-all;
    }

    .simulator-panel-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
        min-width: 0;
    }

    .simulator-section-title {
        font-size: 13px;
        font-weight: 600;
        color: #475569;
        margin-bottom: 8px;
    }

    .simulator-pre {
        min-height: 320px;
        margin: 0;
        padding: 12px;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        background: #0f172a;
        color: #e2e8f0;
        font-size: 12px;
        line-height: 1.65;
        white-space: pre-wrap;
        word-break: break-word;
        overflow: auto;
    }

    .simulator-result-pre {
        max-height: 400px;
        overflow-y: auto;
        background: #111827;
    }

    .trace-page-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
    }

    .trace-toolbar {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .trace-refresh-switch {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        min-height: 42px;
        padding: 0 14px;
        border-radius: 999px;
        background: #fff;
        border: 1px solid rgba(148, 163, 184, 0.2);
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.05);
        margin: 0;
        cursor: pointer;
        user-select: none;
        font-size: 14px;
        color: var(--text-primary);
    }

    .trace-refresh-switch input {
        width: 16px;
        height: 16px;
        margin: 0;
        accent-color: #2563eb;
        flex: 0 0 auto;
    }

    .trace-refresh-switch span {
        display: inline-flex;
        align-items: center;
        line-height: 1;
        white-space: nowrap;
    }

    .trace-overview-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 16px;
    }

    .trace-overview-card {
        display: flex;
        flex-direction: column;
        gap: 6px;
        padding: 20px 22px;
        background: #fff;
        border-radius: 18px;
        border: 1px solid rgba(226, 232, 240, 0.9);
        box-shadow: 0 10px 28px rgba(15, 23, 42, 0.05);
    }

    .trace-overview-card-primary {
        border-color: rgba(59, 130, 246, 0.18);
        background: linear-gradient(135deg, rgba(239, 246, 255, 0.92), #fff);
    }

    .trace-overview-card-danger {
        border-color: rgba(239, 68, 68, 0.2);
        background: linear-gradient(135deg, rgba(254, 242, 242, 0.95), #fff);
    }

    .trace-overview-card-warning {
        border-color: rgba(245, 158, 11, 0.2);
        background: linear-gradient(135deg, rgba(255, 251, 235, 0.95), #fff);
    }

    .trace-overview-label {
        font-size: 13px;
        color: var(--text-secondary);
    }

    .trace-overview-value {
        font-size: 30px;
        line-height: 1;
        font-weight: 800;
        color: var(--text-primary);
    }

    .trace-overview-hint {
        font-size: 12px;
        color: var(--text-secondary);
    }

    .trace-loading-card {
        margin-bottom: 16px;
        padding: 16px 18px;
        border-radius: 18px;
        border: 1px solid rgba(59, 130, 246, 0.14);
        background: linear-gradient(135deg, rgba(239, 246, 255, 0.9), #fff);
        box-shadow: 0 10px 28px rgba(15, 23, 42, 0.05);
    }

    .trace-loading-title {
        margin-bottom: 6px;
        font-size: 14px;
        font-weight: 700;
        color: #1d4ed8;
    }

    .trace-loading-text {
        font-size: 13px;
        color: var(--text-secondary);
    }

    .trace-loading-card.d-none {
        display: none;
    }

    .trace-pagination-bar {
        display: none;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 16px;
        padding: 14px 16px;
        border-radius: 18px;
        border: 1px solid rgba(226, 232, 240, 0.9);
        background: #fff;
        box-shadow: 0 10px 28px rgba(15, 23, 42, 0.05);
    }

    .trace-pagination-summary {
        font-size: 13px;
        color: var(--text-secondary);
    }

    .trace-pagination-actions {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
    }

    .trace-card {
        border: 1px solid rgba(226, 232, 240, 0.9);
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 12px 32px rgba(15, 23, 42, 0.05);
    }

    .trace-card-success {
        border-left: 6px solid #22c55e;
    }

    .trace-card-pending {
        border-left: 6px solid #f59e0b;
        background: linear-gradient(180deg, rgba(255, 251, 235, 0.4), #fff 42%);
    }

    .trace-card-danger {
        border-left: 6px solid #ef4444;
        background: linear-gradient(180deg, rgba(254, 242, 242, 0.55), #fff 42%);
        box-shadow: 0 16px 36px rgba(239, 68, 68, 0.12);
    }

    .trace-card-header {
        border-bottom: 0;
        padding: 0;
    }

    .trace-card-toggle {
        width: 100%;
        border: 0;
        background: transparent;
        padding: 18px 20px;
        text-align: left;
    }

    .trace-card-toggle:hover {
        background: rgba(248, 250, 252, 0.72);
    }

    .trace-card-main {
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .trace-card-topline {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
    }

    .trace-title-group {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
    }

    .trace-status-pill,
    .trace-protocol-pill,
    .trace-source-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 28px;
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
        line-height: 1;
        white-space: nowrap;
    }

    .trace-status-pill-success {
        background: #e8f7ea;
        color: #166534;
    }

    .trace-status-pill-pending {
        background: #fff5d6;
        color: #b45309;
    }

    .trace-status-pill-danger {
        background: #fee2e2;
        color: #b91c1c;
        box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.08);
    }

    .trace-protocol-pill {
        background: #eff6ff;
        color: #1d4ed8;
    }

    .trace-source-pill {
        background: #f8fafc;
        color: var(--text-secondary);
    }

    .trace-summary-time {
        font-size: 12px;
        color: var(--text-secondary);
    }

    .trace-card-title-row {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
    }

    .trace-model-pair {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .trace-request-model,
    .trace-attempted-model {
        font-size: 18px;
        font-weight: 800;
        color: var(--text-primary);
        word-break: break-word;
    }

    .trace-attempted-model {
        color: #1d4ed8;
    }

    .trace-model-arrow {
        font-size: 18px;
        font-weight: 700;
        color: #94a3b8;
    }

    .trace-meta-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: 10px;
    }

    .trace-meta-chip {
        display: flex;
        flex-direction: column;
        gap: 4px;
        padding: 12px 14px;
        border-radius: 14px;
        background: #f8fafc;
        border: 1px solid rgba(226, 232, 240, 0.95);
    }

    .trace-meta-label {
        font-size: 12px;
        color: var(--text-secondary);
    }

