@page
@model AITool.Web.Pages.Admin.Developer.Invocations.IndexModel
@using global::System.Text.Json
@{
    ViewData["Title"] = "调用调试";
}

<div class="page-header trace-page-header">
    <div>
        <h2 class="page-title">调用调试</h2>
        <p class="page-subtitle">内存中最多保留最近 100 条记录，且仅保留 6 小时；列表按页加载，每页只展示 20 条</p>
    </div>
    <div class="trace-toolbar">
        <label class="trace-refresh-switch" for="autoRefreshToggle">
            <input type="checkbox" id="autoRefreshToggle">
            <span>自动刷新（5 秒）</span>
        </label>
        <button type="button" class="btn btn-primary" id="refreshNowButton">立即刷新</button>
    </div>
</div>

<div class="trace-overview-grid mb-4">
    <article class="trace-overview-card trace-overview-card-primary">
        <span class="trace-overview-label">当前记录数</span>
        <strong class="trace-overview-value" id="traceTotalCount">@Model.InitialTotalCount</strong>
        <span class="trace-overview-hint">最多 100 条，且仅保留 6 小时</span>
    </article>
    <article class="trace-overview-card trace-overview-card-danger">
        <span class="trace-overview-label">失败 / 异常</span>
        <strong class="trace-overview-value" id="traceFailedCount">@Model.InitialFailedCount</strong>
        <span class="trace-overview-hint">优先检查红色告警记录</span>
    </article>
    <article class="trace-overview-card trace-overview-card-warning">
        <span class="trace-overview-label">等待返回</span>
        <strong class="trace-overview-value" id="tracePendingCount">@Model.InitialPendingCount</strong>
        <span class="trace-overview-hint">请求已到达，但返回尚未补齐</span>
    </article>
</div>

<div class="trace-loading-card" id="traceLoadingCard">
    <div class="trace-loading-title">调用记录按需加载中</div>
    <div class="trace-loading-text">首次进入页面时先展示统计信息，详细列表会在后台懒加载，并按页加载 20 条，避免一次性渲染过多记录导致页面抖动。</div>
</div>

<div class="accordion trace-accordion d-flex flex-column gap-3" id="invocationTraceAccordion"></div>

<div class="trace-pagination-bar" id="tracePaginationBar">
    <div class="trace-pagination-summary" id="tracePaginationSummary">每页 20 条</div>
    <div class="trace-pagination-actions">
        <button type="button" class="btn btn-outline-secondary btn-sm" id="tracePrevPageButton">上一页</button>
        <button type="button" class="btn btn-outline-secondary btn-sm" id="traceNextPageButton">下一页</button>
    </div>
</div>

<style>
    .trace-page-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
    }

    .trace-toolbar {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .trace-refresh-switch {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        min-height: 42px;
        padding: 0 14px;
        border-radius: 999px;
        background: #fff;
        border: 1px solid rgba(148, 163, 184, 0.2);
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.05);
        margin: 0;
        cursor: pointer;
        user-select: none;
        font-size: 14px;
        color: var(--text-primary);
    }

    .trace-refresh-switch input {
        width: 16px;
        height: 16px;
        margin: 0;
        accent-color: #2563eb;
        flex: 0 0 auto;
    }

    .trace-refresh-switch span {
        display: inline-flex;
        align-items: center;
        line-height: 1;
        white-space: nowrap;
    }

    .trace-overview-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 16px;
    }

    .trace-overview-card {
        display: flex;
        flex-direction: column;
        gap: 6px;
        padding: 20px 22px;
        background: #fff;
        border-radius: 18px;
        border: 1px solid rgba(226, 232, 240, 0.9);
        box-shadow: 0 10px 28px rgba(15, 23, 42, 0.05);
    }

    .trace-overview-card-primary {
        border-color: rgba(59, 130, 246, 0.18);
        background: linear-gradient(135deg, rgba(239, 246, 255, 0.92), #fff);
    }

    .trace-overview-card-danger {
        border-color: rgba(239, 68, 68, 0.2);
        background: linear-gradient(135deg, rgba(254, 242, 242, 0.95), #fff);
    }

    .trace-overview-card-warning {
        border-color: rgba(245, 158, 11, 0.2);
        background: linear-gradient(135deg, rgba(255, 251, 235, 0.95), #fff);
    }

    .trace-overview-label {
        font-size: 13px;
        color: var(--text-secondary);
    }

    .trace-overview-value {
        font-size: 30px;
        line-height: 1;
        font-weight: 800;
        color: var(--text-primary);
    }

    .trace-overview-hint {
        font-size: 12px;
        color: var(--text-secondary);
    }

    .trace-loading-card {
        margin-bottom: 16px;
        padding: 16px 18px;
        border-radius: 18px;
        border: 1px solid rgba(59, 130, 246, 0.14);
        background: linear-gradient(135deg, rgba(239, 246, 255, 0.9), #fff);
        box-shadow: 0 10px 28px rgba(15, 23, 42, 0.05);
    }

    .trace-loading-title {
        margin-bottom: 6px;
        font-size: 14px;
        font-weight: 700;
        color: #1d4ed8;
    }

    .trace-loading-text {
        font-size: 13px;
        color: var(--text-secondary);
    }

    .trace-loading-card.d-none {
        display: none;
    }

    .trace-pagination-bar {
        display: none;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 16px;
        padding: 14px 16px;
        border-radius: 18px;
        border: 1px solid rgba(226, 232, 240, 0.9);
        background: #fff;
        box-shadow: 0 10px 28px rgba(15, 23, 42, 0.05);
    }

    .trace-pagination-summary {
        font-size: 13px;
        color: var(--text-secondary);
    }

    .trace-pagination-actions {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
    }

    .trace-card {
        border: 1px solid rgba(226, 232, 240, 0.9);
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 12px 32px rgba(15, 23, 42, 0.05);
    }

    .trace-card-success {
        border-left: 6px solid #22c55e;
    }

    .trace-card-pending {
        border-left: 6px solid #f59e0b;
        background: linear-gradient(180deg, rgba(255, 251, 235, 0.4), #fff 42%);
    }

    .trace-card-danger {
        border-left: 6px solid #ef4444;
        background: linear-gradient(180deg, rgba(254, 242, 242, 0.55), #fff 42%);
        box-shadow: 0 16px 36px rgba(239, 68, 68, 0.12);
    }

    .trace-card-header {
        border-bottom: 0;
        padding: 0;
    }

    .trace-card-toggle {
        width: 100%;
        border: 0;
        background: transparent;
        padding: 18px 20px;
        text-align: left;
    }

    .trace-card-toggle:hover {
        background: rgba(248, 250, 252, 0.72);
    }

    .trace-card-main {
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .trace-card-topline {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
    }

    .trace-title-group {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
    }

    .trace-status-pill,
    .trace-protocol-pill,
    .trace-source-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 28px;
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
        line-height: 1;
        white-space: nowrap;
    }

    .trace-status-pill-success {
        background: #e8f7ea;
        color: #166534;
    }

    .trace-status-pill-pending {
        background: #fff5d6;
        color: #b45309;
    }

    .trace-status-pill-danger {
        background: #fee2e2;
        color: #b91c1c;
        box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.08);
    }

    .trace-protocol-pill {
        background: #eff6ff;
        color: #1d4ed8;
    }

    .trace-source-pill {
        background: #f8fafc;
        color: var(--text-secondary);
    }

    .trace-summary-time {
        font-size: 12px;
        color: var(--text-secondary);
    }

    .trace-card-title-row {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
    }

    .trace-model-pair {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .trace-request-model,
    .trace-attempted-model {
        font-size: 18px;
        font-weight: 800;
        color: var(--text-primary);
        word-break: break-word;
    }

    .trace-attempted-model {
        color: #1d4ed8;
    }

    .trace-model-arrow {
        font-size: 18px;
        font-weight: 700;
        color: #94a3b8;
    }

    .trace-meta-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: 10px;
    }

    .trace-meta-chip {
        display: flex;
        flex-direction: column;
        gap: 4px;
        padding: 12px 14px;
        border-radius: 14px;
        background: #f8fafc;
        border: 1px solid rgba(226, 232, 240, 0.95);
    }

    .trace-meta-label {
        font-size: 12px;
        color: var(--text-secondary);
    }

    .trace-chain-tip {
        margin-bottom: 12px;
        font-size: 12px;
        color: var(--text-secondary);
    }

    .trace-attempt-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .trace-attempt-card {
        padding: 14px;
        border-radius: 16px;
        border: 1px solid rgba(226, 232, 240, 0.9);
        background: #fff;
    }

    .trace-attempt-card-success {
        border-left: 5px solid #22c55e;
    }

    .trace-attempt-card-pending {
        border-left: 5px solid #f59e0b;
        background: #fffdf6;
    }

    .trace-attempt-card-danger {
        border-left: 5px solid #ef4444;
        background: #fff7f7;
    }

    .trace-attempt-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
        margin-bottom: 10px;
    }

    .trace-attempt-order {
        display: inline-flex;
        align-items: center;
        min-height: 28px;
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
        line-height: 1;
        background: #f1f5f9;
        color: #334155;
    }

    .trace-attempt-route {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
        margin-bottom: 10px;
    }

    .trace-attempt-site {
        font-size: 13px;
        color: var(--text-secondary);
    }

    .trace-meta-grid-attempt {
        margin-bottom: 12px;
    }

    .trace-info-panel,
    .trace-code-panel {
        border-radius: 16px;
        border: 1px solid rgba(226, 232, 240, 0.9);
        background: #f8fafc;
        padding: 16px;
    }

    .trace-error-stack {
        display: grid;
        gap: 12px;
        min-width: 0;
    }

    .trace-code-panel {
        min-width: 0;
        overflow: hidden;
    }

    .trace-info-panel {
        display: flex;
        flex-direction: column;
        gap: 10px;
        font-size: 13px;
        color: var(--text-primary);
    }

    .trace-section-title {
        margin-bottom: 10px;
        font-size: 13px;
        font-weight: 700;
        color: var(--text-secondary);
    }

    .trace-section-title-danger {
        color: #b91c1c;
    }

    .trace-code-panel-danger {
        background: #fff5f5;
        border-color: rgba(239, 68, 68, 0.22);
    }

    .trace-panel-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 10px;
        flex-wrap: wrap;
    }

    .trace-copy-btn {
        min-width: 96px;
    }

    .trace-pre {
        margin: 0;
        white-space: pre-wrap;
        word-break: break-word;
        max-height: 360px;
        overflow: auto;
        font-size: 12px;
        line-height: 1.6;
    }

    @@media (max-width: 768px) {
        .trace-page-header,
        .trace-toolbar {
            align-items: stretch;
        }

        .trace-toolbar .btn {
            width: 100%;
        }

        .trace-refresh-switch {
            justify-content: center;
        }

        .trace-card-toggle {
            padding: 16px;
        }

        .trace-request-model,
        .trace-attempted-model {
            font-size: 16px;
        }
    }
</style>

@section Scripts {
    <script>
        (function () {
            var autoRefreshToggle = document.getElementById('autoRefreshToggle');
            var refreshNowButton = document.getElementById('refreshNowButton');
            var traceAccordion = document.getElementById('invocationTraceAccordion');
            var traceLoadingCard = document.getElementById('traceLoadingCard');
            var tracePaginationBar = document.getElementById('tracePaginationBar');
            var tracePaginationSummary = document.getElementById('tracePaginationSummary');
            var tracePrevPageButton = document.getElementById('tracePrevPageButton');
            var traceNextPageButton = document.getElementById('traceNextPageButton');
            var refreshIntervalMs = 5000;
            var refreshTimerId = null;
            var listEndpoint = '@Url.Page("./Index", "List")';
            var detailEndpoint = '@Url.Page("./Index", "Detail")';
            var hasLoadedListOnce = false;
            var isRefreshing = false;
            var currentPage = 1;
            var currentTotalPages = 1;

            function escapeHtml(value) {
                return (value || '').replace(/[&<>"']/g, function (char) {
                    switch (char) {
                        case '&': return '&amp;';
                        case '<': return '&lt;';
                        case '>': return '&gt;';
                        case '"': return '&quot;';
                        case '\'': return '&#39;';
                        default: return char;
                    }
                });
            }

            function getOpenTraceIds() {
                if (!traceAccordion) {
                    return [];
                }

                return Array.from(traceAccordion.querySelectorAll('.collapse.show'))
                    .map(function (element) { return element.id; })
                    .filter(Boolean);
            }

            function updateSummary(payload) {
                var totalEl = document.getElementById('traceTotalCount');
                var failedEl = document.getElementById('traceFailedCount');
                var pendingEl = document.getElementById('tracePendingCount');
                if (totalEl) {
                    totalEl.textContent = payload.totalCount;
                }
                if (failedEl) {
                    failedEl.textContent = payload.failedCount;
                }
                if (pendingEl) {
                    pendingEl.textContent = payload.pendingCount;
                }
            }

            function formatDuration(durationMs) {
                var value = Number(durationMs || 0);
                if (!value || value <= 0) {
                    return '-';
                }

                // 按量级自动切换毫秒、秒、分钟，避免长耗时记录难以扫读。
                if (value < 1000) {
                    return value + ' ms';
                }
                if (value < 60000) {
                    return formatDurationNumber(value / 1000) + ' 秒';
                }
                return formatDurationNumber(value / 60000) + ' 分';
            }

            function formatDurationNumber(value) {
                return Number(value.toFixed(value >= 10 ? 1 : 2)).toString();
            }

            // 分页信息需要在自动刷新后继续保持当前页，并在不足一页时直接隐藏翻页栏。
            function updatePagination(payload) {
                currentPage = payload.pageNumber || 1;
                currentTotalPages = payload.totalPages || 1;
                var totalCount = payload.totalCount || 0;
                var pageSize = payload.pageSize || 20;
                var shouldShowPagination = currentTotalPages > 1 && totalCount > pageSize;
                if (tracePaginationBar) {
                    tracePaginationBar.style.display = shouldShowPagination ? 'flex' : 'none';
                }
                if (tracePaginationSummary) {
                    tracePaginationSummary.textContent = '第 ' + currentPage + ' / ' + currentTotalPages + ' 页 · 每页 ' + pageSize + ' 条 · 共 ' + totalCount + ' 条';
                }
                if (tracePrevPageButton) {
                    tracePrevPageButton.disabled = !shouldShowPagination || currentPage <= 1 || isRefreshing;
                }
                if (traceNextPageButton) {
                    traceNextPageButton.disabled = !shouldShowPagination || currentPage >= currentTotalPages || isRefreshing;
                }
            }

            function buildListUrl(page) {
                var url = new URL(listEndpoint, window.location.origin);
                url.searchParams.set('page', String(page || 1));
                return url.toString();
            }

            function buildDetailUrl(traceId) {
                var url = new URL(detailEndpoint, window.location.origin);
                url.searchParams.set('traceId', String(traceId || ''));
                return url.toString();
            }

            function renderRequestHeaders(headers) {
                try {
                    return JSON.stringify(headers || {}, null, 2);
                } catch {
                    return '{}';
                }
            }

            function getForwardingModeText(forwardingMode) {
                switch ((forwardingMode || '').toLowerCase()) {
                    case 'direct':
                        return '直接透传';
                    case 'bridge':
                        return '兼容中转';
                    default:
                        return '未标记';
                }
            }

            function renderAttempts(entry) {
                if (!entry.attempts || entry.attempts.length === 0) {
                    return '';
                }

                return '' +
                    '<div class="trace-attempt-list">' +
                    entry.attempts.map(function (attempt, attemptIndex) {
                        var attemptStatusCodeText = attempt.statusCode > 0 ? String(attempt.statusCode) : '-';
                        var attemptDurationText = formatDuration(attempt.totalDurationMs);
                        var attemptResponseBodyText = attempt.responseBody && attempt.responseBody.trim() ? attempt.responseBody : '-';
                        var attemptErrorBlock = attempt.errorMessage && attempt.errorMessage.trim()
                            ? '<div class="trace-error-stack"><div class="trace-section-title trace-section-title-danger">尝试错误</div><pre class="trace-pre trace-code-panel trace-code-panel-danger">' + escapeHtml(attempt.errorMessage) + '</pre></div>'
                            : '';

                        return '' +
                            '<article class="trace-attempt-card trace-attempt-card-' + escapeHtml(attempt.statusClass) + '">' +
                                '<div class="trace-attempt-head">' +
                                    '<div class="trace-title-group">' +
                                        '<span class="trace-status-pill trace-status-pill-' + escapeHtml(attempt.statusClass) + '">' + escapeHtml(attempt.statusText) + '</span>' +
                                        '<span class="trace-attempt-order">尝试 ' + (attemptIndex + 1) + '</span>' +
                                        '<span class="trace-protocol-pill">' + escapeHtml(attempt.upstreamProtocolType || '-') + '</span>' +
                                        '<span class="trace-source-pill">' + escapeHtml(getForwardingModeText(attempt.forwardingMode)) + '</span>' +
                                    '</div>' +
                                    '<div class="trace-summary-time">' + escapeHtml(attempt.createdAtText) + '</div>' +
                                '</div>' +
                                '<div class="trace-attempt-route">' +
                                    '<div class="trace-attempted-model">' + escapeHtml(attempt.summaryAttemptedModel) + '</div>' +
                                    '<div class="trace-attempt-site">' + escapeHtml(attempt.summarySite) + '</div>' +
                                '</div>' +
                                '<div class="trace-meta-grid trace-meta-grid-attempt">' +
                                    '<div class="trace-meta-chip"><span class="trace-meta-label">转发方式</span><strong>' + escapeHtml(getForwardingModeText(attempt.forwardingMode)) + '</strong></div>' +
                                    '<div class="trace-meta-chip"><span class="trace-meta-label">状态码</span><strong>' + escapeHtml(attemptStatusCodeText) + '</strong></div>' +
                                    '<div class="trace-meta-chip"><span class="trace-meta-label">总耗时</span><strong>' + escapeHtml(attemptDurationText) + '</strong></div>' +
                                    '<div class="trace-meta-chip"><span class="trace-meta-label">Token</span><strong>' + escapeHtml(attempt.inputTokens + ' / ' + attempt.cachedTokens + ' / ' + attempt.outputTokens) + '</strong></div>' +
                                '</div>' +
                                attemptErrorBlock +
                                '<div class="row g-3">' +
                                    '<div class="col-xl-6">' +
                                        '<div class="trace-panel-header">' +
                                            '<div class="trace-section-title mb-0">尝试返回体</div>' +
                                            '<button type="button" class="btn btn-sm btn-outline-secondary trace-copy-btn" onclick="copyTraceContent(this)" data-copy-target="attempt-response-body-' + entry.traceId + '-' + attempt.attemptId + '">复制返回体</button>' +
                                        '</div>' +
                                        '<pre id="attempt-response-body-' + entry.traceId + '-' + attempt.attemptId + '" class="trace-pre trace-code-panel">' + escapeHtml(attemptResponseBodyText) + '</pre>' +
                                    '</div>' +
                                '</div>' +
                            '</article>';
                    }).join('') +
                    '</div>';
            }

            function renderDetail(entry) {
                var responseBodyText = entry.responseBody && entry.responseBody.trim() ? entry.responseBody : '-';
                var errorBlock = entry.errorMessage && entry.errorMessage.trim()
                    ? '<div class="trace-error-stack"><div class="trace-section-title trace-section-title-danger">错误信息</div><pre class="trace-pre trace-code-panel trace-code-panel-danger">' + escapeHtml(entry.errorMessage) + '</pre></div>'
                    : '';
                var attemptsSummary = '成功 ' + (entry.successAttemptCount || 0) + ' / 失败 ' + (entry.failedAttemptCount || 0) + ' / 等待 ' + (entry.pendingAttemptCount || 0);

                return '' +
                    '<div class="card-body d-flex flex-column gap-3">' +
                        '<div class="row g-3">' +
                            '<div class="col-xl-4">' +
                                '<div class="trace-section-title">基础信息</div>' +
                                '<div class="trace-info-panel">' +
                                    '<div><strong>客户端来源：</strong>' + escapeHtml(entry.source) + '</div>' +
                                    '<div><strong>User-Agent：</strong>' + escapeHtml(entry.userAgent || '-') + '</div>' +
                                    '<div><strong>客户端 IP：</strong>' + escapeHtml(entry.clientIp || '-') + '</div>' +
                                    '<div><strong>请求协议：</strong>' + escapeHtml(entry.protocolType) + '</div>' +
                                    '<div><strong>请求模型：</strong>' + escapeHtml(entry.requestModel) + '</div>' +
                                    '<div><strong>最终状态：</strong>' + escapeHtml(entry.statusText) + '</div>' +
                                    '<div><strong>尝试次数：</strong>' + escapeHtml(String((entry.attempts || []).length)) + '</div>' +
                                    '<div><strong>尝试统计：</strong>' + escapeHtml(attemptsSummary) + '</div>' +
                                '</div>' +
                            '</div>' +
                            '<div class="col-xl-8">' +
                                '<div class="trace-section-title">请求头</div>' +
                                '<pre class="trace-pre trace-code-panel">' + escapeHtml(renderRequestHeaders(entry.requestHeaders)) + '</pre>' +
                            '</div>' +
                        '</div>' +
                        '<div>' +
                            '<div class="trace-section-title">真实路由尝试链路</div>' +
                            '<div class="trace-chain-tip">会按真实尝试顺序展示每一次命中的路由模型，包括前面失败、后面成功的完整链路。</div>' +
                            (renderAttempts(entry) || '<div class="trace-info-panel">当前还没有命中任何路由尝试。</div>') +
                        '</div>' +
                        errorBlock +
                        '<div class="row g-3">' +
                            '<div class="col-xl-6">' +
                                '<div class="trace-panel-header">' +
                                    '<div class="trace-section-title mb-0">请求体</div>' +
                                    '<button type="button" class="btn btn-sm btn-outline-secondary trace-copy-btn" onclick="copyTraceContent(this)" data-copy-target="request-body-' + entry.traceId + '">复制请求体</button>' +
                                '</div>' +
                                '<pre id="request-body-' + entry.traceId + '" class="trace-pre trace-code-panel">' + escapeHtml(entry.requestBody) + '</pre>' +
                            '</div>' +
                            '<div class="col-xl-6">' +
                                '<div class="trace-panel-header">' +
                                    '<div class="trace-section-title mb-0">返回体</div>' +
                                    '<button type="button" class="btn btn-sm btn-outline-secondary trace-copy-btn" onclick="copyTraceContent(this)" data-copy-target="response-body-' + entry.traceId + '">复制返回体</button>' +
                                '</div>' +
                                '<pre id="response-body-' + entry.traceId + '" class="trace-pre trace-code-panel">' + escapeHtml(responseBodyText) + '</pre>' +
                            '</div>' +
                        '</div>' +
                    '</div>';
            }

            function renderEntry(entry) {
                var traceCollapseId = 'invocation-trace-' + entry.traceId;
                var statusCodeText = entry.statusCode > 0 ? String(entry.statusCode) : '-';
                var durationText = formatDuration(entry.totalDurationMs);
                var attemptsSummary = '成功 ' + (entry.successAttemptCount || 0) + ' / 失败 ' + (entry.failedAttemptCount || 0) + ' / 等待 ' + (entry.pendingAttemptCount || 0);

                return '' +
                    '<div class="card trace-card trace-card-' + escapeHtml(entry.statusClass) + '" data-trace-status="' + escapeHtml(entry.status) + '">' +
                        '<div class="card-header trace-card-header bg-white">' +
                            '<button class="trace-card-toggle" type="button" data-bs-toggle="collapse" data-bs-target="#' + traceCollapseId + '" aria-expanded="false" aria-controls="' + traceCollapseId + '">' +
                                '<div class="trace-card-main">' +
                                    '<div class="trace-card-topline">' +
                                        '<div class="trace-title-group">' +
                                            '<span class="trace-status-pill trace-status-pill-' + escapeHtml(entry.statusClass) + '">' + escapeHtml(entry.statusText) + '</span>' +
                                            '<span class="trace-protocol-pill">' + escapeHtml(entry.protocolType) + '</span>' +
                                            '<span class="trace-source-pill">' + escapeHtml(entry.source) + '</span>' +
                                        '</div>' +
                                        '<div class="trace-summary-time">' + escapeHtml(entry.createdAtText) + '</div>' +
                                    '</div>' +
                                    '<div class="trace-card-title-row">' +
                                        '<div class="trace-model-pair">' +
                                            '<div class="trace-request-model">' + escapeHtml(entry.requestModel) + '</div>' +
                                            '<div class="trace-model-arrow">→</div>' +
                                            '<div class="trace-attempted-model">' + escapeHtml(entry.summaryAttemptedModel) + '</div>' +
                                        '</div>' +
                                    '</div>' +
                                    '<div class="trace-meta-grid">' +
                                        '<div class="trace-meta-chip"><span class="trace-meta-label">目标站点</span><strong>' + escapeHtml(entry.summarySite) + '</strong></div>' +
                                        '<div class="trace-meta-chip"><span class="trace-meta-label">请求路径</span><strong>' + escapeHtml(entry.requestPath) + '</strong></div>' +
                                        '<div class="trace-meta-chip"><span class="trace-meta-label">尝试统计</span><strong>' + escapeHtml(attemptsSummary) + '</strong></div>' +
                                        '<div class="trace-meta-chip"><span class="trace-meta-label">状态码</span><strong>' + escapeHtml(statusCodeText) + '</strong></div>' +
                                        '<div class="trace-meta-chip"><span class="trace-meta-label">总耗时</span><strong>' + escapeHtml(durationText) + '</strong></div>' +
                                    '</div>' +
                                '</div>' +
                            '</button>' +
                        '</div>' +
                        '<div id="' + traceCollapseId + '" class="collapse" data-bs-parent="#invocationTraceAccordion" data-trace-id="' + escapeHtml(entry.traceId) + '">' +
                            '<div class="card-body d-flex flex-column gap-3 trace-detail-loading">' +
                                '<div class="trace-loading-title">详情将在展开后加载</div>' +
                                '<div class="trace-loading-text">为减少列表刷新开销，请求头、请求体、返回体和完整尝试链路会在展开当前卡片后单独获取。</div>' +
                            '</div>' +
                        '</div>' +
                    '</div>';
            }

            function renderEmptyState() {
                return '<div class="card trace-empty-card"><div class="card-body text-secondary">暂无调用记录</div></div>';
            }

            // 展开时单独加载明细，避免分页列表和自动刷新反复搬运大字段。
            async function loadTraceDetail(collapseElement) {
                if (!collapseElement) {
                    return;
                }

                var traceId = collapseElement.getAttribute('data-trace-id');
                if (!traceId || collapseElement.getAttribute('data-detail-loading') === 'true') {
                    return;
                }

                collapseElement.setAttribute('data-detail-loading', 'true');
                collapseElement.innerHTML = '<div class="card-body d-flex flex-column gap-3 trace-detail-loading"><div class="trace-loading-title">详情加载中</div><div class="trace-loading-text">正在单独获取当前调用记录的请求头、请求体、返回体和尝试链路。</div></div>';

                try {
                    var response = await fetch(buildDetailUrl(traceId), {
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        cache: 'no-store'
                    });

                    if (!response.ok) {
                        collapseElement.innerHTML = '<div class="card-body"><div class="trace-error-stack"><div class="trace-section-title trace-section-title-danger">详情加载失败</div><pre class="trace-pre trace-code-panel trace-code-panel-danger">无法读取当前调用记录详情，请稍后重试。</pre></div></div>';
                        return;
                    }

                    var payload = await response.json();
                    collapseElement.innerHTML = renderDetail(payload);
                } catch {
                    collapseElement.innerHTML = '<div class="card-body"><div class="trace-error-stack"><div class="trace-section-title trace-section-title-danger">详情加载失败</div><pre class="trace-pre trace-code-panel trace-code-panel-danger">请求详情接口时发生异常，请稍后重试。</pre></div></div>';
                } finally {
                    collapseElement.removeAttribute('data-detail-loading');
                }
            }

            function restoreOpenTraceIds(openIds) {
                if (!Array.isArray(openIds)) {
                    return;
                }

                openIds.forEach(function (id) {
                    var element = document.getElementById(id);
                    if (!element) {
                        return;
                    }

                    var collapse = bootstrap.Collapse.getOrCreateInstance(element, { toggle: false });
                    collapse.show();
                });
            }

            async function refreshTraceList(page) {
                if (isRefreshing) {
                    return;
                }

                isRefreshing = true;
                var requestedPage = Math.max(1, page || currentPage || 1);
                var openIds = hasLoadedListOnce ? getOpenTraceIds() : [];
                updatePagination({ pageNumber: requestedPage, pageSize: 20, totalPages: Math.max(currentTotalPages, requestedPage, 1), totalCount: currentTotalPages > 1 ? currentTotalPages * 20 : 0 });

                try {
                    var response = await fetch(buildListUrl(requestedPage), {
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        cache: 'no-store'
                    });

                    if (!response.ok) {
                        return;
                    }

                    var payload = await response.json();
                    updateSummary(payload);
                    updatePagination(payload);

                    if (!traceAccordion) {
                        return;
                    }

                    if (!payload.entries || payload.entries.length === 0) {
                        traceAccordion.innerHTML = renderEmptyState();
                        hasLoadedListOnce = true;
                        if (traceLoadingCard) {
                            traceLoadingCard.classList.add('d-none');
                        }
                        return;
                    }

                    traceAccordion.innerHTML = payload.entries.map(renderEntry).join('');
                    hasLoadedListOnce = true;
                    if (traceLoadingCard) {
                        traceLoadingCard.classList.add('d-none');
                    }
                    restoreOpenTraceIds(openIds);
                } finally {
                    isRefreshing = false;
                    if (tracePrevPageButton) {
                        tracePrevPageButton.disabled = currentPage <= 1;
                    }
                    if (traceNextPageButton) {
                        traceNextPageButton.disabled = currentPage >= currentTotalPages;
                    }
                }
            }

            if (traceAccordion) {
                traceAccordion.addEventListener('shown.bs.collapse', function (event) {
                    loadTraceDetail(event.target);
                });
            }

            if (refreshNowButton) {
                refreshNowButton.addEventListener('click', function () {
                    refreshTraceList(currentPage);
                });
            }

            if (tracePrevPageButton) {
                tracePrevPageButton.addEventListener('click', function () {
                    if (currentPage > 1) {
                        refreshTraceList(currentPage - 1);
                    }
                });
            }

            if (traceNextPageButton) {
                traceNextPageButton.addEventListener('click', function () {
                    if (currentPage < currentTotalPages) {
                        refreshTraceList(currentPage + 1);
                    }
                });
            }

            if (autoRefreshToggle) {
                autoRefreshToggle.addEventListener('change', function () {
                    if (autoRefreshToggle.checked && !hasLoadedListOnce) {
                        refreshTraceList(currentPage);
                    }
                });
            }

            window.copyTraceContent = async function (button) {
                if (!button) {
                    return;
                }

                var targetId = button.getAttribute('data-copy-target');
                var target = targetId ? document.getElementById(targetId) : null;
                var text = target ? (target.textContent || '') : '';
                if (!text) {
                    return;
                }

                try {
                    if (navigator.clipboard && window.isSecureContext) {
                        await navigator.clipboard.writeText(text);
                    } else {
                        var textarea = document.createElement('textarea');
                        textarea.value = text;
                        textarea.setAttribute('readonly', 'readonly');
                        textarea.style.position = 'fixed';
                        textarea.style.opacity = '0';
                        textarea.style.left = '-9999px';
                        document.body.appendChild(textarea);
                        textarea.focus();
                        textarea.select();
                        document.execCommand('copy');
                        document.body.removeChild(textarea);
                    }

                    var originalText = button.textContent;
                    button.textContent = '复制成功';
                    button.disabled = true;
                    window.setTimeout(function () {
                        button.textContent = originalText;
                        button.disabled = false;
                    }, 1200);
                } catch {
                    var fallbackText = button.textContent;
                    button.textContent = '复制失败';
                    button.disabled = true;
                    window.setTimeout(function () {
                        button.textContent = fallbackText;
                        button.disabled = false;
                    }, 1200);
                }
            };

            function ensureRefreshTimer() {
                if (refreshTimerId) {
                    window.clearInterval(refreshTimerId);
                }

                refreshTimerId = window.setInterval(function () {
                    if (autoRefreshToggle && autoRefreshToggle.checked) {
                        refreshTraceList(currentPage);
                    }
                }, refreshIntervalMs);
            }

            ensureRefreshTimer();
            window.setTimeout(function () {
                refreshTraceList(currentPage);
            }, 0);
        })();
    </script>
}
