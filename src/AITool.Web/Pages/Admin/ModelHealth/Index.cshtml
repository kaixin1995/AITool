@page
@model AITool.Web.Pages.Admin.ModelHealth.IndexModel
@{
    ViewData["Title"] = "模型健康看板";
}

<style>
    .health-overview-table {
        width: 100%;
        border-collapse: collapse;
        background: #fff;
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(15, 23, 42, 0.06);
    }

    .health-overview-table th,
    .health-overview-table td {
        padding: 22px 18px;
        border-bottom: 1px solid var(--border-light);
        vertical-align: middle;
    }

    .health-overview-table thead th {
        font-size: 14px;
        font-weight: 700;
        color: var(--text-secondary);
        background: #fff;
        white-space: nowrap;
    }

    .health-overview-table tbody tr:last-child td {
        border-bottom: none;
    }

    .health-model-cell {
        min-width: 260px;
    }

    .health-model-name {
        font-size: 16px;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 6px;
    }

    .health-model-meta {
        font-size: 13px;
        color: var(--text-secondary);
    }

    .health-kpi-value {
        font-size: 18px;
        font-weight: 700;
        color: var(--text-primary);
        white-space: nowrap;
    }

    .health-kpi-value.success-rate {
        color: var(--success);
    }

    .health-kpi-value.latency {
        color: var(--danger);
    }

    .health-status-bars {
        display: flex;
        align-items: stretch;
        gap: 2px;
        width: 118px;
        min-width: 118px;
    }

    .health-status-bar-item {
        width: 8px;
        height: 36px;
        border-radius: 3px;
        background: var(--success);
        flex: 0 0 auto;
    }

    .health-status-bar-item.fail {
        background: var(--danger);
    }

    .health-status-bar-item.empty {
        background: #e2e8f0;
    }

    .health-row-actions {
        display: flex;
        gap: 10px;
        justify-content: flex-end;
        flex-wrap: wrap;
    }

    .health-action-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 88px;
        height: 36px;
        padding: 0 14px;
        border-radius: 999px;
        border: 1px solid transparent;
        background: #f8fafc;
        color: var(--text-secondary);
        font-size: 13px;
        font-weight: 600;
        line-height: 1;
        transition: all 0.18s ease;
        box-shadow: inset 0 0 0 1px rgba(148, 163, 184, 0.12);
    }

    .health-action-btn:hover {
        transform: translateY(-1px);
    }

    .health-action-btn.detail {
        background: #eff6ff;
        color: var(--primary);
        border-color: rgba(59, 130, 246, 0.18);
    }

    .health-action-btn.detail:hover {
        background: #dbeafe;
        color: #1d4ed8;
    }

    .health-action-btn.remove {
        background: #fff5f5;
        color: var(--danger);
        border-color: rgba(239, 68, 68, 0.16);
    }

    .health-action-btn.remove:hover {
        background: #fee2e2;
        color: #dc2626;
    }

    .health-action-form {
        display: inline-flex;
    }

    .health-detail-row > td {
        background: #fbfdff;
        padding-top: 0;
    }

    .health-detail-panel {
        padding-top: 16px;
        max-width: 100%;
        overflow: hidden;
    }

    .health-site-card {
        margin-bottom: 16px;
        padding: 18px;
        border: 1px solid var(--border-light);
        border-radius: 16px;
        background: #fff;
        overflow: hidden;
    }

    .health-site-card:last-child {
        margin-bottom: 0;
    }

    .health-site-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
        margin-bottom: 12px;
    }

    .health-site-name {
        font-size: 15px;
        color: var(--text-primary);
    }

    .health-site-meta {
        font-size: 13px;
        color: var(--text-secondary);
        white-space: nowrap;
    }

    .health-rate-bar {
        margin-bottom: 14px;
    }

    .health-rate-label {
        margin-bottom: 8px;
        font-size: 13px;
        color: var(--text-secondary);
    }

    .health-rate-track {
        height: 8px;
        border-radius: 999px;
        background: #e2e8f0;
        overflow: hidden;
    }

    .health-rate-fill {
        height: 100%;
        border-radius: inherit;
    }

    .health-timeline {
        min-width: 0;
    }

    .health-timeline-line {
        display: flex;
        align-items: center;
        gap: 4px;
        width: 100%;
        min-height: 18px;
    }

    .health-timeline-segment {
        position: relative;
        height: 10px;
        border-radius: 999px;
        flex: 1 1 0;
        min-width: 8px;
        background: var(--success);
    }

    .health-timeline-segment.fail {
        background: var(--danger);
    }

    .health-timeline-range {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        margin-top: 8px;
        font-size: 12px;
        color: var(--text-secondary);
    }

    @@media (max-width: 1200px) {
        .health-overview-table {
            display: block;
            overflow-x: auto;
        }
    }

    @@media (max-width: 768px) {
        .health-overview-table th,
        .health-overview-table td {
            padding: 16px 12px;
        }

        .health-row-actions {
            justify-content: flex-start;
        }

        .health-site-card {
            padding: 14px;
        }
    }
</style>

<!-- 页面标题 -->
<div class="page-header">
    <div>
        <h2 class="page-title">模型健康看板</h2>
        <p class="page-subtitle">监控指定模型在各站点的健康状态和检测历史</p>
    </div>
</div>

<!-- 操作提示 -->
@if (Model.StatusMessage is not null)
{
    <div class="alert @(Model.StatusSuccess ? "alert-success" : "alert-danger")">
        @Model.StatusMessage
    </div>
}

<!-- 添加监控模型 -->
<div class="form-card" style="margin-bottom:20px;">
    <div class="form-section-title">添加监控模型</div>
    <form method="post" asp-page-handler="AddMonitor" class="row g-2 align-items-end">
        <div class="col-md-4">
            <label class="form-label" for="availableModelSearch">搜索模型</label>
            <input type="text" id="availableModelSearch" class="form-control" placeholder="输入模型名称过滤下拉选项..." oninput="filterAvailableModels()" />
        </div>
        <div class="col-md-5">
            <label class="form-label" for="availableModelSelect">选择模型</label>
            <select id="availableModelSelect" name="modelId" class="form-select" required>
                <option value="">-- 请选择模型 --</option>
                @foreach (var m in Model.AvailableModels)
                {
                    <option value="@m.Id">@m.DisplayName</option>
                }
            </select>
            <div id="availableModelSearchEmpty" class="form-text" style="display:none;">没有匹配的模型，请调整关键词。</div>
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary">添加监控</button>
        </div>
    </form>
</div>

<!-- 搜索过滤 -->
@if (Model.MonitoredModels.Any())
{
    <div class="form-card" style="margin-bottom:20px;">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label" for="range">时间范围</label>
                <select id="range" name="range" class="form-select" onchange="this.form.submit()">
                    @foreach (var option in Model.RangeOptions)
                    {
                        <option value="@option.Value" selected="@(Model.Range == option.Value ? "selected" : null)">@option.Label</option>
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">搜索模型</label>
                <input type="text" id="healthSearch" class="form-control" placeholder="输入模型名称过滤..." oninput="filterHealthModels()" />
            </div>
        </form>
    </div>
}

<!-- 未监控任何模型时的提示 -->
@if (!Model.MonitoredModels.Any())
{
    <div class="table-wrapper">
        <div class="table-empty">
            <div class="table-empty-icon">💊</div>
            <div class="table-empty-text">暂未配置监控模型，请在上方选择模型添加</div>
        </div>
    </div>
}

@if (Model.MonitoredModels.Any())
{
    <div class="table-wrapper">
        <table class="health-overview-table">
            <thead>
                <tr>
                    <th>模型</th>
                    <th>最近状态</th>
                    <th>成功率</th>
                    <th>成功/失败</th>
                    <th>总调用</th>
                    <th>平均延迟</th>
                    <th style="text-align:right;">操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var monitored in Model.MonitoredModels)
                {
                    var healths = Model.HealthData.GetValueOrDefault(monitored.ModelLibraryItemId) ?? [];
                    var detailId = $"health-detail-{monitored.ModelLibraryItemId:N}";
                    var overviewStatusSlots = BuildOverviewRateSlots(monitored.SuccessCount, monitored.FailureCount);

                    <tr class="health-model-group" data-display-name="@monitored.DisplayName" data-detail-id="@detailId">
                        <td class="health-model-cell">
                            <div class="health-model-name">@monitored.DisplayName</div>
                            <div class="health-model-meta">@monitored.SiteCount 个关联站点</div>
                        </td>
                        <td>
                            <div class="health-status-bars">
                                @foreach (var slot in overviewStatusSlots)
                                {
                                    var barClass = slot.Status == "fail"
                                        ? "fail"
                                        : slot.Status == "empty"
                                            ? "empty"
                                            : string.Empty;
                                    <div class="health-status-bar-item @barClass" title="@slot.Title"></div>
                                }
                            </div>
                        </td>
                        <td>
                            <span class="health-kpi-value success-rate">@((monitored.AverageSuccessRate * 100).ToString("F1"))%</span>
                        </td>
                        <td>
                            <div class="health-kpi-value">@monitored.SuccessCount / @monitored.FailureCount</div>
                            <div class="health-model-meta">成功 / 失败</div>
                        </td>
                        <td>
                            <span class="health-kpi-value">@monitored.TotalRequestCount</span>
                        </td>
                        <td>
                            <span class="health-kpi-value latency">@(monitored.AverageDurationMs.HasValue ? $"{FormatDuration(monitored.AverageDurationMs.Value)}" : "-")</span>
                        </td>
                        <td>
                            <div class="health-row-actions">
                                <button type="button" class="health-action-btn detail" onclick="toggleHealthDetail('@detailId', this)">查看明细</button>
                                <form method="post" asp-page-handler="RemoveMonitor" asp-route-modelId="@monitored.ModelLibraryItemId" class="health-action-form">
                                    <button type="submit" class="health-action-btn remove" onclick="return confirm('确认移除该模型的监控？')">移除监控</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    <tr id="@detailId" class="health-detail-row" style="display:none;">
                        <td colspan="7">
                            <div class="health-detail-panel">
                                @if (healths.Any())
                                {
                                    <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
                                        <span class="badge bg-light text-dark">@monitored.SiteCount 个关联站点</span>
                                        <span class="badge bg-success">@monitored.HealthySiteCount 个正常站点</span>
                                        <span class="badge bg-danger">@monitored.UnhealthySiteCount 个异常站点</span>
                                        <span class="badge bg-success-subtle text-success-emphasis">成功 @monitored.SuccessCount 次</span>
                                        <span class="badge bg-danger-subtle text-danger-emphasis">失败 @monitored.FailureCount 次</span>
                                        <span class="badge bg-light text-dark">总请求 @monitored.TotalRequestCount 次</span>
                                    </div>

                                    foreach (var site in healths)
                                    {
                                        <div class="health-site-card">
                                            <div class="health-site-header">
                                                <div>
                                                    <strong class="health-site-name">@site.SiteName</strong>
                                                    <code>@site.RemoteModelName</code>
                                                    <span class="badge bg-@(site.LastStatus == "success" ? "success" : site.LastStatus == "fail" ? "danger" : "secondary")">
                                                        @(site.LastStatus == "success" ? "正常" : site.LastStatus == "fail" ? "异常" : site.LastStatus)
                                                    </span>
                                                </div>
                                                <div class="health-site-meta">
                                                    成功率 @((site.SuccessRate * 100).ToString("F1"))%
                                                    <span class="text-secondary">· 成功 @site.SuccessCount 次</span>
                                                    <span class="text-secondary">· 失败 @site.FailureCount 次</span>
                                                    <span class="text-secondary">· 总请求 @site.RecentLogs.Count 次</span>
                                                    @if (site.LastDurationMs.HasValue)
                                                    {
                                                        <span class="text-secondary">· @site.LastDurationMs ms</span>
                                                    }
                                                </div>
                                            </div>

                                            <div class="health-rate-bar">
                                                <div class="health-rate-label">成功率 @((site.SuccessRate * 100).ToString("F1"))%</div>
                                                <div class="health-rate-track">
                                                    <div class="health-rate-fill" style="width: @((site.SuccessRate * 100).ToString("F1"))%;
                                                        background: @(site.SuccessRate >= 0.8 ? "var(--success)" : site.SuccessRate >= 0.5 ? "var(--warning)" : "var(--danger)");"></div>
                                                </div>
                                            </div>

                                            @if (site.RecentLogs.Any())
                                            {
                                                <div class="health-timeline">
                                                    <div class="health-timeline-label">@GetTimelineTitle(Model.Range, site.RecentLogs.Count, site.SuccessCount, site.FailureCount)（线段按时间段聚合，出现失败即标红）</div>
                                                    <div class="health-timeline-line">
                                                        @foreach (var segment in site.TimelineSegments)
                                                        {
                                                            <div class="health-timeline-segment" style="@BuildTimelineSegmentStyle(segment)" title="@GetTimelineSegmentTitle(segment)"></div>
                                                        }
                                                    </div>
                                                    <div class="health-timeline-range">
                                                        <span>@site.TimelineSegments.First().StartAt.ToString("MM-dd")</span>
                                                        <span>@site.TimelineSegments.Last().EndAt.ToString("MM-dd")</span>
                                                    </div>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="text-secondary" style="font-size: 12.5px; padding: 8px 0;">暂无请求记录</div>
                                            }
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="table-wrapper">
                                        <div class="table-empty">
                                            <div class="table-empty-icon">📭</div>
                                            <div class="table-empty-text">该模型暂无站点映射数据</div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@functions {
    /// <summary>
    /// 折叠态概览中的单个时间槽位。
    /// </summary>
    private sealed class OverviewStatusSlot
    {
        public string Status { get; set; } = string.Empty;
        public string Title { get; set; } = string.Empty;
    }

    private static string FormatDuration(int durationMs)
    {
        if (durationMs >= 60000)
        {
            var minutes = durationMs / 60000;
            var seconds = (durationMs % 60000) / 1000;
            return $"{minutes}分 {seconds}秒";
        }

        if (durationMs >= 1000)
        {
            return $"{durationMs / 1000.0:F1}秒";
        }

        return $"{durationMs}ms";
    }

    /// <summary>
    /// 把概览时间线压缩成最多 12 个时间槽位，保持时间顺序不变。
    /// </summary>
    private static List<OverviewStatusSlot> BuildOverviewStatusSlots(List<ModelHealthTimelineSegment> segments)
    {
        const int maxSlotCount = 12;
        if (segments.Count == 0)
        {
            return [];
        }

        var orderedSegments = segments
            .OrderBy(x => x.StartAt)
            .ToList();
        if (orderedSegments.Count <= maxSlotCount)
        {
            return orderedSegments
                .Select(segment => new OverviewStatusSlot
                {
                    Status = ResolveOverviewSlotStatus(segment.FailureCount, segment.Count),
                    Title = GetTimelineSegmentTitle(segment)
                })
                .ToList();
        }

        var slots = new List<OverviewStatusSlot>(maxSlotCount);
        var groupSize = (int)Math.Ceiling(orderedSegments.Count / (double)maxSlotCount);

        // 超过展示上限时，把相邻时间段合并到同一个槽位里，继续保持先后顺序。
        for (var i = 0; i < orderedSegments.Count; i += groupSize)
        {
            var groupedSegments = orderedSegments
                .Skip(i)
                .Take(groupSize)
                .ToList();
            var successCount = groupedSegments.Sum(x => x.SuccessCount);
            var failureCount = groupedSegments.Sum(x => x.FailureCount);
            var totalCount = groupedSegments.Sum(x => x.Count);
            slots.Add(new OverviewStatusSlot
            {
                Status = ResolveOverviewSlotStatus(failureCount, totalCount),
                Title = $"{groupedSegments.First().StartAt:MM-dd HH:mm} ~ {groupedSegments.Last().EndAt:MM-dd HH:mm} | 总请求 {totalCount} 次 | 成功 {successCount} 次 | 失败 {failureCount} 次"
            });
        }

        return slots;
    }

    /// <summary>
    /// 概览槽位只区分成功或失败，有失败就标红。
    /// </summary>
    private static string ResolveOverviewSlotStatus(int failureCount, int totalCount)
    {
        return totalCount > 0 && failureCount > 0 ? "fail" : "success";
    }

    /// <summary>
    /// 按模型整体成功率生成固定 12 条的概览竖条，避免失败分散时被放大成整排红条。
    /// </summary>
    private static List<OverviewStatusSlot> BuildOverviewRateSlots(int successCount, int failureCount)
    {
        const int slotCount = 12;
        var totalCount = successCount + failureCount;
        if (totalCount <= 0)
        {
            return Enumerable.Range(0, slotCount)
                .Select(_ => new OverviewStatusSlot
                {
                    Status = "empty",
                    Title = "暂无请求记录"
                })
                .ToList();
        }

        var successSlotCount = (int)Math.Floor(successCount * slotCount / (double)totalCount);
        if (successCount > 0)
        {
            successSlotCount = Math.Max(successSlotCount, 1);
        }

        if (failureCount > 0)
        {
            successSlotCount = Math.Min(successSlotCount, slotCount - 1);
        }

        successSlotCount = Math.Clamp(successSlotCount, 0, slotCount);
        var failureSlotCount = slotCount - successSlotCount;
        var successRateText = (successCount * 100d / totalCount).ToString("F1");
        var failureRateText = (failureCount * 100d / totalCount).ToString("F1");
        var slots = new List<OverviewStatusSlot>(slotCount);

        for (var i = 0; i < successSlotCount; i++)
        {
            slots.Add(new OverviewStatusSlot
            {
                Status = "success",
                Title = $"成功率 {successRateText}% | 成功 {successCount} 次 | 失败 {failureCount} 次"
            });
        }

        for (var i = 0; i < failureSlotCount; i++)
        {
            slots.Add(new OverviewStatusSlot
            {
                Status = "fail",
                Title = $"失败率 {failureRateText}% | 成功 {successCount} 次 | 失败 {failureCount} 次"
            });
        }

        return slots;
    }

    /// <summary>
    /// 按单个时间块内的成功/失败占比渲染颜色，避免少量失败把整块放大成全红。
    /// </summary>
    private static string BuildTimelineSegmentStyle(ModelHealthTimelineSegment segment)
    {
        if (segment.Count <= 0)
        {
            return "background: #e2e8f0;";
        }

        var successRate = Math.Clamp(segment.SuccessCount * 100d / segment.Count, 0d, 100d);
        if (successRate <= 0)
        {
            return "background: var(--danger);";
        }

        if (successRate >= 100)
        {
            return "background: var(--success);";
        }

        var successRateText = successRate.ToString("0.##", global::System.Globalization.CultureInfo.InvariantCulture);
        return $"background: linear-gradient(to right, var(--success) 0 {successRateText}%, var(--danger) {successRateText}% 100%);";
    }

    private static string GetTimelineTitle(string range, int totalCount, int successCount, int failureCount)
    {
        var prefix = (range ?? "7d") switch
        {
            "1d" => "最近 24 小时",
            "30d" => "最近 30 天",
            _ => "最近 7 天"
        };

        return $"{prefix}共 {totalCount} 次请求（成功 {successCount} 次，失败 {failureCount} 次）";
    }

    private static string GetTimelineSegmentTitle(ModelHealthTimelineSegment segment)
    {
        var timeRange = $"{segment.StartAt:MM-dd HH:mm} ~ {segment.EndAt:MM-dd HH:mm}";
        return $"{timeRange} | 总请求 {segment.Count} 次 | 成功 {segment.SuccessCount} 次 | 失败 {segment.FailureCount} 次";
    }
}

<script>
    var availableModelOptions = [];

    // 为原生下拉框补一个前端搜索层，避免模型太多时很难定位目标项。
    function initializeAvailableModelOptions() {
        var select = document.getElementById('availableModelSelect');
        if (!select) {
            return;
        }

        availableModelOptions = Array.from(select.options)
            .filter(function(option) {
                return option.value !== '';
            })
            .map(function(option) {
                return {
                    value: option.value,
                    text: option.text
                };
            });
    }

    function filterAvailableModels() {
        var select = document.getElementById('availableModelSelect');
        var searchInput = document.getElementById('availableModelSearch');
        var emptyState = document.getElementById('availableModelSearchEmpty');
        if (!select || !searchInput) {
            return;
        }

        if (availableModelOptions.length === 0) {
            initializeAvailableModelOptions();
        }

        var keyword = searchInput.value.toLowerCase().trim();
        var selectedValue = select.value;
        var matchedOptions = availableModelOptions.filter(function(option) {
            return keyword === '' || option.text.toLowerCase().indexOf(keyword) >= 0;
        });

        select.innerHTML = '';
        select.add(new Option('-- 请选择模型 --', ''));
        matchedOptions.forEach(function(option) {
            select.add(new Option(option.text, option.value));
        });

        var hasSelectedValue = matchedOptions.some(function(option) {
            return option.value === selectedValue;
        });
        select.value = hasSelectedValue ? selectedValue : '';

        if (emptyState) {
            emptyState.style.display = matchedOptions.length === 0 ? '' : 'none';
        }
    }

    /* 按模型名搜索过滤健康看板 */
    function filterHealthModels() {
        var searchInput = document.getElementById('healthSearch');
        if (!searchInput) {
            return;
        }

        var keyword = searchInput.value.toLowerCase();
        document.querySelectorAll('.health-model-group').forEach(function(g) {
            var name = g.getAttribute('data-display-name').toLowerCase();
            var visible = name.indexOf(keyword) >= 0;
            g.style.display = visible ? '' : 'none';

            var detailId = g.getAttribute('data-detail-id');
            if (!detailId) {
                return;
            }

            var detailRow = document.getElementById(detailId);
            if (!detailRow) {
                return;
            }

            if (!visible) {
                detailRow.style.display = 'none';
            }
        });
    }

    /* 切换模型明细展开状态 */
    function toggleHealthDetail(detailId, button) {
        var panel = document.getElementById(detailId);
        if (!panel) {
            return;
        }

        var isHidden = panel.style.display === 'none';
        panel.style.display = isHidden ? '' : 'none';
        if (button) {
            button.textContent = isHidden ? '收起明细' : '查看明细';
        }
    }

    initializeAvailableModelOptions();
</script>
