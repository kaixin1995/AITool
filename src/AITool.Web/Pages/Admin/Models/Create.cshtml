@page
@model AITool.Web.Pages.Admin.Models.CreateModelModel
@{
    ViewData["Title"] = "新增模型";
}

<h1>新增模型</h1>

<form method="post" class="mb-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Command.ModelName" class="form-label">模型名</label>
        <input asp-for="Command.ModelName" class="form-control" placeholder="gpt-5.4" required />
    </div>

    <div class="mb-3">
        <label asp-for="Command.DisplayName" class="form-label">显示名</label>
        <input asp-for="Command.DisplayName" class="form-control" placeholder="GPT 5.4" required />
    </div>

    <div class="mb-3">
        <label asp-for="Command.ModelType" class="form-label">模型类型</label>
        <select asp-for="Command.ModelType" class="form-select">
            <option value="chat">Chat</option>
            <option value="embedding">Embedding</option>
        </select>
    </div>

    <div class="mb-3 form-check">
        <input asp-for="Command.IsEnabled" class="form-check-input" type="checkbox" checked />
        <label asp-for="Command.IsEnabled" class="form-check-label">启用</label>
    </div>

    <button type="submit" class="btn btn-primary">保存</button>
    <a asp-page="./Index" class="btn btn-secondary">取消</a>
</form>
