@page
@model AITool.Web.Pages.Admin.Models.IndexModel
@{
    ViewData["Title"] = "模型库管理";
    var totalModelCount = Model.VendorGroups.Sum(x => x.Models.Count);
    var modelsTabActive = !string.Equals(Model.ActiveTab, "rules", StringComparison.OrdinalIgnoreCase);
    // 兼容完整 svg 或内部 body 两种输入格式；若原始 svg 自带 viewBox，则以内层 svg 保留它的坐标系。
    string BuildVendorIcon(string iconSvgBody)
    {
        if (string.IsNullOrWhiteSpace(iconSvgBody))
        {
            return string.Empty;
        }

        var svgBody = ExtractSvgBody(iconSvgBody);

        // 统一替换外部 SVG 内的渐变引用，避免维护的 path 使用旧 id 时图标丢失。
        var normalizedSvgBody = svgBody
            .Replace("url(#lobe-icons-qwen-fill)", "url(#vendor-gradient-alibaba)", StringComparison.Ordinal)
            .Replace("id=\"lobe-icons-qwen-fill\"", "id=\"vendor-gradient-alibaba\"", StringComparison.Ordinal);

        return $"<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><defs><linearGradient id=\"vendor-gradient-alibaba\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"100%\"><stop offset=\"0%\" stop-color=\"#FF8A00\" /><stop offset=\"100%\" stop-color=\"#FF5F00\" /></linearGradient></defs>{normalizedSvgBody}</svg>";
    }

    string ExtractSvgBody(string iconSvgBody)
    {
        var normalized = iconSvgBody?.Trim() ?? string.Empty;
        if (string.IsNullOrWhiteSpace(normalized))
        {
            return string.Empty;
        }

        var svgMatch = global::System.Text.RegularExpressions.Regex.Match(normalized, "^<svg\\b(?<attrs>[^>]*)>(?<body>[\\s\\S]*)</svg>$", global::System.Text.RegularExpressions.RegexOptions.IgnoreCase | global::System.Text.RegularExpressions.RegexOptions.CultureInvariant);
        if (!svgMatch.Success)
        {
            return normalized;
        }

        var body = svgMatch.Groups["body"].Value.Trim();
        var attrs = svgMatch.Groups["attrs"].Value;
        var viewBoxMatch = global::System.Text.RegularExpressions.Regex.Match(attrs, "\\bviewBox\\s*=\\s*(['\"])(?<viewBox>.*?)\\1", global::System.Text.RegularExpressions.RegexOptions.IgnoreCase | global::System.Text.RegularExpressions.RegexOptions.CultureInvariant);
        if (!viewBoxMatch.Success)
        {
            return body;
        }

        var viewBox = viewBoxMatch.Groups["viewBox"].Value.Trim();
        return string.IsNullOrWhiteSpace(viewBox)
            ? body
            : $"<svg viewBox=\"{viewBox}\">{body}</svg>";
    }
}

<div class="page-header">
    <div>
        <h2 class="page-title">模型库管理</h2>
        <p class="page-subtitle">支持按厂商分组浏览模型，并维护模型与厂商的匹配规则</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-page="./Create" class="btn btn-primary">＋ 新增模型</a>
        <button type="button" id="btnClearAll" class="btn btn-outline-danger" onclick="clearAllModels()">清空模型</button>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert @(Model.StatusSuccess ? "alert-success" : "alert-danger")">
        @Model.StatusMessage
    </div>
}

<div id="statusAlert" style="display:none;" class="alert">
    <span id="statusText"></span>
</div>

<div class="card models-tab-card">
    <div class="card-header p-0">
        <ul class="nav nav-tabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link @(modelsTabActive ? "active" : null)" data-bs-toggle="tab" data-bs-target="#tabModelGallery" type="button" role="tab">模型分组</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(!modelsTabActive ? "active" : null)" data-bs-toggle="tab" data-bs-target="#tabVendorRules" type="button" role="tab">厂商规则</button>
            </li>
        </ul>
    </div>
    <div class="card-body">
        <div class="tab-content">
            <div class="tab-pane fade @(modelsTabActive ? "show active" : null)" id="tabModelGallery" role="tabpanel">
                <div class="model-toolbar">
                    <div class="model-search-box">
                        <input id="modelSearchInput" type="text" class="form-control" placeholder="搜索模型名称或显示名" oninput="filterModels()" />
                    </div>
                    <div class="model-toolbar-summary">
                        共 <strong id="visibleModelCount">@totalModelCount</strong> / <span id="totalModelCount">@totalModelCount</span> 个模型
                    </div>
                </div>

                @if (!Model.VendorGroups.Any())
                {
                    <div class="table-empty model-empty-state">
                        <div class="table-empty-text">暂无模型，点击上方按钮新增</div>
                    </div>
                }
                else
                {
                    <div id="vendorGroupsContainer" class="vendor-groups">
                        @foreach (var group in Model.VendorGroups)
                        {
                            var iconSvg = BuildVendorIcon(group.IconSvgBody);
                            <section class="vendor-group" data-vendor-name="@group.VendorName">
                                <div class="vendor-group-header" style="background:@group.HeaderBackground;">
                                    <div class="vendor-group-title-wrap">
                                        <div class="vendor-group-icon @(string.IsNullOrWhiteSpace(group.IconSvgBody) ? "vendor-group-icon-fallback" : null)">
                                            @if (!string.IsNullOrWhiteSpace(iconSvg))
                                            {
                                                @Html.Raw(iconSvg)
                                            }
                                            else
                                            {
                                                <span>@group.VendorName[..1]</span>
                                            }
                                        </div>
                                        <div>
                                            <h3 class="vendor-group-title">@group.VendorName</h3>
                                            <div class="vendor-group-subtitle" data-group-subtitle>当前分组下共 @group.Models.Count 个模型</div>
                                        </div>
                                    </div>
                                    <span class="badge bg-white text-dark vendor-group-count" data-group-count>@group.Models.Count</span>
                                </div>

                                <div class="vendor-model-grid">
                                    @foreach (var item in group.Models)
                                    {
                                        var searchText = $"{item.ModelName} {item.DisplayName} {group.VendorName}".ToLowerInvariant();
                                        <article class="model-card" data-model-id="@item.Id" data-model-search="@searchText">
                                            <div class="model-card-top">
                                                <div>
                                                    <div class="model-card-name">@item.ModelName</div>
                                                    <div class="model-card-display">@item.DisplayName</div>
                                                </div>
                                                <span class="badge bg-@(item.IsEnabled ? "success" : "secondary")">
                                                    @(item.IsEnabled ? "启用" : "禁用")
                                                </span>
                                            </div>

                                            <div class="model-card-meta">
                                                <span class="badge bg-info">关联站点 @item.SiteCount</span>
                                                <span class="model-card-created">创建于 @item.CreatedAt.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</span>
                                            </div>

                                            <div class="model-card-actions">
                                                <form method="post" asp-page-handler="Toggle" asp-route-modelId="@item.Id" class="d-inline">
                                                    <button type="submit" class="btn btn-sm btn-outline-@(item.IsEnabled ? "warning" : "success")">
                                                        @(item.IsEnabled ? "禁用" : "启用")
                                                    </button>
                                                </form>
                                                <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">编辑</a>
                                                <form method="post" asp-page-handler="Delete" asp-route-modelId="@item.Id" class="d-inline model-delete-form">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger">删除</button>
                                                </form>
                                            </div>
                                        </article>
                                    }
                                </div>
                            </section>
                        }
                    </div>

                    <div id="searchEmptyState" class="table-empty model-empty-state" style="display:none;">
                        <div class="table-empty-text">没有匹配的模型</div>
                    </div>
                }
            </div>

            <div class="tab-pane fade @(!modelsTabActive ? "show active" : null)" id="tabVendorRules" role="tabpanel">
                <form method="post" asp-page-handler="SaveVendorCatalog" onsubmit="return beforeSubmitVendorCatalog()">
                    <input type="hidden" asp-for="VendorCatalogJson" id="vendorCatalogJsonInput" />
                    <input type="hidden" asp-for="ActiveTab" value="rules" />

                    <div class="vendor-editor-toolbar">
                        <div class="text-muted small">默认仅展示厂商名称和模型规则摘要，点击“编辑”后再维护标题样式、SVG 图标和匹配规则。支持精确匹配、通配符匹配（如 <code>gpt*</code>）、正则匹配。单条规则可用逗号分隔多个表达式，例如 <code>doubao*,skylark*</code>。当前配置以软件运行目录下的 <code>model-vendor-catalog.json</code> 为准；如果该文件不存在，才会用源码目录中的同名文件做首次生成模板。</div>
                        <div class="d-flex gap-2 flex-wrap align-items-center">
                            <input type="text" id="vendorRuleSearchInput" class="form-control form-control-sm vendor-rule-search-box" placeholder="搜索厂商名或规则，如 Gemini / qwen*" />
                            <button type="button" class="btn btn-outline-secondary btn-sm" onclick="restoreDefaultVendorCatalog()">恢复当前文件内容</button>
                            <button type="button" class="btn btn-outline-primary btn-sm" onclick="addVendorRow()">新增厂商</button>
                            <button type="submit" class="btn btn-primary btn-sm">保存厂商规则</button>
                        </div>
                    </div>

                    <div class="vendor-editor-section">
                        <div id="vendorDefinitionList" class="vendor-definition-list"></div>
                        <div id="vendorSearchEmptyState" class="vendor-rule-empty mt-3" style="display:none;">没有匹配的厂商规则</div>
                    </div>
                </form>

                <div class="modal fade" id="vendorEditorModal" tabindex="-1">
                    <div class="modal-dialog modal-xl modal-dialog-scrollable">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title" id="vendorEditorModalTitle">编辑厂商</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                <div id="vendorEditorModalBody"></div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">关闭</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .models-tab-card .nav-tabs {
        padding: 0 12px;
    }

    .model-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 20px;
        padding: 16px 18px;
        border: 1px solid var(--border-color, #e9ecef);
        border-radius: 16px;
        background: var(--card-bg, #fff);
    }

    .model-search-box {
        flex: 1;
        max-width: 520px;
    }

    .model-toolbar-summary {
        color: var(--text-secondary, #6c757d);
        white-space: nowrap;
    }

    .vendor-groups {
        display: flex;
        flex-direction: column;
        gap: 22px;
    }

    .vendor-group {
        border: 1px solid var(--border-color, #e9ecef);
        border-radius: 18px;
        overflow: hidden;
        background: var(--card-bg, #fff);
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.04);
    }

    .vendor-group-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 18px 22px;
        color: #1f2937;
        border-bottom: 1px solid rgba(15, 23, 42, 0.06);
    }

    .vendor-group-title-wrap {
        display: flex;
        align-items: center;
        gap: 14px;
        min-width: 0;
    }

    .vendor-group-icon {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        background: rgba(255,255,255,.7);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        border: 1px solid rgba(15, 23, 42, 0.06);
    }

    .vendor-group-icon svg {
        width: 24px;
        height: 24px;
        color: #111827;
    }

    .vendor-group-icon-fallback span {
        font-weight: 700;
        color: #111827;
    }

    .vendor-group-title {
        margin: 0;
        font-size: 26px;
        font-weight: 700;
    }

    .vendor-group-subtitle {
        margin-top: 4px;
        font-size: 13px;
        color: #475569;
    }

    .vendor-model-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 18px;
        padding: 20px;
    }

    .model-card {
        border: 1px solid var(--border-color, #e9ecef);
        border-radius: 16px;
        padding: 18px;
        background: var(--card-bg, #fff);
        display: flex;
        flex-direction: column;
        gap: 14px;
        min-height: 176px;
    }

    .model-card.model-card-deleting {
        opacity: 0.6;
        pointer-events: none;
    }

    .model-card-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
    }

    .model-card-name {
        font-size: 16px;
        font-weight: 700;
        line-height: 1.4;
        word-break: break-word;
    }

    .model-card-display {
        margin-top: 4px;
        color: var(--text-secondary, #6c757d);
        font-size: 13px;
        word-break: break-word;
    }

    .model-card-meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
    }

    .model-card-created {
        color: var(--text-secondary, #6c757d);
        font-size: 12px;
    }

    .model-card-actions {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
        margin-top: auto;
    }

    .model-empty-state {
        padding: 36px 20px;
        border: 1px dashed var(--border-color, #dee2e6);
        border-radius: 16px;
        background: var(--card-bg, #fff);
    }

    .vendor-editor-toolbar,
    .vendor-editor-section-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
    }

    .vendor-editor-toolbar {
        margin-bottom: 16px;
    }

    .vendor-rule-search-box {
        width: 320px;
        max-width: 100%;
    }

    .vendor-editor-section {
        border: 1px solid var(--border-color, #e9ecef);
        border-radius: 16px;
        padding: 18px;
        background: var(--card-bg, #fff);
    }

    .vendor-definition-list {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .vendor-summary-card,
    .vendor-definition-card {
        border: 1px solid var(--border-color, #e9ecef);
        border-radius: 16px;
        padding: 16px;
        background: #fff;
    }

    .vendor-summary-card {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .vendor-summary-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
    }

    .vendor-summary-name {
        font-size: 16px;
        font-weight: 700;
        word-break: break-word;
    }

    .vendor-summary-meta {
        color: var(--text-secondary, #6c757d);
        font-size: 12px;
    }

    .vendor-summary-rules {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .vendor-summary-rule-item {
        display: flex;
        align-items: center;
        gap: 8px;
        min-width: 0;
    }

    .vendor-summary-rule-pattern {
        min-width: 0;
        color: #334155;
        word-break: break-word;
    }

    .vendor-definition-grid {
        display: grid;
        grid-template-columns: 1.2fr 180px 120px;
