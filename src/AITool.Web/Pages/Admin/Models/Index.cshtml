        border-top: 1px dashed rgba(15, 23, 42, 0.12);
        padding-top: 16px;
    }

    .vendor-rule-row {
        display: grid;
        grid-template-columns: 100px 150px minmax(0, 1fr) 76px;
        gap: 10px;
        align-items: start;
        margin-top: 10px;
    }

    .vendor-rule-empty {
        margin-top: 10px;
        padding: 12px 14px;
        border: 1px dashed rgba(15, 23, 42, 0.12);
        border-radius: 12px;
        color: #64748b;
        font-size: 13px;
    }

    .vendor-preview-card {
        margin-top: 14px;
        border: 1px dashed rgba(15, 23, 42, 0.12);
        border-radius: 14px;
        padding: 14px;
    }

    .vendor-preview-header {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 14px;
        border-radius: 12px;
    }

    .vendor-preview-icon {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        background: rgba(255,255,255,.75);
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid rgba(15, 23, 42, 0.06);
    }

    .vendor-preview-icon svg {
        width: 22px;
        height: 22px;
        color: #111827;
    }

    .vendor-preview-fallback {
        font-weight: 700;
    }

    .vendor-svg-textarea {
        min-height: 108px;
        font-family: Consolas, monospace;
        font-size: 12px;
    }

    .vendor-rule-table td,
    .vendor-rule-table th {
        vertical-align: middle;
    }

    @@media (max-width: 992px) {
        .vendor-definition-grid,
        .vendor-rule-row {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 768px) {
        .model-toolbar {
            flex-direction: column;
            align-items: stretch;
        }

        .model-search-box {
            max-width: none;
        }

        .vendor-group-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .vendor-group-title {
            font-size: 22px;
        }
    }
</style>

<script>
    var defaultVendorCatalog = @Html.Raw(Model.VendorCatalogEditorJson);
    var vendorCatalogState = JSON.parse(JSON.stringify(defaultVendorCatalog));
    var vendorEditorModal = null;
    var currentVendorEditIndex = -1;

    document.addEventListener('DOMContentLoaded', function () {
        var vendorEditorModalElement = document.getElementById('vendorEditorModal');
        if (vendorEditorModalElement && window.bootstrap) {
            vendorEditorModal = new bootstrap.Modal(vendorEditorModalElement);
            // 关闭模态框后清空当前编辑目标，避免下次渲染串到旧数据。
            vendorEditorModalElement.addEventListener('hidden.bs.modal', function () {
                currentVendorEditIndex = -1;
                renderVendorEditorModal();
            });
        }

        var vendorRuleSearchInput = document.getElementById('vendorRuleSearchInput');
        if (vendorRuleSearchInput) {
            // 厂商规则搜索只做前端过滤，避免为了查找频繁回发保存表单。
            vendorRuleSearchInput.addEventListener('input', function () {
                renderVendorEditor();
            });
        }

        document.querySelectorAll('.model-delete-form').forEach(function (form) {
            form.addEventListener('submit', deleteModelInline);
        });

        syncVendorCatalogJson();
        renderVendorEditor();
    });

    function showMsg(msg, success) {
        var alert = document.getElementById('statusAlert');
        var text = document.getElementById('statusText');
        alert.style.display = '';
        alert.className = 'alert ' + (success ? 'alert-success' : 'alert-danger');
        text.textContent = msg;
    }

    async function deleteModelInline(event) {
        event.preventDefault();
        if (!confirm('确认删除该模型？')) {
            return;
        }

        var form = event.currentTarget;
        var card = form.closest('.model-card');
        var button = form.querySelector('button[type="submit"]');
        if (!card || !button) {
            form.submit();
            return;
        }

        card.classList.add('model-card-deleting');
        button.disabled = true;
        button.textContent = '删除中...';

        try {
            var response = await fetch(form.action, {
                method: 'POST',
                body: new FormData(form),
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            });
            var data = await response.json();
            if (!response.ok || data.success === false) {
                throw new Error(data.message || '删除失败，请稍后重试');
            }

            removeModelCard(card);
            showMsg(data.message || '模型已删除', true);
        } catch (err) {
            card.classList.remove('model-card-deleting');
            button.disabled = false;
            button.textContent = '删除';
            showMsg('删除失败：' + err.message, false);
        }
    }

    function removeModelCard(card) {
        var group = card.closest('.vendor-group');
        card.remove();
        if (group && group.querySelectorAll('.model-card').length === 0) {
            group.remove();
        }

        decrementTotalModelCount();
        filterModels();
    }

    function decrementTotalModelCount() {
        var totalModelCountElement = document.getElementById('totalModelCount');
        if (!totalModelCountElement) {
            return;
        }

        var total = Math.max((parseInt(totalModelCountElement.textContent, 10) || 0) - 1, 0);
        totalModelCountElement.textContent = total;
    }

    function clearAllModels() {
        if (!confirm('确认清空所有模型？此操作将同时删除所有站点映射、检测日志和健康监控数据，不可恢复！')) return;
        var btn = document.getElementById('btnClearAll');
        btn.disabled = true;
        btn.textContent = '清空中...';

        fetch('/api/admin/models/clear-all', { method: 'POST' })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                btn.disabled = false;
                btn.textContent = '清空模型';
                if (data.message) { showMsg(data.message, false); return; }
                showMsg('已清空 ' + data.deletedModels + ' 个模型、' + data.deletedMappings + ' 条映射、' + data.deletedLogs + ' 条检测日志、' + data.deletedMonitors + ' 条监控', true);
                window.location.reload();
            })
            .catch(function(err) {
                btn.disabled = false;
                btn.textContent = '清空模型';
                showMsg('清空失败：' + err.message, false);
            });
    }

    // 按模型名、显示名和厂商分组做前端过滤，避免频繁回发。
    function filterModels() {
        var keyword = (document.getElementById('modelSearchInput')?.value || '').trim().toLowerCase();
        var visibleModelCount = 0;

        document.querySelectorAll('.vendor-group').forEach(function(group) {
            var groupVisibleCount = 0;
            group.querySelectorAll('.model-card').forEach(function(card) {
                var searchText = card.getAttribute('data-model-search') || '';
                var matched = keyword === '' || searchText.indexOf(keyword) >= 0;
                card.style.display = matched ? '' : 'none';
                if (matched) {
                    visibleModelCount++;
                    groupVisibleCount++;
                }
            });

            group.style.display = groupVisibleCount > 0 ? '' : 'none';
            var countBadge = group.querySelector('[data-group-count]');
            if (countBadge) {
                countBadge.textContent = groupVisibleCount;
            }
            var subtitle = group.querySelector('[data-group-subtitle]');
            if (subtitle) {
                subtitle.textContent = '当前分组下共 ' + group.querySelectorAll('.model-card').length + ' 个模型';
            }
        });

        var visibleModelCountElement = document.getElementById('visibleModelCount');
        if (visibleModelCountElement) {
            visibleModelCountElement.textContent = visibleModelCount;
        }

        var emptyState = document.getElementById('searchEmptyState');
        if (emptyState) {
            emptyState.style.display = visibleModelCount === 0 ? '' : 'none';
        }
    }

    function ensureVendorCatalogShape() {
        if (!vendorCatalogState || typeof vendorCatalogState !== 'object') {
            vendorCatalogState = { Vendors: [], Rules: [] };
        }

        if (!Array.isArray(vendorCatalogState.Vendors)) {
            vendorCatalogState.Vendors = [];
        }

        if (!Array.isArray(vendorCatalogState.Rules)) {
            vendorCatalogState.Rules = [];
        }
    }

    function syncVendorCatalogJson() {
        ensureVendorCatalogShape();
        var input = document.getElementById('vendorCatalogJsonInput');
        if (input) {
            input.value = JSON.stringify(vendorCatalogState);
        }
    }

    function beforeSubmitVendorCatalog() {
        syncVendorCatalogJson();
        return true;
    }

    function restoreDefaultVendorCatalog() {
        if (!confirm('确认恢复为当前文件内容吗？未保存修改将丢失。')) {
            return;
        }

        vendorCatalogState = JSON.parse(JSON.stringify(defaultVendorCatalog));
        renderVendorEditor();
        syncVendorCatalogJson();
    }

    function addVendorRow() {
        ensureVendorCatalogShape();
        vendorCatalogState.Vendors.push({
            VendorName: '',
            IconSvgBody: '',
            HeaderBackground: '#f8fafc',
            SortOrder: vendorCatalogState.Vendors.length * 10
        });
        currentVendorEditIndex = vendorCatalogState.Vendors.length - 1;
        renderVendorEditor();
        syncVendorCatalogJson();
        openVendorEditor(currentVendorEditIndex);
    }

    function removeVendorRow(index) {
        ensureVendorCatalogShape();
        var vendorName = vendorCatalogState.Vendors[index] ? (vendorCatalogState.Vendors[index].VendorName || '') : '';
        vendorCatalogState.Vendors.splice(index, 1);
        if (vendorName !== '') {
            vendorCatalogState.Rules = vendorCatalogState.Rules.filter(function (rule) {
                return (rule.VendorName || '') !== vendorName;
            });
        }

        if (currentVendorEditIndex === index) {
            currentVendorEditIndex = -1;
            if (vendorEditorModal) {
                vendorEditorModal.hide();
            }
        } else if (currentVendorEditIndex > index) {
            currentVendorEditIndex -= 1;
        }

        renderVendorEditor();
        syncVendorCatalogJson();
    }

    function updateVendorField(index, field, value) {
        if (field === 'SortOrder') {
            vendorCatalogState.Vendors[index][field] = parseInt(value || '0', 10) || 0;
        } else if (field === 'IconSvgBody') {
            // 兼容直接粘贴完整 svg 标签，前端预览和最终保存统一使用内部 body。
            vendorCatalogState.Vendors[index][field] = extractSvgBody(value);
        } else {
            vendorCatalogState.Vendors[index][field] = value;
        }

        syncVendorCatalogJson();
    }

    // 厂商名变更时同步改写其名下规则，避免配置被拆散。
    function updateVendorName(index, value) {
        ensureVendorCatalogShape();
        var oldName = vendorCatalogState.Vendors[index] ? (vendorCatalogState.Vendors[index].VendorName || '') : '';
        vendorCatalogState.Vendors[index].VendorName = value;
        vendorCatalogState.Rules.forEach(function (rule) {
            if ((rule.VendorName || '') === oldName) {
                rule.VendorName = value;
            }
        });
        syncVendorCatalogJson();
    }

    function addRuleForVendor(index) {
        ensureVendorCatalogShape();
        vendorCatalogState.Rules.push({
            VendorName: vendorCatalogState.Vendors[index] ? (vendorCatalogState.Vendors[index].VendorName || '') : '',
            MatchType: 'wildcard',
            Pattern: '',
            Priority: (vendorCatalogState.Rules.length + 1) * 10
        });
        renderVendorEditor();
        syncVendorCatalogJson();
    }

    function removeRuleByIndex(ruleIndex) {
        vendorCatalogState.Rules.splice(ruleIndex, 1);
        renderVendorEditor();
        syncVendorCatalogJson();
    }

    function updateRuleField(index, field, value) {
        vendorCatalogState.Rules[index][field] = field === 'Priority' ? parseInt(value || '0', 10) || 0 : value;
        syncVendorCatalogJson();
    }

    function getRulesForVendor(vendorName) {
        var results = [];
        vendorCatalogState.Rules.forEach(function (rule, ruleIndex) {
            if ((rule.VendorName || '') === (vendorName || '')) {
                results.push({ rule: rule, ruleIndex: ruleIndex });
            }
        });
        return results;
    }

    function renderVendorRules(vendorName) {
        var rules = getRulesForVendor(vendorName);
        if (rules.length === 0) {
            return '<div class="vendor-rule-empty">当前厂商还没有匹配规则，点击右上角“新增规则”即可直接补充。</div>';
        }

        return rules.map(function (entry) {
            var rule = entry.rule;
            return '' +
                '<div class="vendor-rule-row" data-rule-index="' + entry.ruleIndex + '">' +
                    '<div>' +
                        '<label class="form-label">优先级</label>' +
                        '<input type="number" class="form-control form-control-sm rule-priority-input" value="' + escapeHtml(String(rule.Priority ?? 0)) + '" />' +
                    '</div>' +
                    '<div>' +
                        '<label class="form-label">匹配方式</label>' +
                        '<select class="form-select form-select-sm rule-match-type-input">' +
                            '<option value="exact" ' + (rule.MatchType === 'exact' ? 'selected' : '') + '>精确</option>' +
                            '<option value="wildcard" ' + ((rule.MatchType || 'wildcard') === 'wildcard' ? 'selected' : '') + '>通配符 *</option>' +
                            '<option value="regex" ' + (rule.MatchType === 'regex' ? 'selected' : '') + '>正则</option>' +
                        '</select>' +
                    '</div>' +
                    '<div>' +
                        '<label class="form-label">匹配表达式</label>' +
                        '<input type="text" class="form-control form-control-sm rule-pattern-input" value="' + escapeHtml(rule.Pattern || '') + '" placeholder="如 doubao*,skylark* 或 ^claude-3.*$,^claude-4.*$" />' +
                    '</div>' +
                    '<div class="pt-4 text-end">' +
                        '<button type="button" class="btn btn-sm btn-outline-danger rule-delete-btn">删除</button>' +
                    '</div>' +
                '</div>';
        }).join('');
    }

    function getMatchTypeLabel(matchType) {
        switch ((matchType || 'wildcard').toLowerCase()) {
            case 'exact':
                return '精确';
            case 'regex':
                return '正则';
            default:
                return '通配符';
        }
    }

    function renderVendorRuleSummary(vendorName) {
        var rules = getRulesForVendor(vendorName);
        if (rules.length === 0) {
            return '<div class="vendor-rule-empty mt-0">当前还没有配置匹配规则。</div>';
        }

        return rules.map(function (entry) {
            var rule = entry.rule;
            return '' +
                '<div class="vendor-summary-rule-item">' +
                    '<span class="badge text-bg-light border">' + escapeHtml(getMatchTypeLabel(rule.MatchType)) + '</span>' +
                    '<span class="vendor-summary-rule-pattern">' + escapeHtml(rule.Pattern || '') + '</span>' +
                '</div>';
        }).join('');
    }

    // 详情编辑仍沿用原有字段和规则逻辑，只是入口改成模态框。
    function openVendorEditor(index) {
        ensureVendorCatalogShape();
        if (index < 0 || index >= vendorCatalogState.Vendors.length) {
            return;
        }

        currentVendorEditIndex = index;
        renderVendorEditorModal();
        if (vendorEditorModal) {
            vendorEditorModal.show();
        }
    }

    function renderVendorEditorModal() {
        var modalTitle = document.getElementById('vendorEditorModalTitle');
        var modalBody = document.getElementById('vendorEditorModalBody');
        if (!modalTitle || !modalBody) {
            return;
        }

        ensureVendorCatalogShape();
        if (currentVendorEditIndex < 0 || currentVendorEditIndex >= vendorCatalogState.Vendors.length) {
            modalTitle.textContent = '编辑厂商';
            modalBody.innerHTML = '';
            return;
        }

        var vendor = vendorCatalogState.Vendors[currentVendorEditIndex];
        modalTitle.textContent = '编辑厂商 - ' + (vendor.VendorName || '未命名厂商');
        modalBody.innerHTML = '' +
            '<div class="vendor-definition-card">' +
                '<div class="d-flex justify-content-between align-items-center gap-2 flex-wrap mb-3">' +
                    '<strong>详细配置</strong>' +
                    '<button type="button" class="btn btn-sm btn-outline-danger vendor-delete-btn">删除厂商</button>' +
                '</div>' +
                '<div class="vendor-definition-grid">' +
                    '<div>' +
                        '<label class="form-label">厂商名称</label>' +
                        '<input type="text" class="form-control vendor-name-input" value="' + escapeHtml(vendor.VendorName || '') + '" />' +
                    '</div>' +
                    '<div>' +
                        '<label class="form-label">标题背景色</label>' +
                        '<input type="text" class="form-control vendor-bg-input" value="' + escapeHtml(vendor.HeaderBackground || '#f8fafc') + '" placeholder="#eef6ff" />' +
                    '</div>' +
                    '<div>' +
                        '<label class="form-label">排序值</label>' +
                        '<input type="number" class="form-control vendor-sort-input" value="' + escapeHtml(String(vendor.SortOrder ?? 0)) + '" />' +
                    '</div>' +
                '</div>' +
                '<div class="mt-3">' +
                    '<label class="form-label">标题 SVG 图标内容</label>' +
                    '<textarea class="form-control vendor-svg-input vendor-svg-textarea" placeholder="可直接粘贴 <svg ...>...</svg> 或内部 <path> / <defs> 内容">' + escapeHtml(vendor.IconSvgBody || '') + '</textarea>' +
                '</div>' +
                '<div class="vendor-preview-card">' +
                    '<div class="text-muted small mb-2">标题预览</div>' +
                    '<div class="vendor-preview-header" style="background:' + escapeAttribute(vendor.HeaderBackground || '#f8fafc') + ';">' +
                        '<div class="vendor-preview-icon">' + buildVendorIconPreview(vendor.IconSvgBody, vendor.VendorName) + '</div>' +
                        '<div>' +
                            '<div class="fw-semibold">' + escapeHtml(vendor.VendorName || '未命名厂商') + '</div>' +
                            '<div class="text-muted small">模型分组标题示例</div>' +
                        '</div>' +
                    '</div>' +
                '</div>' +
                '<div class="vendor-rule-section">' +
                    '<div class="vendor-editor-section-header">' +
                        '<h6 class="mb-0">匹配规则</h6>' +
                        '<button type="button" class="btn btn-sm btn-outline-primary vendor-add-rule-btn">新增规则</button>' +
                    '</div>' +
                    '<div class="text-muted small mt-2">当前规则自动归属于该厂商，无需再单独选择厂商名。</div>' +
                    '<div class="vendor-rule-list">' + renderVendorRules(vendor.VendorName) + '</div>' +
                '</div>' +
            '</div>';

        modalBody.querySelector('.vendor-delete-btn').addEventListener('click', function () {
            removeVendorRow(currentVendorEditIndex);
        });
        modalBody.querySelector('.vendor-add-rule-btn').addEventListener('click', function () {
            addRuleForVendor(currentVendorEditIndex);
        });
        modalBody.querySelector('.vendor-name-input').addEventListener('change', function () {
            updateVendorName(currentVendorEditIndex, this.value);
            renderVendorEditor();
        });
        modalBody.querySelector('.vendor-bg-input').addEventListener('change', function () {
            updateVendorField(currentVendorEditIndex, 'HeaderBackground', this.value);
            renderVendorEditor();
        });
        modalBody.querySelector('.vendor-sort-input').addEventListener('change', function () {
            updateVendorField(currentVendorEditIndex, 'SortOrder', this.value);
            renderVendorEditor();
        });
        modalBody.querySelector('.vendor-svg-input').addEventListener('change', function () {
            updateVendorField(currentVendorEditIndex, 'IconSvgBody', this.value);
            renderVendorEditor();
        });

        modalBody.querySelectorAll('.vendor-rule-row').forEach(function (row) {
            var ruleIndex = parseInt(row.getAttribute('data-rule-index') || '-1', 10);
            if (ruleIndex < 0) {
                return;
            }

            row.querySelector('.rule-priority-input').addEventListener('change', function () {
                updateRuleField(ruleIndex, 'Priority', this.value);
                renderVendorEditor();
            });
            row.querySelector('.rule-match-type-input').addEventListener('change', function () {
                updateRuleField(ruleIndex, 'MatchType', this.value);
                renderVendorEditor();
            });
            row.querySelector('.rule-pattern-input').addEventListener('change', function () {
                updateRuleField(ruleIndex, 'Pattern', this.value);
                renderVendorEditor();
            });
            row.querySelector('.rule-delete-btn').addEventListener('click', function () {
                removeRuleByIndex(ruleIndex);
            });
        });
    }

    function renderVendorEditor() {
        ensureVendorCatalogShape();
        var container = document.getElementById('vendorDefinitionList');
        var emptyState = document.getElementById('vendorSearchEmptyState');
        if (!container) {
            return;
        }

        var keyword = (document.getElementById('vendorRuleSearchInput')?.value || '').trim().toLowerCase();
        if (vendorCatalogState.Vendors.length === 0) {
            container.innerHTML = '<div class="vendor-rule-empty mt-0">当前还没有厂商配置，点击上方“新增厂商”即可开始维护。</div>';
            if (emptyState) {
                emptyState.style.display = 'none';
            }
            renderVendorEditorModal();
            return;
        }

        container.innerHTML = '';
        var visibleCount = 0;
        vendorCatalogState.Vendors.forEach(function (vendor, index) {
            var rules = getRulesForVendor(vendor.VendorName);
            var searchText = [vendor.VendorName || '', rules.map(function (entry) { return entry.rule.Pattern || ''; }).join(' '), rules.map(function (entry) { return entry.rule.MatchType || ''; }).join(' ')].join(' ').toLowerCase();
            if (keyword !== '' && searchText.indexOf(keyword) < 0) {
                return;
            }

            visibleCount++;
            var card = document.createElement('div');
            card.className = 'vendor-summary-card';
            card.innerHTML = '' +
                '<div class="vendor-summary-header">' +
                    '<div>' +
                        '<div class="vendor-summary-name">' + escapeHtml(vendor.VendorName || '未命名厂商') + '</div>' +
                        '<div class="vendor-summary-meta">规则 ' + escapeHtml(String(rules.length)) + ' 条 · 排序 ' + escapeHtml(String(vendor.SortOrder ?? 0)) + '</div>' +
                    '</div>' +
                    '<div class="d-flex gap-2 flex-wrap">' +
                        '<button type="button" class="btn btn-sm btn-outline-primary vendor-edit-btn">编辑</button>' +
                        '<button type="button" class="btn btn-sm btn-outline-danger vendor-delete-btn">删除</button>' +
                    '</div>' +
                '</div>' +
                '<div class="vendor-summary-rules">' + renderVendorRuleSummary(vendor.VendorName) + '</div>';

            card.querySelector('.vendor-edit-btn').addEventListener('click', function () {
                openVendorEditor(index);
            });
            card.querySelector('.vendor-delete-btn').addEventListener('click', function () {
                removeVendorRow(index);
            });

            container.appendChild(card);
        });

        if (emptyState) {
            emptyState.style.display = visibleCount === 0 ? '' : 'none';
        }

        renderVendorEditorModal();
    }

    function extractSvgBody(iconSvgBody) {
        var normalized = String(iconSvgBody || '').trim();
        if (normalized === '') {
            return '';
        }

        var svgMatch = normalized.match(/^<svg\b([^>]*)>([\s\S]*)<\/svg>$/i);
        if (!svgMatch) {
            return normalized;
        }

        var attrs = svgMatch[1] || '';
        var body = (svgMatch[2] || '').trim();
        var viewBoxMatch = attrs.match(/\bviewBox\s*=\s*(['"])(.*?)\1/i);
        if (!viewBoxMatch || !viewBoxMatch[2]) {
            return body;
        }

        // 保留原始 viewBox，避免大坐标 svg 在 24x24 外层里被裁掉。
        return '<svg viewBox="' + escapeAttribute(viewBoxMatch[2].trim()) + '">' + body + '</svg>';
    }

    function buildVendorIconPreview(iconSvgBody, vendorName) {
        var svgBody = extractSvgBody(iconSvgBody);
        if (svgBody !== '') {
            // 统一替换外部 SVG 内的渐变引用，避免预览和列表页显示不一致。
            var normalizedSvgBody = String(svgBody)
                .split('url(#lobe-icons-qwen-fill)').join('url(#vendor-gradient-alibaba-preview)')
                .split('id="lobe-icons-qwen-fill"').join('id="vendor-gradient-alibaba-preview"');
            return '<svg viewBox="0 0 24 24"><defs><linearGradient id="vendor-gradient-alibaba-preview" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#FF8A00"></stop><stop offset="100%" stop-color="#FF5F00"></stop></linearGradient></defs>' + normalizedSvgBody + '</svg>';
        }

        return '<span class="vendor-preview-fallback">' + escapeHtml((vendorName || '未').substring(0, 1)) + '</span>';
    }

    function escapeHtml(text) {
        var element = document.createElement('div');
        element.textContent = text == null ? '' : String(text);
        return element.innerHTML;
    }

    function escapeAttribute(text) {
        return escapeHtml(text).replace(/"/g, '&quot;');
    }
</script>
