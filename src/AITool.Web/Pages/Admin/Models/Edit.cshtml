@page "{id:guid}"
@model AITool.Web.Pages.Admin.Models.EditModel
@{
    ViewData["Title"] = "编辑模型";
}

<!-- 页面标题 -->
<div class="page-header">
    <div>
        <h2 class="page-title">编辑模型</h2>
        <p class="page-subtitle">修改模型配置信息</p>
    </div>
</div>

<!-- 状态提示 -->
@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert @(Model.StatusSuccess ? "alert-success" : "alert-danger")">
        @Model.StatusMessage
    </div>
}

<!-- 编辑表单 -->
<div class="form-card">
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="ModelName" class="form-label">模型名</label>
            <input asp-for="ModelName" class="form-control" required />
            <span asp-validation-for="ModelName" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="DisplayName" class="form-label">显示名</label>
            <input asp-for="DisplayName" class="form-control" required />
            <span asp-validation-for="DisplayName" class="text-danger"></span>
        </div>

        <div class="mb-3 form-check">
            <input asp-for="IsEnabled" class="form-check-input" type="checkbox" />
            <label asp-for="IsEnabled" class="form-check-label">启用</label>
        </div>

        <div class="divider"></div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">保存</button>
            <a asp-page="./Index" class="btn btn-secondary">取消</a>
        </div>
    </form>
</div>

<div class="form-card mt-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="h5 mb-1">关联站点</h3>
            <div class="text-muted small">删除关联站点时，会同步清理对应的 route rules。</div>
        </div>
        <span class="badge bg-info">@Model.SiteMappings.Count</span>
    </div>

    @if (!Model.SiteMappings.Any())
    {
        <div class="text-muted">当前模型还没有关联任何站点。</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>站点</th>
                        <th>站点模型名</th>
                        <th>状态</th>
                        <th>最大并发数</th>
                        <th class="text-end">操作</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var mapping in Model.SiteMappings)
                    {
                        <tr>
                            <td>@mapping.SiteName</td>
                            <td><code>@mapping.RemoteModelName</code></td>
                            <td>
                                <span class="badge bg-@(mapping.IsEnabled ? "success" : "secondary")">
                                    @(mapping.IsEnabled ? "启用" : "禁用")
                                </span>
                            </td>
                            <td>
                                <div class="d-flex align-items-center gap-1">
                                    <input type="number"
                                           class="form-control form-control-sm concurrency-input"
                                           value="@mapping.MaxConcurrency"
                                           min="0"
                                           style="width: 80px"
                                           data-mapping-id="@mapping.MappingId" />
                                    <button type="button"
                                            class="btn btn-sm btn-outline-primary concurrency-save"
                                            data-mapping-id="@mapping.MappingId">保存</button>
                                </div>
                            </td>
                            <td class="text-end">
                                <form method="post" asp-page-handler="DeleteMapping" asp-route-id="@Model.CurrentModelId" asp-route-mappingId="@mapping.MappingId" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('确认删除该站点关联？')">删除关联</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<script>
document.querySelectorAll('.concurrency-save').forEach(function(btn) {
    btn.addEventListener('click', async function() {
        var mappingId = this.dataset.mappingId;
        var input = document.querySelector('.concurrency-input[data-mapping-id="' + mappingId + '"]');
        var value = parseInt(input.value) || 0;
        var originalText = this.textContent;

        try {
            this.disabled = true;
            this.textContent = '...';

            var res = await fetch('/api/admin/models/mappings/' + mappingId + '/concurrency', {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ maxConcurrency: value })
            });

            if (res.ok) {
                this.textContent = '✓';
                this.classList.remove('btn-outline-primary');
                this.classList.add('btn-outline-success');
                setTimeout(function() {
                    btn.textContent = originalText;
                    btn.classList.remove('btn-outline-success');
                    btn.classList.add('btn-outline-primary');
                }, 1500);
            } else {
                throw new Error('保存失败');
            }
        } catch (e) {
            this.textContent = '✗';
            this.classList.remove('btn-outline-primary');
            this.classList.add('btn-outline-danger');
            setTimeout(function() {
                btn.textContent = originalText;
                btn.classList.remove('btn-outline-danger');
                btn.classList.add('btn-outline-primary');
            }, 1500);
        } finally {
            this.disabled = false;
        }
    });
});
</script>
