@page
@model AITool.Web.Pages.Admin.DetectionTasks.IndexModel
@{
    ViewData["Title"] = "检测任务管理";
}

<h1>检测任务管理</h1>

@if (Model.StatusMessage is not null)
{
    <div class="alert alert-@(Model.StatusSuccess ? "success" : "danger")">
        @Model.StatusMessage
    </div>
}

<form method="post" asp-page-handler="Create" class="mb-3">
    <div class="row g-2 align-items-end">
        <div class="col-auto">
            <label class="form-label">任务名称</label>
            <input type="text" name="name" class="form-control" required />
        </div>
        <div class="col-auto">
            <label class="form-label">Cron 表达式</label>
            <input type="text" name="cronExpression" class="form-control" value="*/30 * * * *" required />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary">创建任务</button>
        </div>
    </div>
</form>

<table class="table table-striped">
    <thead>
        <tr>
            <th>任务名称</th>
            <th>Cron 表达式</th>
            <th>状态</th>
            <th>最近执行</th>
            <th>操作</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Tasks)
        {
            <tr>
                <td>@item.Name</td>
                <td><code>@item.CronExpression</code></td>
                <td>
                    <span class="badge bg-@(item.IsEnabled ? "success" : "secondary")">
                        @(item.IsEnabled ? "启用" : "禁用")
                    </span>
                </td>
                <td>@(item.LastExecutionSummary ?? "-")</td>
                <td>
                    <form method="post" asp-page-handler="Toggle" asp-route-taskId="@item.TaskId" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-outline-@(item.IsEnabled ? "warning" : "success")">
                            @(item.IsEnabled ? "禁用" : "启用")
                        </button>
                    </form>
                    <form method="post" asp-page-handler="Execute" asp-route-taskId="@item.TaskId" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-outline-primary">立即执行</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
