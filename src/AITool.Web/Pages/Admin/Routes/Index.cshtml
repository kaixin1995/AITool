@page
@model AITool.Web.Pages.Admin.Routes.IndexModel
@{
    ViewData["Title"] = "路由规则管理";
}
<div class="page-header">
    <div>
        <h2 class="page-title">路由规则管理</h2>
        <p class="page-subtitle">主入口绑定有序候选实例队列，请求时按顺序失败切换、成功即停止</p>
    </div>
</div>

<div id="statusMsg" class="alert" style="display:none;"></div>

<div class="route-layout">
    <section class="route-panel route-panel-left">
        <div class="route-panel-header">
            <div>
                <h5 class="route-panel-title">主入口</h5>
                <div class="route-panel-subtitle">管理对外暴露的本地路由入口</div>
            </div>
        </div>

        <div class="route-create-box">
            <label class="form-label" for="entryNameInput">新建主入口</label>
            <div class="input-group">
                <input id="entryNameInput" type="text" class="form-control" placeholder="例如 auto" />
                <button type="button" class="btn btn-primary" onclick="createEntry()">创建</button>
            </div>
        </div>

        <div id="entryEmptyState" class="route-empty-state" style="display:none;">
            暂无主入口，请先创建
        </div>
        <div id="entryList" class="entry-list"></div>
    </section>

    <section class="route-panel route-panel-right">
        <div class="route-panel-header route-panel-header-stack">
            <div>
                <h5 class="route-panel-title">候选实例队列</h5>
                <div id="currentEntryLabel" class="route-panel-subtitle">请选择或创建一个主入口</div>
            </div>
            <div id="entryDangerZone" style="display:none;">
                <button type="button" class="btn btn-outline-danger btn-sm" onclick="deleteCurrentEntry()">删除当前主入口</button>
            </div>
        </div>

        <div id="queueEmptyState" class="route-empty-state">
            请选择或创建一个主入口
        </div>

        <div id="queueEditor" style="display:none;">
            <div class="route-add-box">
                <div class="row g-2 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label" for="siteInstanceSearchInput">搜索候选实例</label>
                        <input id="siteInstanceSearchInput" type="text" class="form-control" placeholder="搜索站点或模型" oninput="renderSiteInstanceSelect()" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label" for="siteInstanceSelect">添加候选实例</label>
                        <select id="siteInstanceSelect" class="form-select">
                            <option value="">-- 请选择站点实例 --</option>
                        </select>
                    </div>
                    <div class="col-auto">
                        <button type="button" class="btn btn-outline-primary" onclick="appendSiteInstance()">追加到队列末尾</button>
                    </div>
                    <div class="col-auto">
                        <button type="button" class="btn btn-secondary" onclick="loadSiteInstances()">刷新实例池</button>
                    </div>
                </div>
            </div>

            <div class="queue-card">
                <div class="queue-card-header">
                    <span>拖拽调整顺序，修改后立即保存生效</span>
                </div>
                <div class="queue-card-body">
                    <div id="routeList" class="route-sort-list"></div>
                    <div id="queueListEmptyState" class="route-empty-state" style="display:none;">
                        当前主入口暂无候选实例，请先添加
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

<style>
    .route-layout {
        display: grid;
        grid-template-columns: 320px 1fr;
        gap: 20px;
        align-items: start;
    }

    .route-panel {
        border: 1px solid var(--border-color, #e9ecef);
        border-radius: 12px;
        background: var(--card-bg, var(--bg-card));
        overflow: hidden;
    }

    .route-panel-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 18px;
        border-bottom: 1px solid var(--border-color, #e9ecef);
        background: var(--card-bg-alt, #f8f9fa);
    }

    .route-panel-header-stack {
        align-items: flex-start;
        gap: 12px;
    }

    .route-panel-title {
        margin: 0;
        font-size: 16px;
        font-weight: 700;
    }

    .route-panel-subtitle {
        margin-top: 4px;
        color: var(--text-secondary, #6c757d);
        font-size: 13px;
    }

    .route-create-box,
    .route-add-box {
        padding: 16px 18px;
        border-bottom: 1px solid var(--border-color, #e9ecef);
    }

    .entry-list {
        padding: 10px;
    }

    .entry-item {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 12px 14px;
        margin-bottom: 8px;
        border: 1px solid var(--border-color, #e9ecef);
        border-radius: 10px;
        background: var(--bg-card);
        cursor: pointer;
        transition: border-color 0.15s, background 0.15s;
    }

    .entry-item:hover {
        border-color: #b6d4fe;
        background: #f8fbff;
    }

    .entry-item.active {
        border-color: #0d6efd;
        background: #e8f0fe;
    }

    .entry-name {
        font-weight: 600;
        font-size: 14px;
    }

    .entry-count {
        color: var(--text-secondary, #6c757d);
        font-size: 12px;
    }

    .route-empty-state {
        padding: 28px 18px;
        color: var(--text-secondary, #6c757d);
        text-align: center;
    }

    .queue-card-header {
        padding: 14px 18px;
        border-bottom: 1px solid var(--border-color, #e9ecef);
        background: var(--card-bg-alt, #f8f9fa);
        color: var(--text-secondary, #6c757d);
        font-size: 13px;
    }

    .queue-card-body {
        min-height: 240px;
    }

    .route-sort-list {
        min-height: 48px;
    }

    .route-item {
        display: grid;
        grid-template-columns: auto auto minmax(0, 1fr) auto auto;
        align-items: center;
        gap: 12px;
        padding: 14px 16px;
        border-bottom: 1px solid var(--border-color, #e9ecef);
        cursor: grab;
        user-select: none;
        transition: background 0.15s;
    }

    .route-item:hover {
        background: var(--card-bg-alt, #f8f9fa);
    }

    .route-item.dragging {
        opacity: 0.4;
        background: #e8f0fe;
    }

    .drag-handle {
        color: var(--text-secondary, #999);
        font-size: 18px;
        cursor: grab;
        flex-shrink: 0;
    }

    .priority-num {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: #e8f0fe;
        color: #0d6efd;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 600;
        flex-shrink: 0;
    }

    .site-info {
        min-width: 0;
    }

    .site-name-row {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 8px;
    }

    .site-name {
        font-weight: 600;
        font-size: 14px;
    }

    .route-badge {
        display: inline-flex;
        align-items: center;
        min-height: 22px;
        padding: 2px 8px;
        border-radius: 999px;
        border: 1px solid #dbeafe;
        background: #eff6ff;
        color: #1d4ed8;
        font-size: 12px;
        line-height: 1.2;
        white-space: nowrap;
    }

    .route-badge-muted {
        border-color: var(--border-color, #e9ecef);
        background: #f8f9fa;
        color: var(--text-secondary, #6c757d);
    }

    .route-badge-warning {
        border-color: #fed7aa;
        background: #fff7ed;
        color: #c2410c;
    }

    /* 站点已禁用标签样式。 */
    .badge-disabled {
        border-color: #d1d5db;
        background: #f3f4f6;
        color: #9ca3af;
    }

    /* 站点被禁用时站点名变灰。 */
    .site-disabled {
        color: #9ca3af;
    }

    .remote-name {
        font-size: 12px;
        color: var(--text-secondary, #888);
        margin-top: 4px;
    }

    .route-actions {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 8px;
        flex-shrink: 0;
    }

    .availability-trigger {
        min-width: 96px;
        white-space: nowrap;
    }

    .availability-popover {
        grid-column: 3 / -1;
        display: none;
        align-items: center;
        gap: 10px;
        padding: 10px 12px;
        border: 1px solid #dbeafe;
        border-radius: 8px;
        background: #f8fbff;
        cursor: default;
    }

    .availability-popover.open {
        display: flex;
    }

    .availability-popover .form-select {
        width: 160px;
    }

    .availability-popover .form-control {
        width: 116px;
    }

    .time-range-fields {
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .time-range-fields.is-hidden {
        display: none;
    }

    .availability-hint {
        color: var(--text-secondary, #6c757d);
        font-size: 12px;
        margin-left: auto;
        white-space: nowrap;
    }

    @@media (max-width: 991px) {
        .route-layout {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 767px) {
        .route-item {
            grid-template-columns: auto auto minmax(0, 1fr);
        }

        .route-actions {
            grid-column: 3;
            justify-content: flex-start;
        }

        .availability-popover {
            grid-column: 1 / -1;
            flex-wrap: wrap;
        }

        .availability-hint {
            width: 100%;
            margin-left: 0;
        }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        loadSiteInstances();
        loadEntries();
    });

    var _entries = [];
    var _currentEntryName = '';
    var _currentItems = [];
    var _siteInstances = [];
    var _routeEditorLoadToken = 0;
    var _pendingRouteSave = null;
    var _routeSaveInFlight = false;

    function loadEntries(preferredEntryName) {
        fetch('/api/admin/route-rules/entries')
            .then(function(r) { return r.json(); })
            .then(function(data) {
                _entries = data || [];
                renderEntryList();

                if (_entries.length === 0) {
                    setCurrentEntry('');
                    return;
                }

                var targetEntryName = preferredEntryName || _currentEntryName;
                var exists = _entries.some(function(item) { return item.entryName === targetEntryName; });
                if (!exists) {
                    targetEntryName = _entries[0].entryName;
                }

                setCurrentEntry(targetEntryName);
            })
            .catch(function(err) {
                showMsg('加载主入口失败：' + err.message, false);
            });
    }

    function renderEntryList() {
        var list = document.getElementById('entryList');
        var emptyState = document.getElementById('entryEmptyState');

        if (_entries.length === 0) {
            list.innerHTML = '';
            emptyState.style.display = 'block';
            return;
        }

        emptyState.style.display = 'none';
        list.innerHTML = '';

        _entries.forEach(function(entry) {
            var button = document.createElement('button');
            button.type = 'button';
            button.className = 'entry-item' + (entry.entryName === _currentEntryName ? ' active' : '');
            button.onclick = function() { setCurrentEntry(entry.entryName); };
            button.innerHTML =
                '<div>' +
                    '<div class="entry-name">' + escHtml(entry.entryName) + '</div>' +
                    '<div class="entry-count">' + entry.candidateCount + ' 个候选</div>' +
                '</div>' +
                '<span class="text-secondary">›</span>';
            list.appendChild(button);
        });
    }

    function setCurrentEntry(entryName) {
        _currentEntryName = entryName || '';
        renderEntryList();
        updateQueuePanelState();

        if (!_currentEntryName) {
            _currentItems = [];
            renderRouteList();
            return;
        }

        loadRouteEditor(_currentEntryName);
    }

    function updateQueuePanelState() {
        var currentEntryLabel = document.getElementById('currentEntryLabel');
        var queueEmptyState = document.getElementById('queueEmptyState');
        var queueEditor = document.getElementById('queueEditor');
        var dangerZone = document.getElementById('entryDangerZone');

        if (!_currentEntryName) {
            currentEntryLabel.textContent = '请选择或创建一个主入口';
            queueEmptyState.textContent = '请选择或创建一个主入口';
            queueEmptyState.style.display = 'block';
            queueEditor.style.display = 'none';
            dangerZone.style.display = 'none';
            return;
        }

        currentEntryLabel.textContent = '当前主入口：' + _currentEntryName;
        queueEmptyState.style.display = 'none';
        queueEditor.style.display = 'block';
        dangerZone.style.display = 'block';
    }

    function createEntry() {
        var input = document.getElementById('entryNameInput');
        var entryName = (input.value || '').trim();
        if (!entryName) {
            showMsg('请输入主入口名称', false);
            return;
        }

        fetch('/api/admin/route-rules/entries', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ entryName: entryName })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.message === '创建成功') {
                input.value = '';
                showMsg('主入口已创建', true);
                loadEntries(entryName);
            } else {
                showMsg(data.message || '创建失败', false);
            }
        })
        .catch(function(err) {
            showMsg('创建失败：' + err.message, false);
        });
    }

    function deleteCurrentEntry() {
        if (!_currentEntryName) {
            return;
        }

        if (!confirm('确认删除主入口 ' + _currentEntryName + ' 及其候选队列？')) {
            return;
        }

        fetch('/api/admin/route-rules/entries/delete', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ entryName: _currentEntryName })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.message === '删除成功') {
                showMsg('主入口已删除', true);
                _currentEntryName = '';
                _currentItems = [];
                loadEntries();
            } else {
                showMsg(data.message || '删除失败', false);
            }
        })
        .catch(function(err) {
            showMsg('删除失败：' + err.message, false);
        });
    }

    function loadRouteEditor(entryName) {
        var loadToken = ++_routeEditorLoadToken;
        fetch('/api/admin/route-rules/list?modelName=' + encodeURIComponent(entryName))
            .then(function(r) { return r.json(); })
            .then(function(existingRules) {
                if (loadToken !== _routeEditorLoadToken || entryName !== _currentEntryName) {
                    return;
                }

                _currentItems = (existingRules || []).map(function(r) {
                    var ranges = parseTimeRanges(r.timeRangesJson);
                    var mode = normalizeAvailabilityMode(r.availabilityMode);
                    if (ranges.length === 0) {
                        mode = 'AllDay';
                    }

                    return {
                        siteId: r.siteId,
                        siteName: r.siteName,
                        siteEnabled: r.siteEnabled !== false,
                        upstreamModelName: r.upstreamModelName || r.siteModelName,
                        siteModelName: r.siteModelName,
                        availabilityMode: mode,
                        timeRanges: ranges
                    };
                });
                renderRouteList();
            })
            .catch(function(err) {
                if (loadToken !== _routeEditorLoadToken || entryName !== _currentEntryName) {
                    return;
                }

                showMsg('加载候选队列失败：' + err.message, false);
            });
    }

    function loadSiteInstances() {
        var select = document.getElementById('siteInstanceSelect');
        select.innerHTML = '<option value="">-- 加载中... --</option>';

        fetch('/api/admin/route-rules/site-instances')
            .then(function(r) { return r.json(); })
            .then(function(data) {
                _siteInstances = data || [];
                renderSiteInstanceSelect();
            })
            .catch(function(err) {
                select.innerHTML = '<option value="">-- 加载失败 --</option>';
                showMsg('加载实例池失败：' + err.message, false);
            });
    }

    function renderSiteInstanceSelect() {
        var select = document.getElementById('siteInstanceSelect');
        var keyword = (document.getElementById('siteInstanceSearchInput').value || '').trim().toLowerCase();
        select.innerHTML = '<option value="">-- 请选择站点实例 --</option>';

        _siteInstances.forEach(function(item, index) {
            var label = item.siteName + ' / ' + item.siteModelName;
            if (keyword && label.toLowerCase().indexOf(keyword) < 0) {
                return;
            }

            var opt = document.createElement('option');
            opt.value = String(index);
            opt.textContent = label;
            select.appendChild(opt);
        });

        if (select.options.length === 1) {
            select.innerHTML = '<option value="">-- 暂无匹配实例 --</option>';
            if (_siteInstances.length === 0) {
                select.innerHTML = '<option value="">-- 暂无可用实例 --</option>';
            }
        }
    }

    function appendSiteInstance() {
        if (!_currentEntryName) {
            showMsg('请先选择或创建主入口', false);
            return;
        }

        var selectedIndex = document.getElementById('siteInstanceSelect').value;
        if (selectedIndex === '') {
            showMsg('请先选择站点实例', false);
            return;
        }

        var selectedItem = _siteInstances[Number(selectedIndex)];
        if (!selectedItem) {
            showMsg('未找到对应站点实例', false);
            return;
        }

        _currentItems.push({
            siteId: selectedItem.siteId,
            siteName: selectedItem.siteName,
            siteEnabled: selectedItem.siteEnabled !== false,
            upstreamModelName: selectedItem.siteModelName,
            siteModelName: selectedItem.siteModelName,
            availabilityMode: 'AllDay',
            timeRanges: []
        });

        renderRouteList();
        persistCurrentQueue('已追加候选实例');
    }

    function renderRouteList(openAvailabilityIndex) {
        var list = document.getElementById('routeList');
        var emptyState = document.getElementById('queueListEmptyState');

        if (_currentItems.length === 0) {
            list.innerHTML = '';
            emptyState.style.display = _currentEntryName ? 'block' : 'none';
            return;
        }

        emptyState.style.display = 'none';
        list.innerHTML = '';

        _currentItems.forEach(function(item, index) {
            var row = document.createElement('div');
            row.className = 'route-item';
            row.draggable = true;
            row.setAttribute('data-index', String(index));
            var availabilityLabel = getAvailabilitySummary(item);
            row.innerHTML =
                '<span class="drag-handle">⠿</span>' +
                '<span class="priority-num">' + (index + 1) + '</span>' +
                '<div class="site-info">' +
                    '<div class="site-name-row">' +
                        '<span class="site-name' + (item.siteEnabled ? '' : ' site-disabled') + '">' + escHtml(item.siteName) + '</span>' +
                        (item.siteEnabled ? '' : '<span class="route-badge badge-disabled">站点已禁用</span>') +
                        '<span class="route-badge ' + availabilityLabel.badgeClass + '">' + escHtml(availabilityLabel.text) + '</span>' +
                    '</div>' +
                    '<div class="remote-name">上游模型：' + escHtml(item.upstreamModelName) + ' · 站点实例：' + escHtml(item.siteModelName) + '</div>' +
                '</div>' +
                '<button type="button" class="btn btn-sm btn-outline-secondary availability-trigger" onclick="toggleAvailabilityEditor(event, ' + index + ')">时间规则</button>' +
                '<div class="route-actions">' +
                    '<button type="button" class="btn btn-sm btn-outline-danger" onclick="removeItem(' + index + ')">移除</button>' +
                '</div>' +
                buildAvailabilityEditorHtml(item, index, openAvailabilityIndex === index);
            list.appendChild(row);
        });

        initDragDrop();
    }

    function initDragDrop() {
        var list = document.getElementById('routeList');
        var draggedItem = null;

        list.ondragstart = function(e) {
            draggedItem = e.target.closest('.route-item');
            if (draggedItem) {
                e.dataTransfer.effectAllowed = 'move';
                setTimeout(function() { draggedItem.classList.add('dragging'); }, 0);
            }
        };

        list.ondragend = function() {
            if (!draggedItem) {
                return;
            }

            draggedItem.classList.remove('dragging');
            draggedItem = null;
            syncItemsFromDOM();
            renderRouteList();
            persistCurrentQueue('顺序已更新');
        };

        list.ondragover = function(e) {
            e.preventDefault();
            e.dataTransfer.dropEffect = 'move';
            var target = e.target.closest('.route-item');
            if (!draggedItem || !target || target === draggedItem) {
                return;
            }

            var rect = target.getBoundingClientRect();
            var mid = rect.top + rect.height / 2;
            if (e.clientY < mid) {
                list.insertBefore(draggedItem, target);
            } else {
                list.insertBefore(draggedItem, target.nextSibling);
            }
        };
    }

    function syncItemsFromDOM() {
        var rows = document.querySelectorAll('#routeList .route-item');
        var reordered = [];
        rows.forEach(function(row) {
            var index = Number(row.getAttribute('data-index'));
            if (!Number.isNaN(index) && _currentItems[index]) {
                reordered.push(_currentItems[index]);
            }
        });
        _currentItems = reordered;
    }

    function removeItem(index) {
        _currentItems.splice(index, 1);
        renderRouteList();
        persistCurrentQueue('已移除候选实例');
    }

    function buildAvailabilityEditorHtml(item, index, isOpen) {
        var mode = normalizeAvailabilityMode(item.availabilityMode);
        var range = getPrimaryTimeRange(item);
        var timeClass = mode === 'AllDay' ? 'time-range-fields is-hidden' : 'time-range-fields';
        var popoverClass = isOpen ? 'availability-popover open' : 'availability-popover';
        return '<div class="' + popoverClass + '" data-availability-index="' + index + '">' +
            '<select class="form-select form-select-sm" onchange="updateAvailabilityMode(' + index + ', this.value)">' +
                '<option value="AllDay"' + (mode === 'AllDay' ? ' selected' : '') + '>全天可用</option>' +
                '<option value="AvailableOnly"' + (mode === 'AvailableOnly' ? ' selected' : '') + '>仅指定时间可用</option>' +
                '<option value="Unavailable"' + (mode === 'Unavailable' ? ' selected' : '') + '>指定时间不可用</option>' +
            '</select>' +
            '<span class="' + timeClass + '">' +
                '<input type="time" class="form-control form-control-sm" value="' + escHtml(range.start) + '" onchange="updateAvailabilityTime(' + index + ', \'start\', this.value)" />' +
                '<span class="text-secondary">至</span>' +
                '<input type="time" class="form-control form-control-sm" value="' + escHtml(range.end) + '" onchange="updateAvailabilityTime(' + index + ', \'end\', this.value)" />' +
            '</span>' +
            '<span class="availability-hint">留空或无效配置会按全天可用处理</span>' +
        '</div>';
    }

    function toggleAvailabilityEditor(event, index) {
        event.stopPropagation();
        var current = document.querySelector('[data-availability-index="' + index + '"]');
        if (!current) {
            return;
        }

        var shouldOpen = !current.classList.contains('open');
        document.querySelectorAll('.availability-popover.open').forEach(function(el) {
            el.classList.remove('open');
        });
        if (shouldOpen) {
            current.classList.add('open');
        }
    }

    function updateAvailabilityMode(index, mode) {
        var item = _currentItems[index];
        if (!item) {
            return;
        }

        item.availabilityMode = normalizeAvailabilityMode(mode);
        if (item.availabilityMode === 'AllDay') {
            item.timeRanges = [];
        } else if (!item.timeRanges || item.timeRanges.length === 0) {
            item.timeRanges = [{ start: '00:00', end: '23:59' }];
        }

        renderRouteList(index);
        persistCurrentQueue('时间范围已更新');
    }

    function updateAvailabilityTime(index, field, value) {
        var item = _currentItems[index];
        if (!item) {
            return;
        }

        if (normalizeAvailabilityMode(item.availabilityMode) === 'AllDay') {
            item.availabilityMode = 'Unavailable';
        }

        var range = getPrimaryTimeRange(item);
        range[field] = value || (field === 'start' ? '00:00' : '23:59');
        item.timeRanges = [range];
        renderRouteList(index);
        persistCurrentQueue('时间范围已更新');
    }

    function persistCurrentQueue(successMessage) {
        if (!_currentEntryName) {
            return;
        }

        _pendingRouteSave = {
            entryName: _currentEntryName,
            successMessage: successMessage,
            rules: _currentItems.map(function(item) {
                var mode = normalizeAvailabilityMode(item.availabilityMode);
                var ranges = mode === 'AllDay' ? [] : normalizeTimeRanges(item.timeRanges);
                return {
                    upstreamModelName: item.upstreamModelName,
                    siteId: item.siteId,
                    siteModelName: item.siteModelName,
                    availabilityMode: ranges.length === 0 ? 'AllDay' : mode,
                    timeRangesJson: ranges.length === 0 ? '' : JSON.stringify(ranges)
                };
            })
        };

        flushRouteSaveQueue();
    }

    function flushRouteSaveQueue() {
        if (_routeSaveInFlight || !_pendingRouteSave) {
            return;
        }

        var saveRequest = _pendingRouteSave;
        _pendingRouteSave = null;
        _routeSaveInFlight = true;

        fetch('/api/admin/route-rules/save', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ externalModelName: saveRequest.entryName, rules: saveRequest.rules })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if ((data.message || '').indexOf('保存成功') === 0) {
                syncEntryCandidateCount(saveRequest.entryName, saveRequest.rules.length);
                if (!_pendingRouteSave) {
                    showMsg(data.message === '保存成功' ? saveRequest.successMessage : data.message, true);
                }
            } else {
                showMsg(data.message || '保存失败', false);
            }
        })
        .catch(function(err) {
            showMsg('保存失败：' + err.message, false);
        })
        .finally(function() {
            _routeSaveInFlight = false;
            flushRouteSaveQueue();
        });
    }

    function syncEntryCandidateCount(entryName, candidateCount) {
        var entry = _entries.find(function(item) { return item.entryName === entryName; });
        if (!entry) {
            return;
        }

        entry.candidateCount = candidateCount;
        renderEntryList();
    }

    function showMsg(msg, success) {
        var el = document.getElementById('statusMsg');
        el.textContent = msg;
        el.className = 'alert alert-' + (success ? 'success' : 'danger');
        el.style.display = 'block';
        setTimeout(function() { el.style.display = 'none'; }, 3000);
    }

    function normalizeAvailabilityMode(mode) {
        return mode === 'AvailableOnly' || mode === 'Unavailable' ? mode : 'AllDay';
    }

    function parseTimeRanges(timeRangesJson) {
        if (!timeRangesJson) {
            return [];
        }

        try {
            return normalizeTimeRanges(JSON.parse(timeRangesJson));
        } catch (err) {
            return [];
        }
    }

    function normalizeTimeRanges(ranges) {
        if (!Array.isArray(ranges)) {
            return [];
        }

        return ranges
            .map(function(range) {
                return {
                    start: range.start || range.Start,
                    end: range.end || range.End
                };
            })
            .filter(function(range) { return isValidTime(range.start) && isValidTime(range.end); });
    }

    function getPrimaryTimeRange(item) {
        var ranges = normalizeTimeRanges(item.timeRanges);
        if (ranges.length > 0) {
            return ranges[0];
        }

        return { start: '00:00', end: '23:59' };
    }

    function getAvailabilitySummary(item) {
        var mode = normalizeAvailabilityMode(item.availabilityMode);
        var ranges = normalizeTimeRanges(item.timeRanges);
        if (mode === 'AllDay' || ranges.length === 0) {
            return { text: '全天可用', badgeClass: 'route-badge-muted' };
        }

        var range = ranges[0];
        if (mode === 'AvailableOnly') {
            return { text: range.start + '-' + range.end + ' 可用', badgeClass: '' };
        }

        return { text: range.start + '-' + range.end + ' 不可用', badgeClass: 'route-badge-warning' };
    }

    function isValidTime(value) {
        return /^\d{2}:\d{2}$/.test(value || '');
    }

    function escHtml(str) {
        var d = document.createElement('div');
        d.textContent = str || '';
        return d.innerHTML;
    }
</script>
