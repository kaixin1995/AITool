@page
@model AITool.Web.Pages.Admin.AccessKeys.IndexModel
@{
    ViewData["Title"] = "访问密钥管理";
}

<h1>访问密钥管理</h1>

@if (Model.StatusMessage is not null)
{
    <div class="alert alert-@(Model.StatusSuccess ? "success" : "danger")">
        @Model.StatusMessage
    </div>
}

<form method="post" asp-page-handler="Create" class="mb-3">
    <div class="row g-2 align-items-end">
        <div class="col-auto">
            <label class="form-label">密钥名称</label>
            <input type="text" name="keyName" class="form-control" required />
        </div>
        <div class="col-auto">
            <label class="form-label">密钥值</label>
            <input type="text" name="accessKey" class="form-control" required />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary">创建密钥</button>
        </div>
    </div>
</form>

<table class="table table-striped">
    <thead>
        <tr>
            <th>密钥名称</th>
            <th>密钥值</th>
            <th>状态</th>
            <th>操作</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Keys)
        {
            <tr>
                <td>@item.KeyName</td>
                <td><code>@item.MaskedValue</code></td>
                <td>
                    <span class="badge bg-@(item.IsEnabled ? "success" : "secondary")">
                        @(item.IsEnabled ? "启用" : "禁用")
                    </span>
                </td>
                <td>
                    <form method="post" asp-page-handler="Toggle" asp-route-keyId="@item.KeyId" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-outline-@(item.IsEnabled ? "warning" : "success")">
                            @(item.IsEnabled ? "禁用" : "启用")
                        </button>
                    </form>
                    <form method="post" asp-page-handler="Delete" asp-route-keyId="@item.KeyId" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('确认删除该密钥？')">删除</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
