@page
@model AITool.Web.Pages.Admin.AccessKeys.IndexModel
@{
    ViewData["Title"] = "访问密钥管理";
}

<!-- 页面标题 -->
<div class="page-header">
    <div>
        <h2 class="page-title">访问密钥管理</h2>
        <p class="page-subtitle">管理用于访问代理服务的密钥，可限定每个密钥只能访问指定路由</p>
    </div>
</div>

<!-- 操作提示 -->
<div id="statusAlert" style="display:none;" class="alert">
    <span id="statusText"></span>
</div>

<!-- 新建密钥明文展示区域 -->
<div id="plainKeyBox" style="display:none;" class="alert alert-warning">
    <div><strong>请立即复制并妥善保存密钥：</strong></div>
    <div class="d-flex align-items-center gap-2 mt-2">
        <code id="plainKeyValue" style="font-size:14px;word-break:break-all;"></code>
        <button type="button" class="btn btn-sm btn-outline-primary" onclick="copyText(document.getElementById('plainKeyValue').textContent)">复制</button>
    </div>
</div>

<!-- 内联创建表单 -->
<div class="inline-form">
    <div class="row g-2 align-items-end">
        <div class="col-auto">
            <label class="form-label">密钥名称</label>
            <input type="text" id="inputKeyName" class="form-control" placeholder="输入密钥名称" />
        </div>
        <div class="col-auto">
            <button type="button" id="btnCreate" class="btn btn-primary" onclick="createKey()">创建密钥</button>
        </div>
    </div>
</div>

<!-- 密钥列表表格 -->
<div class="table-wrapper">
    <table class="table">
        <thead>
            <tr>
                <th>密钥名称</th>
                <th>密钥值</th>
                <th>允许路由</th>
                <th>状态</th>
                <th>操作</th>
            </tr>
        </thead>
        <tbody id="keyTableBody">
            @if (!Model.Keys.Any())
            {
                <tr id="emptyRow">
                    <td colspan="5">
                        <div class="table-empty">
                            <div class="table-empty-icon">🔑</div>
                            <div class="table-empty-text">暂无密钥，请在上方创建</div>
                        </div>
                    </td>
                </tr>
            }
            @foreach (var item in Model.Keys)
            {
                <tr data-key-id="@item.KeyId">
                    <td><strong>@item.KeyName</strong></td>
                    <td>
                        @if (string.IsNullOrEmpty(item.PlainKey))
                        {
                            <span class="text-muted">历史数据无明文</span>
                        }
                        else
                        {
                            <code class="plain-value">@item.PlainKey</code>
                        }
                    </td>
                    <td class="allowed-routes-cell">
                        <span class="badge bg-@(item.AllowedRouteNames.Count == 0 ? "secondary" : "info")">
                            @(item.AllowedRouteNamesText)
                        </span>
                    </td>
                    <td>
                        <span class="badge bg-@(item.IsEnabled ? "success" : "secondary")">
                            @(item.IsEnabled ? "启用" : "禁用")
                        </span>
                    </td>
                    <td>
                        <button type="button" class="btn btn-sm btn-outline-primary btn-copy"
                                data-plain-key="@item.PlainKey" onclick="copyKey(this)" title="复制真实密钥" @(string.IsNullOrEmpty(item.PlainKey) ? "disabled" : null)>
                            复制
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-secondary"
                                onclick="editRoutes('@item.KeyId', '@item.AllowedRouteNamesText', this)" title="编辑允许路由">
                            路由
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-@(item.IsEnabled ? "warning" : "success")"
                                onclick="toggleKey('@item.KeyId', this)">
                            @(item.IsEnabled ? "禁用" : "启用")
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-danger"
                                onclick="deleteKey('@item.KeyId', this)">
                            删除
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- 编辑路由 Modal -->
<div class="modal fade" id="editRoutesModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">编辑允许路由</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <span class="badge bg-secondary" id="modalCurrentRoutesLabel">当前: 全部</span>
                </div>
                <p class="text-muted small mb-2">勾选该密钥允许访问的路由入口。不勾选任何项 = 允许全部路由（包括后续新增的）。</p>
                <div class="mb-2 d-flex gap-2">
                    <button type="button" class="btn btn-sm btn-outline-primary" onclick="selectAllRoutes(true)">全选</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary" onclick="selectAllRoutes(false)">清空（=全部路由）</button>
                </div>
                <div id="editRouteCheckboxes" class="border rounded p-2" style="max-height:360px;overflow-y:auto;column-count:3;column-gap:0.75rem;">
                    @foreach (var entry in Model.RouteEntries)
                    {
                        <div class="form-check" style="break-inside:avoid;margin-bottom:0.25rem;">
                            <input class="form-check-input route-checkbox" type="checkbox" value="@entry.EntryName" id="route_@entry.EntryName" />
                            <label class="form-check-label text-truncate d-inline-block" for="route_@entry.EntryName" style="max-width:160px;" title="@entry.EntryName">@entry.EntryName</label>
                        </div>
                    }
                </div>
                @if (!Model.RouteEntries.Any())
                {
                    <p class="text-muted mt-2">暂无路由入口，请先在路由管理页创建。</p>
                }
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-primary" id="btnSaveRoutes" onclick="saveRoutes()">保存</button>
            </div>
        </div>
    </div>
</div>

<script>
    // 当前正在编辑路由的密钥 ID
    var editingKeyId = null;

    // 显示操作提示
    function showStatus(msg, success) {
        var alert = document.getElementById('statusAlert');
        var text = document.getElementById('statusText');
        alert.style.display = '';
        alert.className = 'alert ' + (success ? 'alert-success' : 'alert-danger');
        text.textContent = msg;
    }

    // 创建密钥（默认允许全部路由，不传 allowedRouteNames）
    function createKey() {
        var nameInput = document.getElementById('inputKeyName');
        var name = nameInput.value.trim();
        if (!name) { showStatus('请输入密钥名称', false); return; }

        var btn = document.getElementById('btnCreate');
        btn.disabled = true;
        btn.textContent = '创建中...';

        fetch('/api/admin/access-keys/create', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ keyName: name })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            btn.disabled = false;
            btn.textContent = '创建密钥';
            nameInput.value = '';

            if (data.message) { showStatus(data.message, false); return; }

            // 显示明文密钥
            document.getElementById('plainKeyBox').style.display = '';
            document.getElementById('plainKeyValue').textContent = data.plainKey;

            // 刷新页面以获取最新列表（含路由列）
            showStatus('密钥创建成功，正在刷新...', true);
            setTimeout(function() { location.reload(); }, 800);
        })
        .catch(function(err) {
            btn.disabled = false;
            btn.textContent = '创建密钥';
            showStatus('创建失败：' + err.message, false);
        });
    }

    // 编辑允许路由（打开 modal）
    function editRoutes(keyId, currentText, btn) {
        editingKeyId = keyId;
        document.getElementById('modalCurrentRoutesLabel').textContent = '当前: ' + (currentText || '全部');

        // 从行的 data 属性读取当前已选路由
        var row = btn.closest('tr');
        var currentRoutes = [];
        // 从后端渲染的 badge 文本无法精确还原选中项，改为从 API 重新读取
        fetch('/api/admin/access-keys')
            .then(function(r) { return r.json(); })
            .then(function(keys) {
                var found = keys.find(function(k) { return k.keyId === keyId; });
                currentRoutes = (found && found.allowedRouteNames) || [];
                // 勾选当前已允许的路由
                var checkboxes = document.querySelectorAll('.route-checkbox');
                checkboxes.forEach(function(cb) {
                    cb.checked = currentRoutes.indexOf(cb.value) >= 0;
                });

                var modal = new bootstrap.Modal(document.getElementById('editRoutesModal'));
                modal.show();
            })
            .catch(function() {
                var modal = new bootstrap.Modal(document.getElementById('editRoutesModal'));
                modal.show();
            });
    }

    // 全选/清空路由
    function selectAllRoutes(selectAll) {
        document.querySelectorAll('.route-checkbox').forEach(function(cb) {
            cb.checked = selectAll;
        });
    }

    // 保存路由权限
    function saveRoutes() {
        if (!editingKeyId) return;

        // 收集勾选的路由（空数组 = 允许全部，这是正确的语义）
        var selectedRoutes = Array.from(document.querySelectorAll('.route-checkbox:checked')).map(function(cb) {
            return cb.value;
        });

        var btn = document.getElementById('btnSaveRoutes');
        btn.disabled = true;
        btn.textContent = '保存中...';

        fetch('/api/admin/access-keys/update-routes/' + editingKeyId, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ allowedRouteNames: selectedRoutes })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            btn.disabled = false;
            btn.textContent = '保存';

            if (data.message) { showStatus(data.message, false); return; }

            // 关闭 modal
            var modalEl = document.getElementById('editRoutesModal');
            var modal = bootstrap.Modal.getInstance(modalEl);
            if (modal) modal.hide();

            // 刷新页面以更新表格
            showStatus('路由权限已更新', true);
            setTimeout(function() { location.reload(); }, 800);
        })
        .catch(function(err) {
            btn.disabled = false;
            btn.textContent = '保存';
            showStatus('保存失败：' + err.message, false);
        });
    }

    // 切换启用/禁用
    function toggleKey(keyId, btn) {
        btn.disabled = true;
        fetch('/api/admin/access-keys/toggle/' + keyId, { method: 'POST' })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.message) { showStatus(data.message, false); btn.disabled = false; return; }
            var row = btn.closest('tr');
            var badge = row.querySelector('td:nth-child(4) .badge');
            badge.className = 'badge bg-' + (data.isEnabled ? 'success' : 'secondary');
            badge.textContent = data.isEnabled ? '启用' : '禁用';
            btn.className = 'btn btn-sm btn-outline-' + (data.isEnabled ? 'warning' : 'success');
            btn.textContent = data.isEnabled ? '禁用' : '启用';
            btn.disabled = false;
        })
        .catch(function(err) {
            showStatus('操作失败：' + err.message, false);
            btn.disabled = false;
        });
    }

    // 删除密钥
    function deleteKey(keyId, btn) {
        if (!confirm('确认删除该密钥？')) return;
        btn.disabled = true;
        fetch('/api/admin/access-keys/delete/' + keyId, { method: 'POST' })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.message) { showStatus(data.message, false); btn.disabled = false; return; }
            var row = btn.closest('tr');
            row.remove();
            showStatus('密钥已删除', true);
        })
        .catch(function(err) {
            showStatus('删除失败：' + err.message, false);
            btn.disabled = false;
        });
    }

    // 复制真实密钥
    function copyKey(btn) {
        var plainKey = btn.getAttribute('data-plain-key');
        copyText(plainKey);
    }

    // 通用复制函数，兼容 HTTP 环境
    function copyText(text) {
        if (navigator.clipboard && window.isSecureContext) {
            navigator.clipboard.writeText(text).then(function() {
                showStatus('已复制到剪贴板', true);
            }).catch(function() {
                fallbackCopy(text);
            });
        } else {
            fallbackCopy(text);
        }
    }

    // HTTP 环境下的降级复制方案
    function fallbackCopy(text) {
        var textarea = document.createElement('textarea');
        textarea.value = text;
        textarea.style.position = 'fixed';
        textarea.style.opacity = '0';
        document.body.appendChild(textarea);
        textarea.select();
        try {
            document.execCommand('copy');
            showStatus('已复制到剪贴板', true);
        } catch (e) {
            showStatus('复制失败，请手动复制', false);
        }
        document.body.removeChild(textarea);
    }
</script>
