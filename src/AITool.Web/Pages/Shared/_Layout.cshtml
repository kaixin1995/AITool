@using AITool.Application.Operations
@using AITool.Web.Services
@inject ISystemRuntimeSettingsService RuntimeSettingsService
@inject AppVersionInfo AppVersion
<!DOCTYPE html>
<html lang="zh-CN" data-theme="classic">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AI Tool</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/theme.css" rel="stylesheet" />
    <!-- 防闪烁：在 CSS 加载前尽早从 LocalStorage 读取主题并应用到 <html> -->
    <script>
        (function() {
            var theme = localStorage.getItem('aitool.theme') || 'classic';
            document.documentElement.setAttribute('data-theme', theme);
            document.documentElement.setAttribute('data-bs-theme', theme === 'dark' ? 'dark' : 'light');
        })();
    </script>
</head>
<body>
    @{
        var runtimeSettings = await RuntimeSettingsService.GetOrCreateAsync();
    }
    <div class="app-wrapper" id="appWrapper">
        <!-- 侧边栏 -->
        <aside class="app-sidebar">
            <div class="sidebar-brand">
                <div class="sidebar-brand-main">
                    <div class="sidebar-brand-icon">AI</div>
                    <div class="sidebar-brand-content">
                        <div class="sidebar-brand-text">AI Tool</div>
                        <div class="sidebar-brand-sub">管理后台</div>
                    </div>
                </div>
                <button class="sidebar-collapse-toggle" id="sidebarCollapseToggle" type="button" title="折叠侧边栏">‹</button>
            </div>
            <nav class="sidebar-nav">
                <!-- 概览 -->
                <div class="sidebar-section">
                    <div class="sidebar-section-title">概览</div>
                    <a class="sidebar-link" href="/" title="仪表盘首页">
                        <span class="sidebar-link-icon">📊</span>仪表盘
                    </a>
                    <a class="sidebar-link" href="/Admin/Analytics" title="可视化分析">
                        <span class="sidebar-link-icon">🛰️</span>可视化分析
                    </a>
                    <a class="sidebar-link" href="/Admin/Chat" title="对话">
                        <span class="sidebar-link-icon">💬</span>对话
                    </a>
                </div>
                <!-- 资源管理 -->
                <div class="sidebar-section">
                    <div class="sidebar-section-title">资源管理</div>
                    <a class="sidebar-link" href="/Admin/Sites" title="站点管理">
                        <span class="sidebar-link-icon">🌐</span>站点管理
                    </a>
                    <a class="sidebar-link" href="/Admin/Models" title="模型库">
                        <span class="sidebar-link-icon">🧠</span>模型库
                    </a>
                </div>
                <!-- 代理配置 -->
                <div class="sidebar-section">
                    <div class="sidebar-section-title">代理配置</div>
                    <a class="sidebar-link" href="/Admin/Routes" title="路由规则">
                        <span class="sidebar-link-icon">🔀</span>路由规则
                    </a>
                    <a class="sidebar-link" href="/Admin/AccessKeys" title="访问密钥">
                        <span class="sidebar-link-icon">🔑</span>访问密钥
                    </a>
                </div>
                <!-- 监控运维 -->
                <div class="sidebar-section">
                    <div class="sidebar-section-title">监控运维</div>
                    <a class="sidebar-link" href="/Admin/Detection" title="模型检测">
                        <span class="sidebar-link-icon">🔍</span>模型检测
                    </a>
                    <a class="sidebar-link" href="/Admin/DetectionTasks" title="检测任务">
                        <span class="sidebar-link-icon">⏰</span>检测任务
                    </a>
                    <a class="sidebar-link" href="/Admin/ModelHealth" title="模型健康">
                        <span class="sidebar-link-icon">💊</span>模型健康
                    </a>
                    @if (runtimeSettings.DeveloperFeaturesEnabled)
                    {
                        <a class="sidebar-link" href="/Admin/Developer/Invocations" title="调试工具">
                            <span class="sidebar-link-icon">🛠️</span>调试工具
                        </a>
                    }
                    <a class="sidebar-link" href="/Admin/UsageLogs" title="使用日志">
                        <span class="sidebar-link-icon">📋</span>使用日志
                    </a>
                    <a class="sidebar-link" href="/Admin/System/Settings" title="系统设置">
                        <span class="sidebar-link-icon">⚙️</span>系统设置
                    </a>
                </div>
            </nav>
            <!-- 主题切换器 -->
            <div class="theme-switcher" id="themeSwitcher">
                <button class="theme-btn" data-theme-value="classic" title="经典主题">
                    <span class="theme-btn-icon">🏛️</span>经典
                </button>
                <button class="theme-btn" data-theme-value="modern" title="现代主题">
                    <span class="theme-btn-icon">🎨</span>现代
                </button>
                <button class="theme-btn" data-theme-value="minimal" title="简洁主题">
                    <span class="theme-btn-icon">⚪</span>简洁
                </button>
                <button class="theme-btn" data-theme-value="dark" title="暗夜主题">
                    <span class="theme-btn-icon">🌙</span>暗夜
                </button>
            </div>
        </aside>

        <!-- 遮罩层（移动端） -->
        <div class="sidebar-overlay" id="sidebarOverlay"></div>

        <!-- 主内容区 -->
        <div class="app-main">
            <!-- 顶部栏 -->
            <header class="app-topbar">
                <div class="d-flex align-items-center gap-3">
                    <!-- 移动端菜单按钮 -->
                    <button class="sidebar-toggle" id="sidebarToggle" type="button">☰</button>
                    <h1 class="app-topbar-title">@ViewData["Title"]</h1>
                </div>
                <div class="app-topbar-right">
                    <span class="text-secondary" style="font-size:13px;">AI Tool v@(AppVersion.Value)</span>
                </div>
            </header>

            <!-- 页面内容 -->
            <main class="app-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <!-- 侧边栏 + 主题切换逻辑 -->
    <script>
        (function() {
            var toggle = document.getElementById('sidebarToggle');
            var collapseToggle = document.getElementById('sidebarCollapseToggle');
            var wrapper = document.getElementById('appWrapper');
            var sidebar = document.querySelector('.app-sidebar');
            var overlay = document.getElementById('sidebarOverlay');
            if (toggle && sidebar && overlay) {
                toggle.addEventListener('click', function() {
                    sidebar.classList.toggle('show');
                    overlay.classList.toggle('show');
                });
                overlay.addEventListener('click', function() {
                    sidebar.classList.remove('show');
                    overlay.classList.remove('show');
                });
            }
            function applySidebarCollapsed(collapsed) {
                if (!wrapper || !collapseToggle) {
                    return;
                }
                wrapper.classList.toggle('sidebar-collapsed', collapsed);
                collapseToggle.textContent = collapsed ? '›' : '‹';
                collapseToggle.title = collapsed ? '展开侧边栏' : '折叠侧边栏';
            }
            if (collapseToggle && wrapper) {
                applySidebarCollapsed(localStorage.getItem('aitool.sidebarCollapsed') === 'true');
                collapseToggle.addEventListener('click', function() {
                    var collapsed = !wrapper.classList.contains('sidebar-collapsed');
                    localStorage.setItem('aitool.sidebarCollapsed', collapsed ? 'true' : 'false');
                    applySidebarCollapsed(collapsed);
                });
            }
            /* 高亮当前页面的侧边栏链接 */
            var links = document.querySelectorAll('.sidebar-link');
            var path = window.location.pathname;
            links.forEach(function(link) {
                if (link.getAttribute('href') === path) {
                    link.classList.add('active');
                }
            });

            /* 主题切换逻辑 */
            function applyTheme(theme) {
                document.documentElement.setAttribute('data-theme', theme);
                document.documentElement.setAttribute('data-bs-theme', theme === 'dark' ? 'dark' : 'light');
                localStorage.setItem('aitool.theme', theme);
                /* 更新切换器高亮 */
                document.querySelectorAll('.theme-btn').forEach(function(btn) {
                    btn.classList.toggle('active', btn.getAttribute('data-theme-value') === theme);
                });
            }
            /* 初始化高亮当前主题 */
            var currentTheme = localStorage.getItem('aitool.theme') || 'classic';
            applyTheme(currentTheme);
            /* 绑定点击 */
            document.querySelectorAll('.theme-btn').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    applyTheme(btn.getAttribute('data-theme-value'));
                });
            });
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
